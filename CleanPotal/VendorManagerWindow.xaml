<Window x:Class="CleanPotal.VendorManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="업체 기준 정보 관리" Width="1340" Height="950"
        WindowStartupLocation="CenterOwner" Background="#F8FAFC"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        SnapsToDevicePixels="True" UseLayoutRounding="True">

    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1E3A8A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E2E8F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Foreground" Value="#DC2626"/>
            <Setter Property="BorderBrush" Value="#FECACA"/>
            <Setter Property="Background" Value="#FEF2F2"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FEE2E2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SegmentedTabStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}" CornerRadius="20" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#0F172A"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="#E2E8F0"/>
                                <Setter Property="Foreground" Value="#0F172A"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="MinHeight" Value="40"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EFF6FF"/>
                    <Setter Property="Foreground" Value="#1E3A8A"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8FAFC"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="업체 기준 정보 관리" FontSize="22" FontWeight="ExtraBold" Foreground="#0F172A" Margin="0,0,16,0"/>
                    <TextBlock x:Name="TxtSummary" Text="로딩 중..." VerticalAlignment="Center" Foreground="#64748B" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="⚙️ 전역 설정 (마스터 DB / 템플릿)" Style="{StaticResource SecondaryButton}" Margin="0,0,12,0" Click="BtnOpenSettings_Click"/>
                    <Button Content="저장하기" Style="{StaticResource PrimaryButton}" Width="120" Click="BtnSave_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Margin="0,0,24,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Padding="16,16,16,0">
                        <Border Background="#F1F5F9" CornerRadius="8" Padding="12,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="🔍" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox x:Name="SearchBox" Grid.Column="1" Background="Transparent" BorderThickness="0" TextChanged="SearchBox_TextChanged" Foreground="#0F172A" VerticalContentAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="업체명 검색..." Foreground="#94A3B8" VerticalAlignment="Center" IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style></TextBlock>
                            </Grid>
                        </Border>
                    </Border>
                    <Border Grid.Row="1" Padding="16,12,16,12" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <RadioButton Content="전체" Style="{StaticResource SegmentedTabStyle}" IsChecked="True" Checked="FilterTab_Checked"/>
                            <RadioButton Content="일반" Style="{StaticResource SegmentedTabStyle}" Checked="FilterTab_Checked"/>
                            <RadioButton Content="SEMES" Style="{StaticResource SegmentedTabStyle}" Checked="FilterTab_Checked"/>
                            <RadioButton Content="QTZ" Style="{StaticResource SegmentedTabStyle}" Checked="FilterTab_Checked"/>
                        </StackPanel>
                    </Border>
                    <ListBox x:Name="VendorListBox" Grid.Row="2" Background="Transparent" BorderThickness="0" Margin="0,8" SelectionChanged="VendorListBox_SelectionChanged" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="16,12"/>
                                <Setter Property="Margin" Value="8,2"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" Background="Transparent" CornerRadius="8">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#F1F5F9"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#EFF6FF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding VendorName}" FontSize="15" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,4"/>
                                        <TextBlock Foreground="#64748B" FontSize="12"><Run Text="분류: "/><Run Text="{Binding Category, TargetNullValue='미지정', FallbackValue='미지정'}" FontWeight="SemiBold"/></TextBlock>
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="#F1F5F9" CornerRadius="6" Padding="8,4" VerticalAlignment="Center">
                                        <TextBlock Text="▶" Foreground="#94A3B8" FontSize="10"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Button Grid.Row="2" Content="+ 새 거래처" Style="{StaticResource SecondaryButton}" VerticalAlignment="Bottom" Margin="16" Click="AddVendor_Click"/>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="32">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="DetailRootPanel">
                        <Grid Margin="0,0,0,32">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="기본 정보" FontSize="18" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,16"/>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="1*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,16">
                                        <TextBlock Text="업체명" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <Border Background="#F8FAFC" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6">
                                            <TextBox Text="{Binding VendorName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" BorderThickness="0" Padding="12,10" FontSize="15" FontWeight="Bold" Foreground="#0F172A"/>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,16">
                                        <TextBlock Text="분류" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <ComboBox Width="120" HorizontalAlignment="Left" Foreground="#1E293B" BorderBrush="#D1D5DB" 
                                                  SelectedValue="{Binding Category, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                  SelectedValuePath="Content">
                                            <ComboBoxItem Content="일반"/>
                                            <ComboBoxItem Content="SEMES"/>
                                            <ComboBoxItem Content="QTZ"/>
                                            <ComboBoxItem Content="기타"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.ColumnSpan="3">
                                        <TextBlock Text="기본 네트워크 경로 (베이스 폴더)" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Background="#F8FAFC" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6">
                                                <TextBox Text="{Binding BasePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" BorderThickness="0" Padding="12,10"/>
                                            </Border>
                                            <Button Grid.Column="1" Content="찾기" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Padding="16,0" Click="BrowseFolder_Click"/>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                            <Button Grid.Column="1" Content="이 업체 삭제" Style="{StaticResource DangerButton}" VerticalAlignment="Top" Click="DeleteVendor_Click"/>
                        </Grid>

                        <Border Height="1" Background="#E2E8F0" Margin="0,0,0,32"/>
                        <StackPanel Margin="0,0,0,32">
                            <Grid Margin="0,0,0,16">
                                <TextBlock Text="사업장 주소 관리" FontSize="18" FontWeight="Bold" Foreground="#0F172A" VerticalAlignment="Center"/>
                                <Button Content="+ 주소 추가" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Right" Click="AddAddress_Click"/>
                            </Grid>
                            <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
                                <DataGrid x:Name="DetailGrid" AutoGenerateColumns="False" CanUserAddRows="False" Background="White" BorderThickness="0" HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9" VirtualizingPanel.ScrollUnit="Pixel" VerticalAlignment="Top">
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="대표" Width="60">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <RadioButton IsChecked="{Binding IsMain, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="구분(명칭)" Width="100">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox Text="{Binding LocationName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="전체 주소" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox Text="{Binding FullAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="삭제" Width="70">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="삭제" Focusable="False" Height="26" Margin="4" Style="{StaticResource DangerButton}" Padding="0" Click="DeleteAddress_Click"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                        </StackPanel>
                        <StackPanel>
                            <Grid Margin="0,0,0,16">
                                <TextBlock Text="담당자 연락처 관리" FontSize="18" FontWeight="Bold" Foreground="#0F172A" VerticalAlignment="Center"/>
                                <Button Content="+ 담당자 추가" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Right" Click="AddManager_Click"/>
                            </Grid>
                            <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
                                <DataGrid x:Name="ManagersDataGrid" AutoGenerateColumns="False" CanUserAddRows="False" Background="White" BorderThickness="0" HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9" VirtualizingPanel.ScrollUnit="Pixel" VerticalAlignment="Top">
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="이름" Width="100">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox Text="{Binding ManagerName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="연락처" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox Text="{Binding ContactNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="삭제" Width="70">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="삭제" Focusable="False" Height="26" Margin="4" Style="{StaticResource DangerButton}" Padding="0" Click="DeleteManager_Click"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border x:Name="SettingsOverlay" Grid.RowSpan="2" Background="#800F172A" Visibility="Collapsed">
            <Border Background="White" CornerRadius="12" Width="600" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="32">
                <StackPanel>
                    <TextBlock Text="⚙️ 전역 설정 관리" FontSize="20" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,24"/>
                    <TextBlock Text="마스터 데이터베이스 경로" FontWeight="Bold" Foreground="#475569" Margin="0,0,0,8"/>

                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="#F8FAFC" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6">
                            <TextBox x:Name="TxtMasterDbPath" Background="Transparent" BorderThickness="0" Padding="10" IsReadOnly="True" Foreground="#64748B"/>
                        </Border>
                        <Button Grid.Column="1" Content="변경" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Padding="16,0" Click="BtnChangeMasterDb_Click"/>
                    </Grid>

                    <TextBlock Text="글로벌 출고증 템플릿 맵핑" FontWeight="Bold" Foreground="#475569" Margin="0,0,0,8"/>
                    <DataGrid x:Name="GlobalTemplatesGrid" AutoGenerateColumns="False" CanUserAddRows="False" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" HeadersVisibility="Column" GridLinesVisibility="Horizontal" Margin="0,0,0,32" MaxHeight="300" VirtualizingPanel.ScrollUnit="Pixel">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="제품 코드" Binding="{Binding ProductCode}" Width="80" IsReadOnly="True"/>
                            <DataGridTextColumn Header="제품명" Binding="{Binding ProductName}" Width="120" IsReadOnly="True"/>
                            <DataGridTemplateColumn Header="서식 파일 경로 (xltx)" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid Margin="4,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Text="{Binding TemplatePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" IsReadOnly="True" Foreground="#475569"/>
                                            <Button Grid.Column="1" Content="찾기" Focusable="False" Width="50" Height="28" Margin="4,0,0,0" Style="{StaticResource SecondaryButton}" Padding="0" Click="BrowseGlobalTemplate_Click"/>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <Button Content="변경사항 저장 후 닫기" Focusable="False" Height="50" Style="{StaticResource PrimaryButton}" Click="BtnCloseSettings_Click"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>