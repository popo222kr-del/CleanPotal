<UserControl x:Class="CleanPotal.DispatchCertificateBatchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F1F5F9" Loaded="UserControl_Loaded"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             SnapsToDevicePixels="True" UseLayoutRounding="True">

    <UserControl.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernScrollBar" TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="Margin" Value="0,2,2,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#94A3B8" CornerRadius="4"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SolidDataGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#94A3B8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="#FFFFFF"/>
            <Setter Property="AlternatingRowBackground" Value="#F8FAFC"/>
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#CBD5E1"/>
            <Setter Property="VerticalGridLinesBrush" Value="#CBD5E1"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="RowHeight" Value="34"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#E2E8F0"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="FontWeight" Value="ExtraBold"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderBrush" Value="#94A3B8"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="GridTextBlock" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24" VerticalAlignment="Top">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="초기화" Width="80" Height="36" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Click="BtnReset_Click"/>
                <Button Content="생성이력 조회" Width="120" Height="36" Style="{StaticResource SecondaryButton}" Click="BtnShowHistory_Click"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" x:Name="AetsFilePanel" Height="160" Background="#FFFFFF" BorderBrush="#94A3B8" BorderThickness="1" CornerRadius="6" Margin="0,0,0,16" AllowDrop="True" PreviewDragOver="AetsPanel_PreviewDragOver" Drop="AetsPanel_Drop">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="BorderBrush" Value="#CBD5E1"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#EFF6FF"/>
                            <Setter Property="BorderBrush" Value="#2563EB"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="이곳에 고객사 세정 의뢰 양식(.xlsx, .xltx)을 끌어다 놓으세요" FontWeight="Bold" FontSize="16" Foreground="#1E293B" HorizontalAlignment="Center"/>
                <TextBlock x:Name="TxtAetsStatus" Text="파일을 놓으면 즉시 분석을 시작합니다." FontSize="13" Foreground="#64748B" Margin="0,8,0,0" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="White" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="6" Padding="16,12" Margin="0,0,0,16">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="[ 반출 정보 요약 ]" FontWeight="ExtraBold" Foreground="#2563EB" VerticalAlignment="Center" Margin="0,0,20,0"/>

                <TextBlock Text="업체명 :" Foreground="#64748B" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock x:Name="TxtSummaryCompany" Text="-" FontWeight="ExtraBold" Foreground="#0F172A" VerticalAlignment="Center" Width="90" Margin="0,0,10,0"/>

                <TextBlock Text="담당자 :" Foreground="#64748B" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock x:Name="TxtSummaryManager" Text="-" FontWeight="ExtraBold" Foreground="#0F172A" VerticalAlignment="Center" Width="70" Margin="0,0,10,0"/>

                <TextBlock Text="품목명 :" Foreground="#64748B" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock x:Name="TxtSummaryPartName" Text="-" FontWeight="ExtraBold" Foreground="#0F172A" VerticalAlignment="Center" Width="140" Margin="0,0,10,0" TextTrimming="CharacterEllipsis" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>

                <TextBlock Text="총 수량 :" Foreground="#64748B" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock x:Name="TxtSummaryTotalQty" Text="-" FontWeight="ExtraBold" Foreground="#0F172A" VerticalAlignment="Center" Width="50" Margin="0,0,10,0"/>

                <TextBlock Text="사용 공정 :" Foreground="#64748B" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock x:Name="TxtSummaryProcess" Text="-" FontWeight="ExtraBold" Foreground="#0F172A" VerticalAlignment="Center" Width="70" Margin="0,0,10,0"/>

                <TextBlock Text="제품 상태 :" Foreground="#64748B" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock x:Name="TxtSummaryStatus" Text="-" FontWeight="ExtraBold" Foreground="#0F172A" VerticalAlignment="Center" Width="70" Margin="0,0,10,0"/>

                <TextBlock Text="반출일 :" Foreground="#64748B" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock x:Name="TxtSummaryDate" Text="-" FontWeight="ExtraBold" Foreground="#0F172A" VerticalAlignment="Center"/>
            </WrapPanel>
        </Border>

        <Button x:Name="BtnRun" Grid.Row="3" Content="성적서 자동 생성 실행" Width="180" Height="42" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Right" Margin="0,0,0,12" Click="BtnRun_Click"/>

        <Grid Grid.Row="4" MaxHeight="550">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Background="#334155" BorderBrush="#334155" BorderThickness="1" Padding="14,10" CornerRadius="6,6,0,0">
                <TextBlock Text="데이터 검증 및 처리 결과 통합 목록" FontWeight="Bold" Foreground="White" FontSize="14"/>
            </Border>

            <DataGrid x:Name="AetsPreviewGrid" Grid.Row="1" Style="{StaticResource SolidDataGridStyle}">
                <DataGrid.Resources>
                    <Style TargetType="ScrollBar" BasedOn="{StaticResource ModernScrollBar}"/>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="선택" Width="50">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsChecked, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="구분" Binding="{Binding ProductCode}" Width="60">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource GridTextBlock}">
                                <Setter Property="FontWeight" Value="ExtraBold"/>
                                <Setter Property="Foreground" Value="#059669"/>
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="품목명" Binding="{Binding PartName}" Width="160" ElementStyle="{StaticResource GridTextBlock}"/>

                    <DataGridTextColumn Header="도면명" Binding="{Binding ItemCode}" Width="140">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource GridTextBlock}">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="#2563EB"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="수량" Binding="{Binding Qty}" Width="60">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource GridTextBlock}">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="결과" Binding="{Binding Result}" Width="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource GridTextBlock}">
                                <Setter Property="FontWeight" Value="ExtraBold"/>
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Result}" Value="성공">
                                        <Setter Property="Foreground" Value="#059669"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Result}" Value="실패">
                                        <Setter Property="Foreground" Value="#DC2626"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Result}" Value="대기">
                                        <Setter Property="Foreground" Value="#94A3B8"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Result}" Value="처리중...">
                                        <Setter Property="Foreground" Value="#F59E0B"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="처리 상세 메시지" Binding="{Binding Message}" Width="*" ElementStyle="{StaticResource GridTextBlock}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <Border x:Name="HistoryOverlay" Grid.RowSpan="5" Background="#CC000000" Visibility="Collapsed" Panel.ZIndex="1000">
            <Border Background="White" Width="1000" Height="650" CornerRadius="8" Padding="24" BorderBrush="#E2E8F0" BorderThickness="1" VerticalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="성적서 생성이력 조회" FontSize="20" FontWeight="Bold" Foreground="#0F172A"/>
                        <Button Content="닫기" Width="80" Height="36" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Right" Click="BtnCloseHistory_Click"/>
                    </Grid>
                    <Grid Grid.Row="1" Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="검색어 (업체/품목):" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,8,0"/>
                            <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="4" Padding="8,0" Background="#F8FAFC" Width="200" Height="36" Margin="0,0,16,0">
                                <TextBox x:Name="TxtHistorySearch" VerticalContentAlignment="Center" Background="Transparent" BorderThickness="0" TextChanged="TxtHistorySearch_TextChanged"/>
                            </Border>
                            <Button Content="새로고침" Width="100" Height="36" Style="{StaticResource SecondaryButton}" Click="BtnRefreshHistory_Click"/>
                        </StackPanel>
                    </Grid>
                    <DataGrid x:Name="HistoryGrid" Grid.Row="2" Style="{StaticResource SolidDataGridStyle}">
                        <DataGrid.Resources>
                            <Style TargetType="ScrollBar" BasedOn="{StaticResource ModernScrollBar}"/>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="생성일시" Binding="{Binding CreateDate}" Width="150" ElementStyle="{StaticResource GridTextBlock}"/>
                            <DataGridTextColumn Header="등록번호" Binding="{Binding RegNo}" Width="160" ElementStyle="{StaticResource GridTextBlock}"/>
                            <DataGridTextColumn Header="업체명" Binding="{Binding CompanyName}" Width="120" ElementStyle="{StaticResource GridTextBlock}"/>
                            <DataGridTextColumn Header="제품구분" Binding="{Binding ProductType}" Width="100" ElementStyle="{StaticResource GridTextBlock}"/>
                            <DataGridTextColumn Header="품목명" Binding="{Binding PartName}" Width="180" ElementStyle="{StaticResource GridTextBlock}"/>
                            <DataGridTextColumn Header="수량" Binding="{Binding Qty}" Width="60" ElementStyle="{StaticResource GridTextBlock}"/>
                            <DataGridTextColumn Header="담당자" Binding="{Binding ManagerName}" Width="100" ElementStyle="{StaticResource GridTextBlock}"/>
                            <DataGridTextColumn Header="저장경로" Binding="{Binding SavePath}" Width="*" ElementStyle="{StaticResource GridTextBlock}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>