<Window x:Class="CleanPotal.ScheduleRegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="일정 및 교육 등록" Width="450" 
        WindowStartupLocation="CenterOwner" WindowStyle="ToolWindow" ResizeMode="NoResize" Background="#F8FAFC"
        SnapsToDevicePixels="True" UseLayoutRounding="True" SizeToContent="Height">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="세정팀 일정 등록" FontSize="20" FontWeight="Bold" Foreground="#0F172A"/>
            <TextBlock Text="시스템에 등록된 일정은 인수인계 및 달력에 즉시 반영됩니다." FontSize="12" Foreground="#64748B" Margin="0,4,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="2">
            <TabControl x:Name="MainTab" Background="White" BorderThickness="0" Padding="8,10">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border Name="Border" BorderBrush="#E2E8F0" BorderThickness="0,0,0,2" Margin="0,0,10,0" Padding="10,6">
                                        <ContentPresenter x:Name="ContentSite" ContentSource="Header" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Border" Property="BorderBrush" Value="#2563EB"/>
                                            <Setter Property="Foreground" Value="#2563EB"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="False">
                                            <Setter Property="Foreground" Value="#64748B"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <TabItem Header="🏖️ 근태/휴가 등록" FontSize="14" FontWeight="SemiBold">
                    <StackPanel Margin="10,16,10,10">
                        <TextBlock Text="직원 이름" FontSize="13" Foreground="#475569" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ComboBox x:Name="CmbShiftName" Height="38" BorderBrush="#CBD5E1" Margin="0,0,0,14" VerticalContentAlignment="Center" Padding="10,0"/>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="시작일" FontSize="13" Foreground="#475569" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <DatePicker x:Name="DpShiftStart" Height="38" BorderBrush="#CBD5E1" VerticalContentAlignment="Center" SelectedDateChanged="DpShiftStart_SelectedDateChanged"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="종료일" FontSize="13" Foreground="#475569" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <DatePicker x:Name="DpShiftEnd" Height="38" BorderBrush="#CBD5E1" VerticalContentAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="근태 구분" FontSize="13" Foreground="#475569" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ComboBox x:Name="CmbShiftType" Height="38" BorderBrush="#CBD5E1" VerticalContentAlignment="Center" Padding="10,0" Margin="0,0,0,14" SelectionChanged="CmbShiftType_SelectionChanged">
                            <ComboBoxItem Content="연차" IsSelected="True"/>
                            <ComboBoxItem Content="오전반차"/>
                            <ComboBoxItem Content="오후반차"/>
                            <ComboBoxItem Content="반반차"/>
                            <ComboBoxItem Content="휴무"/>
                            <ComboBoxItem Content="특근"/>
                        </ComboBox>

                        <ComboBox x:Name="CmbHalfTime" Height="38" BorderBrush="#CBD5E1" VerticalContentAlignment="Center" Padding="10,0" Margin="0,0,0,4" Visibility="Collapsed">
                            <ComboBoxItem Content="08:30~10:30" IsSelected="True"/>
                            <ComboBoxItem Content="10:30~12:30"/>
                            <ComboBoxItem Content="13:30~15:30"/>
                            <ComboBoxItem Content="15:30~17:30"/>
                        </ComboBox>
                    </StackPanel>
                </TabItem>

                <TabItem x:Name="TabEdu" Header="📖 교육 일정 등록" FontSize="14" FontWeight="SemiBold">
                    <StackPanel Margin="10,16,10,10">
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="팀 선택" FontSize="13" Foreground="#475569" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <ComboBox x:Name="CmbEduTeam" Height="38" BorderBrush="#CBD5E1" VerticalContentAlignment="Center" Padding="10,0" SelectionChanged="CmbEduTeam_SelectionChanged"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="대상자 이름" FontSize="13" Foreground="#475569" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <ComboBox x:Name="CmbEduName" Height="38" BorderBrush="#CBD5E1" VerticalContentAlignment="Center" Padding="10,0"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="교육/프로젝트명" FontSize="13" Foreground="#475569" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtEduCourse" Height="38" Padding="10,0" VerticalContentAlignment="Center" BorderBrush="#CBD5E1" Margin="0,0,0,14"/>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="시작일" FontSize="13" Foreground="#475569" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <DatePicker x:Name="DpEduStart" Height="38" BorderBrush="#CBD5E1" VerticalContentAlignment="Center" SelectedDateChanged="DpEduStart_SelectedDateChanged"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="종료일" FontSize="13" Foreground="#475569" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <DatePicker x:Name="DpEduEnd" Height="38" BorderBrush="#CBD5E1" VerticalContentAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="교육 내용 및 방식 (직접 입력)" FontSize="13" Foreground="#475569" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtEduMethod" Height="38" Padding="10,0" VerticalContentAlignment="Center" BorderBrush="#CBD5E1" Tag="예: 6시그마, 신입사원 교육, 집합교육 등"/>
                    </StackPanel>
                </TabItem>
            </TabControl>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="취소" Width="85" Height="40" Background="White" BorderBrush="#CBD5E1" Foreground="#475569" FontWeight="SemiBold" Margin="0,0,10,0" Click="BtnCancel_Click"/>
            <Button Content="저장하기" Width="100" Height="40" Background="#2563EB" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>