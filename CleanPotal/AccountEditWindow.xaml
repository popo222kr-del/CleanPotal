<Window x:Class="CleanPotal.AccountEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="내 계정 관리" Height="450" Width="380"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#F8FAFC"
        SnapsToDevicePixels="True" UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType" RenderOptions.BitmapScalingMode="HighQuality">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="내 계정 정보 수정" FontSize="20" FontWeight="Bold" Foreground="#1E293B"/>
            <TextBlock Text="아이디와 비밀번호를 안전하게 변경할 수 있습니다." FontSize="12" Foreground="#64748B" Margin="0,4,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1">
            <TextBlock Text="변경할 아이디" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6"/>
            <Border Background="White" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="6" Height="38" Margin="0,0,0,16">
                <TextBox x:Name="TxtEditId" BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center" Padding="10,0"/>
            </Border>

            <TextBlock Text="현재 비밀번호 확인" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6"/>
            <Border Background="White" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="6" Height="38" Margin="0,0,0,16">
                <PasswordBox x:Name="TxtCurrentPw" BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center" Padding="10,0"/>
            </Border>

            <Separator Background="#E2E8F0" Margin="0,5,0,15"/>

            <TextBlock Text="새 비밀번호" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6"/>
            <Border Background="White" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="6" Height="38" Margin="0,0,0,16">
                <PasswordBox x:Name="TxtNewPw" BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center" Padding="10,0"/>
            </Border>

            <TextBlock Text="새 비밀번호 확인" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6"/>
            <Border Background="White" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="6" Height="38">
                <PasswordBox x:Name="TxtNewPwConfirm" BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center" Padding="10,0"/>
            </Border>
        </StackPanel>

        <UniformGrid Grid.Row="2" Columns="2" Height="45" Margin="0,10,0,0">
            <Button Content="취소" Margin="0,0,5,0" Background="#F1F5F9" BorderBrush="#CBD5E1" Click="BtnCancel_Click"/>
            <Button Content="변경 내용 저장" Margin="5,0,0,0" Background="#2563EB" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="BtnSave_Click"/>
        </UniformGrid>
    </Grid>
</Window>