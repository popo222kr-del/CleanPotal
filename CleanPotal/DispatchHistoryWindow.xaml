<Window x:Class="CleanPotal.DispatchHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="과거 배차 이력 조회 및 수정" Height="860" Width="1650"
        WindowStartupLocation="CenterOwner" Background="#F8FAFC"
        TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType"
        RenderOptions.BitmapScalingMode="HighQuality" UseLayoutRounding="True" SnapsToDevicePixels="True">

    <Window.Resources>
        <Style x:Key="CenterTextColumnStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <Style x:Key="TopButtonStyle" TargetType="Button" BasedOn="{StaticResource MacSecondaryButtonStyle}">
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinWidth" Value="92"/>
        </Style>

        <Style x:Key="PrimaryTopButtonStyle" TargetType="Button" BasedOn="{StaticResource MacPrimaryButtonStyle}">
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinWidth" Value="110"/>
        </Style>

        <Style x:Key="GridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,14"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
        </Style>

        <Style x:Key="GridCellStyle" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <Style x:Key="PlainTextBoxStyle" TargetType="TextBox">
            <Setter Property="MinHeight" Value="58"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="8,10"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="EditorComboStyle" TargetType="ComboBox">
            <Setter Property="IsEditable" Value="True"/>
            <Setter Property="IsTextSearchEnabled" Value="False"/>
            <Setter Property="StaysOpenOnEdit" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ValidationCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid x:Name="CaptureTarget" Background="#F8FAFC">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid x:Name="TitleGrid" Grid.Row="0" Margin="32,28,32,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock x:Name="MainTitleText" Text="과거 배차 이력 조회 및 수정" FontSize="30" FontWeight="ExtraBold" Foreground="#0F172A"/>
                <TextBlock x:Name="TxtTitleDate" Margin="0,10,0,0" Text="배차 LIST" FontSize="24" FontWeight="SemiBold" Foreground="#475569"/>
            </StackPanel>

            <StackPanel x:Name="ActionButtonsPanel" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="어제" Style="{StaticResource TopButtonStyle}" Click="BtnYesterday_Click"/>
                <Button Content="오늘" Style="{StaticResource TopButtonStyle}" Margin="8,0,0,0" Click="BtnToday_Click"/>
                <Button Content="내일" Style="{StaticResource TopButtonStyle}" Margin="8,0,0,0" Click="BtnTomorrow_Click"/>

                <Border Background="#EEF2FF" CornerRadius="0" Padding="14,0" Margin="14,0,0,0" Height="40">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="조회일" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,10,0"/>
                        <DatePicker x:Name="HistoryDatePicker" Width="132" FontSize="14" SelectedDateChanged="HistoryDatePicker_SelectedDateChanged" BorderThickness="0" Background="Transparent"/>
                    </StackPanel>
                </Border>

                <Button Content="+ 행 추가" Style="{StaticResource TopButtonStyle}" Margin="14,0,0,0" Click="BtnAddRow_Click"/>
                <Button Content="변경 저장" Style="{StaticResource PrimaryTopButtonStyle}" Margin="8,0,0,0" Click="BtnSave_Click"/>
                <Button Content="검토본 복사" Style="{StaticResource TopButtonStyle}" Margin="8,0,0,0" Click="BtnCapture_Click"/>
                <Button Content="닫기" Style="{StaticResource TopButtonStyle}" Margin="8,0,0,0" Click="BtnClose_Click"/>
            </StackPanel>
        </Grid>

        <Grid x:Name="SummaryCardsPanel" Grid.Row="1" Margin="32,0,32,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.5*"/>
                <ColumnDefinition Width="1.55*"/>
                <ColumnDefinition Width="1.15*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource ValidationCardStyle}" Background="White" BorderBrush="#E2E8F0">
                <StackPanel>
                    <TextBlock Text="운영 요약" FontWeight="Bold" Foreground="#0F172A"/>
                    <TextBlock Text="{Binding SummaryText}" Margin="0,6,0,0" Foreground="#475569" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource ValidationCardStyle}" Background="#FFF7ED" BorderBrush="#FDBA74">
                <StackPanel>
                    <TextBlock Text="검증 상태" FontWeight="Bold" Foreground="#9A3412"/>
                    <TextBlock Text="{Binding ValidationSummaryText}" Margin="0,6,0,0" Foreground="#9A3412" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource ValidationCardStyle}" Background="#EFF6FF" BorderBrush="#93C5FD" Margin="0">
                <StackPanel>
                    <TextBlock Text="검토 상태" FontWeight="Bold" Foreground="#1D4ED8"/>
                    <TextBlock Text="{Binding SaveStateText}" Margin="0,6,0,0" Foreground="#1D4ED8" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border x:Name="ListContainer" Grid.Row="2" Background="White" Margin="32,0,32,32" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="0" VerticalAlignment="Top" SnapsToDevicePixels="True">
            <Grid>
                <DataGrid x:Name="DispatchDataGrid"
                          Margin="0"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          SnapsToDevicePixels="True"
                          UseLayoutRounding="True"
                          Background="Transparent"
                          BorderThickness="0"
                          MinRowHeight="58"
                          AlternationCount="2"
                          ColumnHeaderStyle="{StaticResource GridHeaderStyle}"
                          CellStyle="{StaticResource GridCellStyle}">

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Style.Triggers>
                                <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                    <Setter Property="Background" Value="#F8FAFC"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#EEF2FF"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#E0E7FF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.Resources>
                        <Style TargetType="ScrollBar">
                            <Setter Property="Width" Value="8"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ScrollBar">
                                        <Grid Background="Transparent">
                                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                                <Track.Thumb>
                                                    <Thumb>
                                                        <Thumb.Template>
                                                            <ControlTemplate TargetType="Thumb">
                                                                <Border CornerRadius="0" Background="#CBD5E1" Margin="2,0"/>
                                                            </ControlTemplate>
                                                        </Thumb.Template>
                                                    </Thumb>
                                                </Track.Thumb>
                                            </Track>
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="No" Binding="{Binding DisplayOrder}" Width="62" IsReadOnly="True" ElementStyle="{StaticResource CenterTextColumnStyle}"/>

                        <DataGridTemplateColumn Header="업체명" Width="1.5*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Padding="4">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="CornerRadius" Value="0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsVendorMissing}" Value="True">
                                                        <Setter Property="Background" Value="#FEE2E2"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <ComboBox ItemsSource="{Binding DataContext.VendorNameOptions, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                  Text="{Binding VendorName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Style="{StaticResource EditorComboStyle}"
                                                  VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                                                  HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                  SelectionChanged="VendorCombo_SelectionChanged"
                                                  LostFocus="VendorCombo_LostFocus"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="반출" Width="1.6*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding OutgoingDetails, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource PlainTextBoxStyle}"
                                             PreviewKeyDown="TextBox_PreviewKeyDown"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="납품" Width="2.1*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding IncomingDetails, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource PlainTextBoxStyle}"
                                             TextAlignment="Left"
                                             PreviewKeyDown="TextBox_PreviewKeyDown"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="담당자" Width="1.4*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Padding="4">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="CornerRadius" Value="0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsManagerMissing}" Value="True">
                                                        <Setter Property="Background" Value="#FEF3C7"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <ComboBox ItemsSource="{Binding AvailableManagerNames}"
                                                  Text="{Binding ManagerName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Style="{StaticResource EditorComboStyle}"
                                                  VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                                                  HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                  SelectionChanged="ManagerCombo_SelectionChanged"
                                                  LostFocus="ManagerCombo_LostFocus"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="연락처" Width="1.4*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Padding="4">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="CornerRadius" Value="0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsContactMissing}" Value="True">
                                                        <Setter Property="Background" Value="#FFEDD5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <ComboBox ItemsSource="{Binding AvailableContactNumbers}"
                                                  Text="{Binding ContactNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Style="{StaticResource EditorComboStyle}"
                                                  VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                                                  HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                  SelectionChanged="ContactCombo_SelectionChanged"
                                                  LostFocus="ContactCombo_LostFocus"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="주소" Width="3.4*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Padding="4">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="CornerRadius" Value="0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAddressMissing}" Value="True">
                                                        <Setter Property="Background" Value="#FEE2E2"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <ComboBox ItemsSource="{Binding AvailableAddressTexts}"
                                                  Text="{Binding FullAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Style="{StaticResource EditorComboStyle}"
                                                  VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                                                  HorizontalContentAlignment="Left" VerticalContentAlignment="Center"
                                                  SelectionChanged="AddressCombo_SelectionChanged"
                                                  LostFocus="AddressCombo_LostFocus"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="비고" Width="1.5*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Padding="0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="CornerRadius" Value="0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsUrgentNote}" Value="True">
                                                        <Setter Property="Background" Value="#FEE2E2"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBox Text="{Binding Note, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource PlainTextBoxStyle}"
                                                 PreviewKeyDown="TextBox_PreviewKeyDown"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn x:Name="StatusColumn" Header="상태" Binding="{Binding ValidationSummary}" Width="1.1*" IsReadOnly="True" ElementStyle="{StaticResource CenterTextColumnStyle}"/>

                        <DataGridTemplateColumn x:Name="ManageColumn" Header="관리" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Button Content="이월"
                                                Foreground="#2563EB"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Margin="0,0,12,0"
                                                Click="BtnCarryOver_Click"
                                                FontWeight="Bold"
                                                Cursor="Hand"
                                                ToolTip="이 항목을 내일 배차표로 이동시킵니다."/>
                                        <Button Content="삭제"
                                                Foreground="#DC2626"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Click="BtnDeleteRow_Click"
                                                FontWeight="Bold"
                                                Cursor="Hand"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Window>