<UserControl x:Class="CleanPotal.WeeklyReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FFFFFF" SnapsToDevicePixels="True" UseLayoutRounding="True"
             TextOptions.TextFormattingMode="Ideal" 
             TextOptions.TextRenderingMode="Auto"
             RenderOptions.BitmapScalingMode="HighQuality">

    <UserControl.Resources>
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="10"/>
            <Setter Property="Margin" Value="2,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#CBD5E1" CornerRadius="4" Margin="2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MonthExpanderStyle" TargetType="Expander">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <StackPanel>
                            <ToggleButton x:Name="HeaderSite" IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}" Cursor="Hand" Padding="12,8">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="Arrow" Text="▶" FontSize="10" VerticalAlignment="Center" Foreground="#94A3B8" Margin="0,0,8,0"/>
                                                <ContentPresenter ContentSource="Content" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Arrow" Property="Text" Value="▼"/>
                                                <Setter TargetName="Arrow" Property="Foreground" Value="#475569"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <ContentPresenter Content="{TemplateBinding Header}"/>
                            </ToggleButton>
                            <Border x:Name="ExpandSite" Visibility="Collapsed" Margin="0,0,0,0">
                                <ContentPresenter />
                            </Border>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatToggleStyle" TargetType="ToggleButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="999" Padding="8,2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid x:Name="RootLayout" Background="Transparent">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="340"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="0,0,1,0">
            <Grid Margin="0,20,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="14,8,14,12">
                    <Button x:Name="BtnCreateNewReport" Content="+ 새 보고서 생성" Margin="0,0,0,0" Height="36" Background="#2563EB" Foreground="White" FontWeight="SemiBold" FontSize="13" BorderThickness="0" Cursor="Hand" Click="BtnCreateNewReport_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="GroupedHistoryControl" Margin="8,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Expander Header="{Binding MonthTitle}" IsExpanded="{Binding IsExpanded, Mode=TwoWay}" Style="{StaticResource MonthExpanderStyle}" Expanded="MonthExpander_Expanded">
                                    <Expander.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" FontSize="14" FontWeight="Bold" Foreground="#475569"/>
                                        </DataTemplate>
                                    </Expander.HeaderTemplate>
                                    <ListBox ItemsSource="{Binding Reports}" Background="Transparent" BorderThickness="0" SelectionChanged="HistoryListBox_SelectionChanged" Margin="8,8,0,0" VirtualizingPanel.ScrollUnit="Pixel" ScrollViewer.CanContentScroll="True">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Padding" Value="10,8"/>
                                                <Setter Property="Margin" Value="0,0,0,3"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Grid>
                                                                <Border x:Name="Bd" Background="Transparent" CornerRadius="8">
                                                                    <ContentPresenter Margin="4,0,0,0"/>
                                                                </Border>
                                                                <Border x:Name="Indicator" Width="3" Height="16" Background="#2563EB" CornerRadius="1.5" HorizontalAlignment="Left" Visibility="Collapsed"/>
                                                            </Grid>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="#E2E8F0"/>
                                                                </Trigger>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="#DBEAFE"/>
                                                                    <Setter Property="Foreground" Value="#1D4ED8"/>
                                                                    <Setter TargetName="Indicator" Property="Visibility" Value="Visible"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding ShortTitle}" FontWeight="Bold" FontSize="14"/>
                                                    <TextBlock Text="{Binding DateRange}" FontSize="12" Foreground="#64748B" Margin="0,1,0,0"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Expander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="32,24,32,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="TxtCurrentReportTitle" Text="보고서를 선택하세요" FontSize="26" FontWeight="ExtraBold" Foreground="#0F172A"/>
                    <TextBlock x:Name="TxtCurrentReportDate" Text="작성 기간이 표시됩니다." FontSize="14" Foreground="#64748B" Margin="0,2,0,0"/>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Border Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="999" Padding="8,2" Margin="0,0,6,0">
                            <TextBlock x:Name="TxtStatTotal" Text="총 0건" FontSize="13" FontWeight="SemiBold" Foreground="#1D4ED8"/>
                        </Border>
                        <ToggleButton x:Name="ToggleInProgress" Click="Filter_Changed" Background="#ECFDF5" BorderBrush="#A7F3D0" Foreground="#047857" Style="{StaticResource StatToggleStyle}">
                            <TextBlock x:Name="TxtStatInProgress" Text="진행 0" FontSize="13" FontWeight="SemiBold"/>
                        </ToggleButton>
                        <ToggleButton x:Name="TogglePending" Click="Filter_Changed" Background="#FFFBEB" BorderBrush="#FDE68A" Foreground="#B45309" Style="{StaticResource StatToggleStyle}">
                            <TextBlock x:Name="TxtStatPending" Text="보류 0" FontSize="13" FontWeight="SemiBold"/>
                        </ToggleButton>
                        <ToggleButton x:Name="ToggleClosed" Click="Filter_Changed" Background="#F8FAFC" BorderBrush="#CBD5E1" Foreground="#475569" Style="{StaticResource StatToggleStyle}">
                            <TextBlock x:Name="TxtStatClosed" Text="종결 0" FontSize="13" FontWeight="SemiBold"/>
                        </ToggleButton>
                        <Border Background="#F5F3FF" BorderBrush="#DDD6FE" BorderThickness="1" CornerRadius="999" Padding="8,2">
                            <TextBlock x:Name="TxtStatAttachments" Text="첨부 0" FontSize="13" FontWeight="SemiBold" Foreground="#6D28D9"/>
                        </Border>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border x:Name="SearchBorder" Background="#F1F5F9" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Height="32" Padding="8,0" Width="160" Margin="0,0,10,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE721;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI Symbol" FontSize="12" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox x:Name="SearchBox" Grid.Column="1" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" FontSize="13" Foreground="#0F172A" TextChanged="SearchBox_TextChanged"/>
                            <TextBlock Grid.Column="1" Text="전체 검색..." Foreground="#94A3B8" FontSize="13" VerticalAlignment="Center" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style></TextBlock>
                        </Grid>
                    </Border>
                    <Button x:Name="BtnDeleteReport" Content="보고서 삭제" Height="32" Padding="12,0" Margin="0,0,10,0" Background="#FEE2E2" Foreground="#B91C1C" BorderBrush="#FCA5A5" BorderThickness="1" FontWeight="Bold" FontSize="13" Cursor="Hand" Click="BtnDeleteReport_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button x:Name="BtnClearSelection" Content="초기화" Height="32" Padding="10,0" Background="#F1F5F9" Foreground="#475569" BorderBrush="#CBD5E1" BorderThickness="1" FontWeight="Bold" FontSize="13" Cursor="Hand" Click="BtnClearSelection_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <StackPanel>
                    <ItemsControl x:Name="ReportBlocksControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10" Margin="0,0,0,10" Padding="12" AllowDrop="True" PreviewDragOver="Card_PreviewDragOver" Drop="Card_Drop" MouseMove="Card_MouseMove" Tag="{Binding}">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#64748B" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid Grid.Row="0" Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="140"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Width="30" Height="30" CornerRadius="6" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" Margin="0,0,10,0">
                                                <TextBlock Text="{Binding Number}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="14" Foreground="#1D4ED8"/>
                                            </Border>

                                            <Grid Grid.Column="1" Margin="0,0,12,0" VerticalAlignment="Center">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding ParentReportTitle}" Visibility="{Binding ParentTitleVisibility}" FontSize="16" FontWeight="ExtraBold" Foreground="#2563EB" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                <TextBox Grid.Column="1" Text="{Binding Category, UpdateSourceTrigger=PropertyChanged}" FontSize="16" FontWeight="ExtraBold" Foreground="#1E293B" BorderThickness="0" Background="Transparent" VerticalAlignment="Center"/>
                                            </Grid>

                                            <Grid Grid.Column="2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Height="28" CornerRadius="6" BorderBrush="#CBD5E1" BorderThickness="1" ClipToBounds="True">
                                                    <ComboBox SelectedValue="{Binding Status, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Content" Background="#F8FAFC" BorderThickness="0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontWeight="Bold" FontSize="13">
                                                        <ComboBoxItem Content="진행 중" Foreground="#2563EB"/>
                                                        <ComboBoxItem Content="보류" Foreground="#D97706"/>
                                                        <ComboBoxItem Content="종결" Foreground="#64748B"/>
                                                    </ComboBox>
                                                </Border>
                                                <Button Grid.Column="1" Content="삭제" Width="44" Height="28" Margin="6,0,0,0" Background="#FEE2E2" Foreground="#B91C1C" FontWeight="Bold" FontSize="13" BorderBrush="#FCA5A5" BorderThickness="1" Cursor="Hand" Tag="{Binding}" Click="BtnDeleteBlock_Click">
                                                    <Button.Resources>
                                                        <Style TargetType="Border">
                                                            <Setter Property="CornerRadius" Value="6"/>
                                                        </Style>
                                                    </Button.Resources>
                                                </Button>
                                            </Grid>
                                        </Grid>
                                        <Grid Grid.Row="1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" MinWidth="400"/>
                                                <ColumnDefinition Width="140"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,12,0" VerticalAlignment="Top">
                                                <TextBox Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}" MinHeight="40" Margin="0,0,0,6"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="▶" FontSize="16" Foreground="#3B82F6" VerticalAlignment="Center" Margin="2,0,8,0"/>
                                                    <TextBox Grid.Column="1" Text="{Binding FollowUp, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}" MinHeight="40" Background="#EFF6FF" BorderBrush="#BFDBFE"/>
                                                </Grid>
                                            </StackPanel>
                                            <Border Grid.Column="1" Height="92" VerticalAlignment="Top" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="8" AllowDrop="True" PreviewDragOver="AttachmentPanel_PreviewDragOver" Drop="AttachmentPanel_Drop" PreviewKeyDown="AttachmentPanel_PreviewKeyDown" Focusable="True" Tag="{Binding}">
                                                <StackPanel>
                                                    <Grid Margin="0,0,0,4">
                                                        <TextBlock Text="첨부 (이미지/파일)" FontSize="12" FontWeight="Bold" Foreground="#334155" VerticalAlignment="Center"/>
                                                        <Button Content="+" Height="20" Width="20" HorizontalAlignment="Right" Background="#E2E8F0" Foreground="#334155" BorderThickness="0" Cursor="Hand" FontWeight="Bold" Tag="{Binding}" Click="BtnAddAttachment_Click">
                                                            <Button.Resources>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="CornerRadius" Value="10"/>
                                                                </Style>
                                                            </Button.Resources>
                                                        </Button>
                                                    </Grid>
                                                    <ScrollViewer VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Auto" Height="52">
                                                        <ItemsControl ItemsSource="{Binding FollowUpAttachments}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <StackPanel Orientation="Horizontal"/>
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Grid Width="48" Height="48" Margin="0,0,6,0" ToolTip="{Binding FileName}">
                                                                        <Border Cursor="Hand" CornerRadius="6" BorderBrush="#CBD5E1" BorderThickness="1" MouseLeftButtonDown="AttachmentPreview_Click" Background="#F8FAFC">
                                                                            <Border.Style>
                                                                                <Style TargetType="Border">
                                                                                    <Setter Property="Background" Value="#F8FAFC"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsDisplayableImage}" Value="True">
                                                                                            <Setter Property="Background">
                                                                                                <Setter.Value>
                                                                                                    <ImageBrush ImageSource="{Binding FilePath}" Stretch="UniformToFill"/>
                                                                                                </Setter.Value>
                                                                                            </Setter>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Border.Style>
                                                                            <StackPanel VerticalAlignment="Center" Margin="2">
                                                                                <StackPanel.Style>
                                                                                    <Style TargetType="StackPanel">
                                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding IsDisplayableImage}" Value="True">
                                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </StackPanel.Style>
                                                                                <TextBlock Text="{Binding FileIcon}" FontSize="14" HorizontalAlignment="Center" FontFamily="Segoe UI Emoji"/>
                                                                                <TextBlock Text="{Binding FileTypeLabel}" FontSize="8" FontWeight="Bold" Foreground="#475569" HorizontalAlignment="Center" Margin="0,-1,0,0"/>
                                                                                <TextBlock Text="{Binding FileName}" FontSize="8" Foreground="#64748B" TextAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                                            </StackPanel>
                                                                        </Border>
                                                                        <Button Content="✕" Width="14" Height="14" Background="#EF4444" Foreground="White" BorderThickness="0" FontSize="8" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-4,-4,0" Cursor="Hand" Tag="{Binding}" Click="BtnRemoveAttachment_Click">
                                                                            <Button.Resources>
                                                                                <Style TargetType="Border">
                                                                                    <Setter Property="CornerRadius" Value="7"/>
                                                                                </Style>
                                                                            </Button.Resources>
                                                                        </Button>
                                                                    </Grid>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </ScrollViewer>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button x:Name="BtnAddBlock" Content="+ 새로운 업무 항목 추가" Height="44" Background="Transparent" BorderBrush="#CBD5E1" BorderThickness="1" Foreground="#64748B" FontWeight="Bold" FontSize="15" Margin="0,6,0,24" Cursor="Hand" Click="BtnAddBlock_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="10"/>
                            </Style>
                        </Button.Resources>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F8FAFC"/>
                                        <Setter Property="Foreground" Value="#0F172A"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Border Grid.Column="2" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1,0,0,0">
            <Grid x:Name="MemoArea" Margin="24,32,24,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="추가 메모" FontSize="18" FontWeight="ExtraBold" Foreground="#0F172A" Margin="0,0,0,16" HorizontalAlignment="Center"/>
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBox Grid.Row="0" x:Name="MemoTextBox" Text="{Binding Memo, UpdateSourceTrigger=PropertyChanged}" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" Padding="20" FontSize="15" Foreground="#1E293B" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="16"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                    <Border Grid.Row="1" Height="104" Margin="0,12,0,0" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10" Padding="10" AllowDrop="True" PreviewDragOver="MemoAttachmentPanel_PreviewDragOver" Drop="MemoAttachmentPanel_Drop" PreviewKeyDown="MemoAttachmentPanel_PreviewKeyDown" Focusable="True">
                        <StackPanel>
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="첨부 (이미지/파일)" FontSize="13" FontWeight="Bold" Foreground="#334155" VerticalAlignment="Center"/>
                                <Button Content="+" Height="22" Width="22" HorizontalAlignment="Right" Background="#E2E8F0" Foreground="#334155" BorderThickness="0" Cursor="Hand" FontWeight="Bold" Click="BtnAddMemoAttachment_Click">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="11"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                            </Grid>
                            <ScrollViewer VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Auto" Height="56">
                                <ItemsControl x:Name="MemoAttachmentsControl" ItemsSource="{Binding MemoAttachments}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Width="52" Height="52" Margin="0,0,8,0" ToolTip="{Binding FileName}">
                                                <Border Cursor="Hand" CornerRadius="8" BorderBrush="#CBD5E1" BorderThickness="1" MouseLeftButtonDown="AttachmentPreview_Click" Background="#F8FAFC">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#F8FAFC"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsDisplayableImage}" Value="True">
                                                                    <Setter Property="Background">
                                                                        <Setter.Value>
                                                                            <ImageBrush ImageSource="{Binding FilePath}" Stretch="UniformToFill"/>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel VerticalAlignment="Center" Margin="3">
                                                        <StackPanel.Style>
                                                            <Style TargetType="StackPanel">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsDisplayableImage}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </StackPanel.Style>
                                                        <TextBlock Text="{Binding FileIcon}" FontSize="16" HorizontalAlignment="Center" FontFamily="Segoe UI Emoji"/>
                                                        <TextBlock Text="{Binding FileTypeLabel}" FontSize="9" FontWeight="Bold" Foreground="#475569" HorizontalAlignment="Center" Margin="0,-1,0,0"/>
                                                        <TextBlock Text="{Binding FileName}" FontSize="9" Foreground="#64748B" TextAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                </Border>
                                                <Button Content="✕" Width="16" Height="16" Background="#EF4444" Foreground="White" BorderThickness="0" FontSize="9" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-4,-4,0" Cursor="Hand" Tag="{Binding}" Click="BtnRemoveMemoAttachment_Click">
                                                    <Button.Resources>
                                                        <Style TargetType="Border">
                                                            <Setter Property="CornerRadius" Value="8"/>
                                                        </Style>
                                                    </Button.Resources>
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Border x:Name="CreateReportModal" Grid.ColumnSpan="3" Background="#80000000" Visibility="Collapsed" Panel.ZIndex="200">
            <Border Background="White" Width="350" VerticalAlignment="Center" HorizontalAlignment="Center" CornerRadius="16" Padding="30">
                <StackPanel>
                    <TextBlock Text="새 보고서 생성" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,25"/>
                    <TextBlock Text="작성 주차 선택" FontSize="13" Foreground="#64748B" Margin="0,0,0,10"/>
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="ComboYear" Grid.Column="0" Margin="0,0,5,0" Height="40" VerticalContentAlignment="Center"/>
                        <ComboBox x:Name="ComboMonth" Grid.Column="1" Margin="5,0,5,0" Height="40" VerticalContentAlignment="Center"/>
                        <ComboBox x:Name="ComboWeek" Grid.Column="2" Margin="5,0,0,0" Height="40" VerticalContentAlignment="Center">
                            <ComboBoxItem Content="1주차"/>
                            <ComboBoxItem Content="2주차"/>
                            <ComboBoxItem Content="3주차"/>
                            <ComboBoxItem Content="4주차" Margin="0,10,0,0"/>
                            <ComboBoxItem Content="5주차"/>
                        </ComboBox>
                    </Grid>
                    <TextBlock x:Name="TxtAutoDatePreview" Text="자동 계산 날짜: -" FontSize="12" Foreground="#2563EB" HorizontalAlignment="Center" Margin="0,0,0,30"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Content="취소" Grid.Column="0" Height="45" Margin="0,0,5,0" Background="#F1F5F9" Foreground="#475569" BorderThickness="0" FontWeight="Bold" Click="BtnCancelCreate_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="10"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <Button Content="생성하기" Grid.Column="1" Height="45" Margin="5,0,0,0" Background="#2563EB" Foreground="White" BorderThickness="0" FontWeight="Bold" Click="BtnConfirmCreate_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="10"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
        </Border>

    </Grid>
</UserControl>
