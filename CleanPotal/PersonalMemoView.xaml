<UserControl x:Class="CleanPotal.PersonalMemoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             Background="#F8FAFC">

    <UserControl.Resources>
        <Style x:Key="GhostButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F1F5F9"/>
                                <Setter Property="Foreground" Value="#0F172A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
            <Setter Property="Foreground" Value="#DC2626"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ========== 왼쪽: 메모 목록 ========== -->
        <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="0,0,1,0">
            <Grid Margin="14,16,14,14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 사용자명 -->
                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock x:Name="TxtUserHeader" Text="" FontSize="13" FontWeight="SemiBold" Foreground="#475569"/>
                </StackPanel>

                <!-- 새 메모 버튼 -->
                <Button Grid.Row="1" Content="+ 새 메모" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Stretch" Height="36" Margin="0,0,0,10" Click="BtnNewNote_Click"/>

                <!-- 검색창 -->
                <Border Grid.Row="2" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔎" FontSize="11" Foreground="#94A3B8" VerticalAlignment="Center" Margin="10,0,2,0"/>
                        <TextBox Grid.Column="1" x:Name="TxtSearch" Background="Transparent" BorderThickness="0" Padding="6,8" FontSize="13" Foreground="#1E293B" TextChanged="TxtSearch_TextChanged">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Resources>
                                        <VisualBrush x:Key="PlaceholderBrush" AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                            <VisualBrush.Visual>
                                                <TextBlock Text="제목/본문 검색..." Foreground="#CBD5E1" FontSize="13"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Style.Resources>
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Background" Value="{StaticResource PlaceholderBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </Grid>
                </Border>

                <!-- 메모 목록 (월별 그룹) -->
                <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="GroupedNotesControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="{Binding GroupHeader}" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="4,8,0,4"/>
                                    <ItemsControl ItemsSource="{Binding Notes}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch" Cursor="Hand" Padding="0" Click="NoteItem_Click" Tag="{Binding}">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="10,8" Margin="0,1">
                                                                <ContentPresenter/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="bd" Property="Background" Value="#F1F5F9"/>
                                                                </Trigger>
                                                                <DataTrigger Binding="{Binding IsSelectedInList}" Value="True">
                                                                    <Setter TargetName="bd" Property="Background" Value="#DBEAFE"/>
                                                                </DataTrigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                    <StackPanel>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding DisplayTitle}" FontSize="13" FontWeight="SemiBold" Foreground="#0F172A" TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding ShortDate}" FontSize="10" Foreground="#94A3B8" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                                        </Grid>
                                                        <TextBlock Text="{Binding Preview}" FontSize="11" Foreground="#64748B" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ========== 가운데: 편집 영역 ========== -->
        <Grid Grid.Column="1" Margin="20,16,20,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 빈 상태 안내 (메모 미선택 시) -->
            <Border x:Name="EmptyStatePanel" Grid.RowSpan="3" Background="Transparent" Visibility="Visible">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="📝" FontSize="48" HorizontalAlignment="Center" Foreground="#CBD5E1" Margin="0,0,0,12"/>
                    <TextBlock Text="선택된 메모가 없습니다" FontSize="16" FontWeight="SemiBold" Foreground="#64748B" HorizontalAlignment="Center"/>
                    <TextBlock Text="왼쪽에서 메모를 선택하거나 + 새 메모를 클릭하세요" FontSize="12" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- 편집 영역 (메모 선택 시) -->
            <Grid x:Name="EditorPanel" Grid.RowSpan="3" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 상단: 제목 + 액션 -->
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" x:Name="TxtTitle" Background="Transparent" BorderThickness="0" FontSize="22" FontWeight="ExtraBold" Foreground="#0F172A" Padding="0" TextChanged="EditorContent_TextChanged"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtSaveStatus" Text="" FontSize="11" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Button Content="저장" Style="{StaticResource PrimaryButtonStyle}" Height="32" Padding="14,0" Click="BtnSave_Click"/>
                        <Button Content="삭제" Style="{StaticResource DangerButtonStyle}" Height="32" Padding="10,0" Margin="6,0,0,0" Click="BtnDelete_Click"/>
                    </StackPanel>
                </Grid>

                <!-- 메타 정보 -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock x:Name="TxtMetaCreated" Text="" FontSize="11" Foreground="#94A3B8" Margin="0,0,16,0"/>
                    <TextBlock x:Name="TxtMetaUpdated" Text="" FontSize="11" Foreground="#94A3B8" Margin="0,0,16,0"/>
                    <TextBlock x:Name="TxtMetaAuthor" Text="" FontSize="11" Foreground="#94A3B8"/>
                </StackPanel>

                <!-- 구분선 -->
                <Border Grid.Row="2" Height="1" Background="#E5E7EB" Margin="0,0,0,12"/>

                <!-- 본문 -->
                <Border Grid.Row="3" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="10">
                    <TextBox x:Name="TxtContent" Background="Transparent" BorderThickness="0" Padding="20" FontSize="14" Foreground="#1E293B" TextWrapping="Wrap" AcceptsReturn="True" AcceptsTab="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" SpellCheck.IsEnabled="False" TextChanged="EditorContent_TextChanged"/>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
