<UserControl x:Class="CleanPotal.QuotationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:CleanPotal"
             Background="#F8FAFC"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True" SnapsToDevicePixels="True">

    <UserControl.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="FieldInputStyle" TargetType="TextBox" BasedOn="{StaticResource MacInputTextBoxStyle}">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <Style x:Key="GridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,12"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
        </Style>

        <Style x:Key="GridCellStyle" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>

        <Style x:Key="ListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EEF2FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GridRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#F8FAFC"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EEF2FF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E0E7FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CellTextStyle" TargetType="TextBlock">
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="CellEditStyle" TargetType="TextBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── 왼쪽: 견적서 목록 ── -->
        <Border Grid.Column="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="16,18,16,14" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="견적서 목록" FontSize="14" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,10"/>
                        <Button Content="+ 새 견적서" Style="{StaticResource MacPrimaryButtonStyle}" Height="36" Click="BtnNewQuotation_Click"/>
                    </StackPanel>
                </Border>

                <ListBox Grid.Row="1" x:Name="QuotationListBox"
                         BorderThickness="0" Background="Transparent" Padding="8,8,8,0"
                         ItemContainerStyle="{StaticResource ListItemStyle}"
                         SelectionChanged="QuotationListBox_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding DisplayTitle}" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#1E293B" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding CreatedAt}" FontSize="11" Foreground="#94A3B8" Margin="0,2,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Button Grid.Row="2" Content="선택 삭제" Style="{StaticResource MacDangerButtonStyle}"
                        Margin="12,8,12,14" Height="34" Click="BtnDeleteQuotation_Click"/>
            </Grid>
        </Border>

        <!-- ── 오른쪽: 편집 영역 ── -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 상단 툴바 -->
            <Border Grid.Row="0" Background="White" Padding="28,14,24,14"
                    BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                <Grid>
                    <TextBlock Text="FIRM QUOTATION" FontSize="20" FontWeight="ExtraBold"
                               Foreground="#1E3A8A" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="단가 관리" Style="{StaticResource MacSecondaryButtonStyle}"
                                Height="36" Click="BtnProductMaster_Click"/>
                        <Button Content="저장" Style="{StaticResource MacPrimaryButtonStyle}"
                                Height="36" Margin="8,0,0,0" Click="BtnSave_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 폼 영역 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="FormPanel" Margin="28,24,28,28"
                            DataContext="{Binding CurrentQuotation, RelativeSource={RelativeSource AncestorType=local:QuotationView}}">

                    <!-- 비어있을 때 안내 -->
                    <Border>
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource CardStyle}">
                                <Setter Property="Padding" Value="0,80"/>
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasQuotation, RelativeSource={RelativeSource AncestorType=local:QuotationView}}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="왼쪽에서 견적서를 선택하거나 새 견적서를 만드세요."
                                   FontSize="15" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                    </Border>

                    <!-- 폼 콘텐츠 (견적서 선택 시 표시) -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasQuotation, RelativeSource={RelativeSource AncestorType=local:QuotationView}}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <!-- ── 고객사 / 견적 정보 카드 ── -->
                        <Border Style="{StaticResource CardStyle}" Padding="28,24">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="1"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- 왼쪽: 고객사 정보 -->
                                <StackPanel Grid.Column="0" Margin="0,0,28,0">
                                    <TextBlock Text="고객사 정보" FontSize="13" FontWeight="Bold"
                                               Foreground="#475569" Margin="0,0,0,16"/>

                                    <TextBlock Text="담당자" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding Attention, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource FieldInputStyle}"/>

                                    <TextBlock Text="회사명" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding Company, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource FieldInputStyle}"/>

                                    <TextBlock Text="E-Mail" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource FieldInputStyle}"/>

                                    <TextBlock Text="Phone" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding Phone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource FieldInputStyle}" Margin="0,0,0,0"/>
                                </StackPanel>

                                <!-- 구분선 -->
                                <Border Grid.Column="1" Background="#E2E8F0"/>

                                <!-- 오른쪽: 견적 정보 -->
                                <StackPanel Grid.Column="2" Margin="28,0,0,0">
                                    <TextBlock Text="견적 정보" FontSize="13" FontWeight="Bold"
                                               Foreground="#475569" Margin="0,0,0,16"/>

                                    <TextBlock Text="견적일" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding Date, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource FieldInputStyle}"/>

                                    <TextBlock Text="유효기간" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding Validity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource FieldInputStyle}"/>

                                    <TextBlock Text="AETS 담당자" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding AetsManager, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource FieldInputStyle}"/>

                                    <TextBlock Text="AETS Phone" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding AetsPhone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource FieldInputStyle}"/>

                                    <Grid Margin="0,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="사업자등록번호" Style="{StaticResource FieldLabelStyle}" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Content="기본값 저장" Style="{StaticResource MacSecondaryButtonStyle}"
                                                Height="24" FontSize="11" Padding="8,0"
                                                VerticalAlignment="Center" Click="BtnSaveBusinessNo_Click"/>
                                    </Grid>
                                    <TextBox Text="{Binding BusinessNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource FieldInputStyle}" Margin="0,0,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- ── 견적 품목 카드 ── -->
                        <Border Style="{StaticResource CardStyle}" Padding="24,20,24,0">
                            <StackPanel>
                                <!-- 카드 헤더 -->
                                <Grid Margin="0,0,0,14">
                                    <TextBlock Text="견적 품목" FontSize="13" FontWeight="Bold"
                                               Foreground="#475569" VerticalAlignment="Center"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="단가에서 추가" Style="{StaticResource MacSecondaryButtonStyle}"
                                                Height="32" FontSize="12" Click="BtnInsertFromMasterInline_Click"/>
                                        <Button Content="+ 행 추가" Style="{StaticResource MacSecondaryButtonStyle}"
                                                Height="32" FontSize="12" Margin="6,0,0,0" Click="BtnAddLineItem_Click"/>
                                        <Button Content="선택 삭제" Style="{StaticResource MacDangerButtonStyle}"
                                                Height="32" FontSize="12" Margin="6,0,0,0" Click="BtnDeleteLineItem_Click"/>
                                    </StackPanel>
                                </Grid>

                                <!-- 품목 그리드 -->
                                <DataGrid x:Name="LineItemsGrid"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal"
                                          MinRowHeight="42"
                                          BorderThickness="1"
                                          BorderBrush="#E2E8F0"
                                          Background="Transparent"
                                          AlternationCount="2"
                                          RowStyle="{StaticResource GridRowStyle}"
                                          ColumnHeaderStyle="{StaticResource GridHeaderStyle}"
                                          CellStyle="{StaticResource GridCellStyle}">
                                    <DataGrid.Columns>
                                        <!-- No -->
                                        <DataGridTextColumn Header="No" Binding="{Binding No}" IsReadOnly="True" Width="50">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource CellTextStyle}">
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="Foreground" Value="#64748B"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <!-- 제품명/설명 -->
                                        <DataGridTemplateColumn Header="제품명 / 설명" Width="2.5*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Description}" Style="{StaticResource CellTextStyle}" TextWrapping="Wrap"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                            <DataGridTemplateColumn.CellEditingTemplate>
                                                <DataTemplate>
                                                    <TextBox Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             Style="{StaticResource CellEditStyle}" TextWrapping="Wrap" AcceptsReturn="True"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellEditingTemplate>
                                        </DataGridTemplateColumn>

                                        <!-- 규격/사양 -->
                                        <DataGridTemplateColumn Header="규격 / 사양" Width="1.5*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding StandardSpec}" Style="{StaticResource CellTextStyle}" HorizontalAlignment="Center"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                            <DataGridTemplateColumn.CellEditingTemplate>
                                                <DataTemplate>
                                                    <TextBox Text="{Binding StandardSpec, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             Style="{StaticResource CellEditStyle}" TextAlignment="Center"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellEditingTemplate>
                                        </DataGridTemplateColumn>

                                        <!-- 단가 -->
                                        <DataGridTemplateColumn Header="단가 (₩)" Width="130">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding ListPrice, StringFormat={}{0:N0}}"
                                                               Style="{StaticResource CellTextStyle}" HorizontalAlignment="Right" Padding="10,0,14,0"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                            <DataGridTemplateColumn.CellEditingTemplate>
                                                <DataTemplate>
                                                    <TextBox Text="{Binding ListPrice, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             Style="{StaticResource CellEditStyle}" TextAlignment="Right"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellEditingTemplate>
                                        </DataGridTemplateColumn>

                                        <!-- 수량 -->
                                        <DataGridTemplateColumn Header="수량" Width="70">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Qty}" Style="{StaticResource CellTextStyle}" HorizontalAlignment="Center"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                            <DataGridTemplateColumn.CellEditingTemplate>
                                                <DataTemplate>
                                                    <TextBox Text="{Binding Qty, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             Style="{StaticResource CellEditStyle}" TextAlignment="Center"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellEditingTemplate>
                                        </DataGridTemplateColumn>

                                        <!-- 금액 (자동계산, 읽기전용) -->
                                        <DataGridTemplateColumn Header="금액 (₩)" Width="140" IsReadOnly="True">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Amount, StringFormat={}{0:N0}}"
                                                               Style="{StaticResource CellTextStyle}"
                                                               HorizontalAlignment="Right" Padding="10,0,14,0"
                                                               FontWeight="SemiBold" Foreground="#1E40AF"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <!-- 합계 행 -->
                                <Border Background="#EFF6FF" Padding="20,14"
                                        BorderBrush="#BFDBFE" BorderThickness="1,0,1,1"
                                        CornerRadius="0,0,8,8" Margin="0,0,0,0">
                                    <Grid>
                                        <TextBlock Text="합계 (Total)" FontSize="14" FontWeight="Bold"
                                                   Foreground="#1D4ED8" VerticalAlignment="Center"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <TextBlock Text="수량  " FontSize="13" Foreground="#3B82F6" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding TotalQty, RelativeSource={RelativeSource AncestorType=local:QuotationView}}"
                                                       FontSize="14" Foreground="#1D4ED8" FontWeight="Bold" Margin="0,0,32,0"/>
                                            <TextBlock Text="금액  " FontSize="13" Foreground="#3B82F6" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding TotalAmount, RelativeSource={RelativeSource AncestorType=local:QuotationView}, StringFormat={}{0:N0} ₩}"
                                                       FontSize="15" Foreground="#1D4ED8" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border Height="24" Background="Transparent"/>
                            </StackPanel>
                        </Border>

                        <!-- ── 비고 카드 ── -->
                        <Border Style="{StaticResource CardStyle}" Padding="24,20">
                            <StackPanel>
                                <TextBlock Text="비고 (Remarks)" FontSize="13" FontWeight="Bold"
                                           Foreground="#475569" Margin="0,0,0,12"/>
                                <TextBox Text="{Binding Remarks, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True" TextWrapping="Wrap" MinHeight="72"
                                         Padding="12" BorderBrush="#E2E8F0" BorderThickness="1"
                                         FontSize="14" VerticalScrollBarVisibility="Auto"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ── 단가 관리 모달 ── -->
        <Grid x:Name="ProductMasterOverlay" Grid.ColumnSpan="2"
              Background="#CC000000" Visibility="Collapsed">
            <Border Background="White" CornerRadius="16"
                    Width="860" MaxHeight="620"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Padding="32,28">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="4" Color="Black" Opacity="0.2" Direction="270"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 모달 헤더 -->
                    <Grid Grid.Row="0" Margin="0,0,0,20">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="단가 관리" FontSize="18" FontWeight="Bold" Foreground="#0F172A"/>
                            <TextBlock Text="제품 단가를 등록하면 견적서 작성 시 빠르게 추가할 수 있습니다."
                                       FontSize="12" Foreground="#94A3B8" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button Content="+ 항목 추가" Style="{StaticResource MacSecondaryButtonStyle}"
                                    Height="36" Click="BtnAddMasterItem_Click"/>
                            <Button Content="선택 삭제" Style="{StaticResource MacDangerButtonStyle}"
                                    Height="36" Margin="8,0,0,0" Click="BtnDeleteMasterItem_Click"/>
                            <Button Content="견적에 추가" Style="{StaticResource MacPrimaryButtonStyle}"
                                    Height="36" Margin="8,0,0,0" Click="BtnInsertFromMasterModal_Click"/>
                        </StackPanel>
                    </Grid>

                    <!-- 단가 그리드 -->
                    <DataGrid Grid.Row="1" x:Name="ProductMasterGrid"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              MinRowHeight="42"
                              BorderThickness="1"
                              BorderBrush="#E2E8F0"
                              Background="Transparent"
                              AlternationCount="2"
                              RowStyle="{StaticResource GridRowStyle}"
                              ColumnHeaderStyle="{StaticResource GridHeaderStyle}"
                              CellStyle="{StaticResource GridCellStyle}">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="제품명" Width="2*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ProductName}" Style="{StaticResource CellTextStyle}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding ProductName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource CellEditStyle}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="규격/사양" Width="1.5*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Spec}" Style="{StaticResource CellTextStyle}" HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Spec, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource CellEditStyle}" TextAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="단가 (₩)" Width="140">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding UnitPrice, StringFormat={}{0:N0}}"
                                                   Style="{StaticResource CellTextStyle}" HorizontalAlignment="Right"
                                                   Padding="10,0,14,0" FontWeight="SemiBold" Foreground="#1E40AF"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding UnitPrice, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource CellEditStyle}" TextAlignment="Right"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="단위" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Unit}" Style="{StaticResource CellTextStyle}" HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Unit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource CellEditStyle}" TextAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- 모달 하단 -->
                    <Grid Grid.Row="2" Margin="0,20,0,0">
                        <TextBlock Text="※ 항목 선택 후 '견적에 추가' 버튼을 클릭하면 현재 견적서에 추가됩니다."
                                   FontSize="12" Foreground="#94A3B8" VerticalAlignment="Center"/>
                        <Button Content="닫기 및 저장" Style="{StaticResource MacPrimaryButtonStyle}"
                                Height="40" HorizontalAlignment="Right" Click="BtnCloseProductMaster_Click"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
