<Window x:Class="CleanPotal.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CleanPotal 로그인" Height="560" Width="400" 
        WindowStartupLocation="CenterScreen" WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        SnapsToDevicePixels="True" UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType" RenderOptions.BitmapScalingMode="HighQuality"
        Loaded="Window_Loaded">

    <Border Background="#F8FAFC" CornerRadius="16" BorderBrush="#E2E8F0" BorderThickness="1" Margin="10">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.1" BlurRadius="15" ShadowDepth="4"/>
        </Border.Effect>

        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,10,0,30">
                <TextBlock Text="CleanPotal" FontSize="28" FontWeight="ExtraBold" Foreground="#1E293B" HorizontalAlignment="Center"/>
                <TextBlock Text="팀 업무 관리를 위한 보안 로그인" FontSize="13" Foreground="#64748B" Margin="0,5,0,0"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="0,0,0,16">
                <TextBlock Text="아이디" FontSize="13" FontWeight="SemiBold" Foreground="#475569" Margin="2,0,0,6"/>
                <Border Background="White" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" Height="45">
                    <TextBox x:Name="TxtUsername" BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center" Padding="12,0" FontSize="15" KeyDown="Input_KeyDown"/>
                </Border>
            </StackPanel>

            <StackPanel Grid.Row="2" Margin="0,0,0,12">
                <TextBlock Text="비밀번호" FontSize="13" FontWeight="SemiBold" Foreground="#475569" Margin="2,0,0,6"/>
                <Border Background="White" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" Height="45">
                    <PasswordBox x:Name="TxtPassword" BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center" Padding="12,0" FontSize="15" KeyDown="Input_KeyDown"/>
                </Border>
            </StackPanel>

            <CheckBox x:Name="ChkAutoLogin" Grid.Row="3" Content="자동 로그인" FontSize="13" Foreground="#64748B" Margin="2,0,0,20" IsChecked="False"/>

            <Button Grid.Row="4" x:Name="BtnLogin" Height="50" Margin="0,0,0,25" Click="BtnLogin_Click" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" Background="#2563EB" CornerRadius="8">
                            <TextBlock Text="로그인" Foreground="White" FontWeight="Bold" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <StackPanel Grid.Row="5" HorizontalAlignment="Center" VerticalAlignment="Top">
                <Button Click="BtnUserManager_Click" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,0,16">
                    <TextBlock Text="⚙️ 사용자 계정 관리 (관리자 전용)" Foreground="#64748B" FontSize="13" TextDecorations="Underline"/>
                </Button>
                <Button Click="BtnExit_Click" Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <TextBlock Text="프로그램 종료" Foreground="#94A3B8" FontSize="13" TextDecorations="Underline"/>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>