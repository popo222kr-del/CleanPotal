<Window x:Class="CleanPotal.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CleanPotal 로그인" Height="480" Width="400" 
        WindowStartupLocation="CenterScreen" WindowStyle="None" AllowsTransparency="True" Background="Transparent">

    <Border Background="#F8FAFC" CornerRadius="16" BorderBrush="#E2E8F0" BorderThickness="1" Margin="10">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.1" BlurRadius="15" ShadowDepth="4"/>
        </Border.Effect>

        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,10,0,30">
                <TextBlock Text="CleanPotal" FontSize="28" FontWeight="ExtraBold" Foreground="#1E293B" HorizontalAlignment="Center"/>
                <TextBlock Text="팀 업무 관리를 위한 보안 로그인" FontSize="13" Foreground="#64748B" Margin="0,5,0,0"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="0,0,0,16">
                <TextBlock Text="아이디 (ID)" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,8"/>
                <Border Background="White" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" Height="42">
                    <TextBox x:Name="TxtUsername" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="12,0" FontSize="14" KeyDown="Input_KeyDown"/>
                </Border>
            </StackPanel>

            <StackPanel Grid.Row="2" Margin="0,0,0,24">
                <TextBlock Text="패스워드 (Password)" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,8"/>
                <Border Background="White" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" Height="42">
                    <PasswordBox x:Name="TxtPassword" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="12,0" FontSize="14" KeyDown="Input_KeyDown"/>
                </Border>
            </StackPanel>

            <Button Grid.Row="3" x:Name="BtnLogin" Click="BtnLogin_Click" Height="46" Cursor="Hand" Margin="0,0,0,25">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" Background="#2563EB" CornerRadius="8">
                            <TextBlock Text="로그인" Foreground="White" FontWeight="Bold" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#1E40AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <StackPanel Grid.Row="4" HorizontalAlignment="Center">
                <Button Click="BtnUserManager_Click" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,0,12">
                    <TextBlock Text="⚙️ 사용자 계정 관리 (관리자 전용)" Foreground="#64748B" FontSize="13" TextDecorations="Underline"/>
                </Button>

                <Button Click="BtnExit_Click" Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <TextBlock Text="프로그램 종료" Foreground="#94A3B8" FontSize="13" TextDecorations="Underline"/>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>