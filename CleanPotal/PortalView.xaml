<UserControl x:Class="CleanPotal.PortalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F7FB" SnapsToDevicePixels="True" UseLayoutRounding="True">

    <UserControl.Resources>
        <Style x:Key="ModernCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16,16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#64748B" Opacity="0.06" BlurRadius="12" ShadowDepth="3"/>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,16,24,24">

        <ItemsControl x:Name="GroupsItemsControl" VerticalAlignment="Top">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemContainerStyle>
                <Style TargetType="ContentPresenter">
                    <Setter Property="VerticalAlignment" Value="Top"/>
                </Style>
            </ItemsControl.ItemContainerStyle>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource ModernCardStyle}" Margin="8" Width="290">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="4,0,0,8">
                                <TextBlock Text="{Binding group}" FontWeight="ExtraBold" FontSize="15" Foreground="#1E293B" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Rectangle Height="1" Fill="#E2E8F0" Margin="0,0,0,12"/>

                            <ItemsControl ItemsSource="{Binding items}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Tag="{Binding path}" Click="PortalButton_Click" Margin="0,0,0,6" Cursor="Hand" Background="Transparent" BorderThickness="0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">

                                                    <Border x:Name="border" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="10,8">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <Border x:Name="IconBg" Grid.Column="0" Width="28" Height="28" CornerRadius="6" Background="#F1F5F9" Margin="0,0,10,0">
                                                                <TextBlock x:Name="TypeIcon" Text="&#xE8A5;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI Symbol" FontSize="14" Foreground="#64748B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>

                                                            <TextBlock x:Name="mainText" Grid.Column="1" Text="{Binding title}" Foreground="#334155" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>

                                                            <TextBlock x:Name="arrow" Grid.Column="2" Text="&#xE70A;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI Symbol" Foreground="#CBD5E1" FontWeight="Bold" FontSize="11" VerticalAlignment="Center" Margin="6,0,2,0"/>
                                                        </Grid>
                                                    </Border>

                                                    <ControlTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding type}" Value="folder">
                                                            <Setter TargetName="TypeIcon" Property="Text" Value="&#xE8B7;"/>
                                                            <Setter TargetName="TypeIcon" Property="Foreground" Value="#D97706"/>
                                                            <Setter TargetName="IconBg" Property="Background" Value="#FEF3C7"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding type}" Value="excel">
                                                            <Setter TargetName="TypeIcon" Property="Text" Value="&#xE773;"/>
                                                            <Setter TargetName="TypeIcon" Property="Foreground" Value="#059669"/>
                                                            <Setter TargetName="IconBg" Property="Background" Value="#D1FAE5"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding type}" Value="web">
                                                            <Setter TargetName="TypeIcon" Property="Text" Value="&#xE774;"/>
                                                            <Setter TargetName="TypeIcon" Property="Foreground" Value="#7C3AED"/>
                                                            <Setter TargetName="IconBg" Property="Background" Value="#EDE9FE"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding type}" Value="pdf">
                                                            <Setter TargetName="TypeIcon" Property="Text" Value="&#xEA90;"/>
                                                            <Setter TargetName="TypeIcon" Property="Foreground" Value="#DC2626"/>
                                                            <Setter TargetName="IconBg" Property="Background" Value="#FEE2E2"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding type}" Value="image">
                                                            <Setter TargetName="TypeIcon" Property="Text" Value="&#xE8B9;"/>
                                                            <Setter TargetName="TypeIcon" Property="Foreground" Value="#2563EB"/>
                                                            <Setter TargetName="IconBg" Property="Background" Value="#DBEAFE"/>
                                                        </DataTrigger>

                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="#FFFFFF"/>
                                                            <Setter TargetName="border" Property="BorderBrush" Value="#2563EB"/>
                                                            <Setter TargetName="mainText" Property="Foreground" Value="#1D4ED8"/>
                                                            <Setter TargetName="arrow" Property="Foreground" Value="#2563EB"/>
                                                            <Setter TargetName="border" Property="Effect">
                                                                <Setter.Value>
                                                                    <DropShadowEffect Color="#2563EB" Opacity="0.15" BlurRadius="10" ShadowDepth="2"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</UserControl>