<Window x:Class="CleanPotal.PortalManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="포털 통합 관리자" Width="1000" Height="750"
        WindowStartupLocation="CenterOwner" Background="#F9FAFB"
        FontSize="14" SnapsToDevicePixels="True" UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType" RenderOptions.BitmapScalingMode="HighQuality">

	<Window.Resources>
		<SolidColorBrush x:Key="MacBlue" Color="#007AFF"/>
		<Style x:Key="MacInputTextBoxStyle" TargetType="TextBox">
			<Setter Property="Height" Value="32"/>
			<Setter Property="Padding" Value="10,0"/>
			<Setter Property="VerticalContentAlignment" Value="Center"/>
			<Setter Property="BorderBrush" Value="#E5E5EA"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Background" Value="#FFFFFF"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="TextBox">
						<Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
							<ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
						</Border>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
	</Window.Resources>

	<Grid Margin="24">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<StackPanel Grid.Row="0" Margin="0,0,0,20">
			<TextBlock Text="포털 메뉴 통합 관리" FontSize="24" FontWeight="Bold" Foreground="#1D1D1F"/>
			<TextBlock Text="왼쪽에서 대분류(그룹)를 관리하고, 오른쪽에서 해당 그룹의 버튼들을 관리합니다." FontSize="13" Foreground="#86868B" Margin="0,4,0,0"/>
		</StackPanel>

		<Grid Grid.Row="1">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="280"/>
				<ColumnDefinition Width="24"/>
				<ColumnDefinition Width="*"/>
			</Grid.ColumnDefinitions>

			<StackPanel Grid.Column="0">
				<TextBlock Text="대분류 (그룹)" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,12"/>
				<Border BorderBrush="#E5E5EA" BorderThickness="1" CornerRadius="10" Background="White" Height="400">
					<ListBox x:Name="GroupListBox" BorderThickness="0" Background="Transparent" DisplayMemberPath="group" SelectionChanged="GroupListBox_SelectionChanged"/>
				</Border>
				<TextBox x:Name="GroupNameBox" Style="{StaticResource MacInputTextBoxStyle}" Margin="0,12,0,10"/>
				<UniformGrid Columns="2">
					<Button Content="추가 / 변경" Style="{StaticResource MacSecondaryButtonStyle}" Margin="0,0,8,0" Click="AddOrUpdateGroup_Click"/>
					<Button Content="삭제" Style="{StaticResource MacDangerButtonStyle}" Click="DeleteGroup_Click"/>
				</UniformGrid>
			</StackPanel>

			<Border Grid.Column="2" Style="{StaticResource ModernCardStyle}">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
						<RowDefinition Height="Auto"/>
					</Grid.RowDefinitions>
					<TextBlock Grid.Row="0" FontWeight="SemiBold" FontSize="17" Margin="0,0,0,16">
						<Run Text="["/>
						<Run x:Name="SelectedGroupNameRun" Text="그룹 선택 안됨" Foreground="{StaticResource MacBlue}"/>
						<Run Text="] 내부 버튼 리스트"/>
					</TextBlock>
					<DataGrid x:Name="ButtonDataGrid" Grid.Row="1" Margin="0,0,0,16" AutoGenerateColumns="False" CanUserAddRows="False" SelectionChanged="ButtonDataGrid_SelectionChanged" Background="White" BorderBrush="#E5E5EA">
						<DataGrid.Columns>
							<DataGridTextColumn Header="버튼 이름" Binding="{Binding title}" Width="150"/>
							<DataGridTextColumn Header="실행 경로" Binding="{Binding path}" Width="*"/>
						</DataGrid.Columns>
					</DataGrid>
					<Border Grid.Row="2" Background="#F2F2F7" Padding="20" CornerRadius="12">
						<StackPanel>
							<TextBlock Text="선택된 버튼 상세 편집" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,16" Foreground="#86868B"/>
							<Grid Margin="0,0,0,12">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="80"/>
									<ColumnDefinition Width="*"/>
								</Grid.ColumnDefinitions>
								<TextBlock Text="버튼 이름" VerticalAlignment="Center"/>
								<TextBox x:Name="ItemTitleBox" Grid.Column="1" Style="{StaticResource MacInputTextBoxStyle}"/>
							</Grid>
							<Grid Margin="0,0,0,16">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="80"/>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="Auto"/>
								</Grid.ColumnDefinitions>
								<TextBlock Text="실행 경로" VerticalAlignment="Center"/>
								<TextBox x:Name="ItemPathBox" Grid.Column="1" Style="{StaticResource MacInputTextBoxStyle}" Margin="0,0,8,0"/>
								<Button Grid.Column="2" Content="찾아보기" Style="{StaticResource MacSecondaryButtonStyle}" Width="80" Click="BtnBrowse_Click"/>
							</Grid>
							<UniformGrid Columns="3" HorizontalAlignment="Right" Width="300">
								<Button Content="새 버튼 추가" Style="{StaticResource MacSecondaryButtonStyle}" Margin="0,0,8,0" Click="AddNewItem_Click"/>
								<Button Content="적용" Style="{StaticResource MacPrimaryButtonStyle}" Margin="0,0,8,0" Click="ApplyItemEdit_Click"/>
								<Button Content="삭제" Style="{StaticResource MacDangerButtonStyle}" Click="DeleteItem_Click"/>
							</UniformGrid>
						</StackPanel>
					</Border>
				</Grid>
			</Border>
		</Grid>

		<StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
			<Button Content="취소" Width="90" Style="{StaticResource MacSecondaryButtonStyle}" Margin="0,0,12,0" Click="BtnCancel_Click"/>
			<Button Content="최종 저장" Width="110" Style="{StaticResource MacPrimaryButtonStyle}" Click="BtnSave_Click"/>
		</StackPanel>
	</Grid>
</Window>