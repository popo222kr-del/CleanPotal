<UserControl x:Class="CleanPotal.EduDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:system="clr-namespace:System;assembly=mscorlib"
             Background="#F8FAFC">

    <UserControl.Resources>
        <x:Array x:Key="StatusOptions" Type="system:String">
            <system:String>대기</system:String>
            <system:String>신청완료</system:String>
            <system:String>진행</system:String>
            <system:String>완료</system:String>
            <system:String>취소</system:String>
        </x:Array>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 상태 카드 -->
            <RowDefinition Height="Auto"/>  <!-- 필터 바 -->
            <RowDefinition Height="*"/>     <!-- 데이터 그리드 -->
        </Grid.RowDefinitions>

        <!-- ── 상태 카드 ── -->
        <Grid Grid.Row="0" Margin="28,16,28,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <!-- 대기 -->
            <Border Grid.Column="0" Background="White" CornerRadius="10"
                    BorderBrush="#E2E8F0" BorderThickness="1">
                <Border.Effect><DropShadowEffect Color="#000" Opacity="0.04" BlurRadius="8" ShadowDepth="0"/></Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="4"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#F97316" CornerRadius="10,10,0,0"/>
                    <StackPanel Grid.Row="1" Margin="16,10,16,12">
                        <TextBlock x:Name="CountWaiting" Text="0" FontSize="26" FontWeight="Bold" Foreground="#F97316"/>
                        <TextBlock Text="대기" FontSize="12" Foreground="#94A3B8" FontWeight="SemiBold" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 신청완료 -->
            <Border Grid.Column="2" Background="White" CornerRadius="10"
                    BorderBrush="#E2E8F0" BorderThickness="1">
                <Border.Effect><DropShadowEffect Color="#000" Opacity="0.04" BlurRadius="8" ShadowDepth="0"/></Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="4"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#0D9488" CornerRadius="10,10,0,0"/>
                    <StackPanel Grid.Row="1" Margin="16,10,16,12">
                        <TextBlock x:Name="CountApplied" Text="0" FontSize="26" FontWeight="Bold" Foreground="#0D9488"/>
                        <TextBlock Text="신청완료" FontSize="12" Foreground="#94A3B8" FontWeight="SemiBold" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 취소 -->
            <Border Grid.Column="4" Background="White" CornerRadius="10"
                    BorderBrush="#E2E8F0" BorderThickness="1">
                <Border.Effect><DropShadowEffect Color="#000" Opacity="0.04" BlurRadius="8" ShadowDepth="0"/></Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="4"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#EF4444" CornerRadius="10,10,0,0"/>
                    <StackPanel Grid.Row="1" Margin="16,10,16,12">
                        <TextBlock x:Name="CountCancelled" Text="0" FontSize="26" FontWeight="Bold" Foreground="#EF4444"/>
                        <TextBlock Text="취소" FontSize="12" Foreground="#94A3B8" FontWeight="SemiBold" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 진행 -->
            <Border Grid.Column="6" Background="White" CornerRadius="10"
                    BorderBrush="#E2E8F0" BorderThickness="1">
                <Border.Effect><DropShadowEffect Color="#000" Opacity="0.04" BlurRadius="8" ShadowDepth="0"/></Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="4"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#2563EB" CornerRadius="10,10,0,0"/>
                    <StackPanel Grid.Row="1" Margin="16,10,16,12">
                        <TextBlock x:Name="CountInProgress" Text="0" FontSize="26" FontWeight="Bold" Foreground="#2563EB"/>
                        <TextBlock Text="진행" FontSize="12" Foreground="#94A3B8" FontWeight="SemiBold" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 완료 -->
            <Border Grid.Column="8" Background="White" CornerRadius="10"
                    BorderBrush="#E2E8F0" BorderThickness="1">
                <Border.Effect><DropShadowEffect Color="#000" Opacity="0.04" BlurRadius="8" ShadowDepth="0"/></Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="4"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#10B981" CornerRadius="10,10,0,0"/>
                    <StackPanel Grid.Row="1" Margin="16,10,16,12">
                        <TextBlock x:Name="CountDone" Text="0" FontSize="26" FontWeight="Bold" Foreground="#10B981"/>
                        <TextBlock Text="완료" FontSize="12" Foreground="#94A3B8" FontWeight="SemiBold" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 전체 -->
            <Border Grid.Column="10" Background="White" CornerRadius="10"
                    BorderBrush="#E2E8F0" BorderThickness="1">
                <Border.Effect><DropShadowEffect Color="#000" Opacity="0.04" BlurRadius="8" ShadowDepth="0"/></Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="4"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#64748B" CornerRadius="10,10,0,0"/>
                    <StackPanel Grid.Row="1" Margin="16,10,16,12">
                        <TextBlock x:Name="CountTotal" Text="0" FontSize="26" FontWeight="Bold" Foreground="#64748B"/>
                        <TextBlock Text="전체" FontSize="12" Foreground="#94A3B8" FontWeight="SemiBold" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ── 필터 바 ── -->
        <Grid Grid.Row="1" Margin="28,12,28,0">
            <!-- 왼쪽: 상태 필터 + 전체 건수 -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="상태 필터:" FontSize="12" Foreground="#64748B" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="StatusFilter" Width="130" Height="28"
                          FontSize="12" SelectionChanged="StatusFilter_SelectionChanged"/>
                <Border Background="#EFF6FF" CornerRadius="6" Padding="10,3" Margin="12,0,0,0" VerticalAlignment="Center">
                    <TextBlock x:Name="TotalBadge" Text="전체 0건" FontSize="12" Foreground="#2563EB" FontWeight="SemiBold"/>
                </Border>
            </StackPanel>

            <!-- 오른쪽: 연도 선택 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button x:Name="BtnPrevYear" Content="◄" Width="30" Height="30"
                        Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                        Foreground="#64748B" FontSize="12" Cursor="Hand"
                        Click="BtnPrevYear_Click">
                    <Button.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                    </Button.Resources>
                </Button>
                <TextBlock x:Name="YearText" FontSize="15" FontWeight="Bold" Foreground="#0F172A"
                           Width="60" TextAlignment="Center" VerticalAlignment="Center"/>
                <Button x:Name="BtnNextYear" Content="►" Width="30" Height="30"
                        Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                        Foreground="#64748B" FontSize="12" Cursor="Hand"
                        Click="BtnNextYear_Click">
                    <Button.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ── 데이터 그리드 ── -->
        <DataGrid x:Name="EduDataGrid" Grid.Row="2"
                  Margin="28,10,28,20"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" SelectionUnit="FullRow"
                  Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                  RowHeight="36" HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9"
                  AlternatingRowBackground="#FAFAFA"
                  CanUserSortColumns="True">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#F8FAFC"/>
                    <Setter Property="Foreground" Value="#475569"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="Padding" Value="10,7"/>
                    <Setter Property="BorderBrush" Value="#E2E8F0"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="이름" Binding="{Binding MemberName}" Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="10,0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="사번" Binding="{Binding Username}" Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#94A3B8"/>
                            <Setter Property="Padding" Value="10,0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="소속팀" Binding="{Binding TeamName}" Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding" Value="10,0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="교육명" Binding="{Binding CourseName}" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding" Value="10,0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="시작일" Binding="{Binding StartDateStr}" Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding" Value="10,0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="종료일" Binding="{Binding EndDateStr}" Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding" Value="10,0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- 상태 컬럼: 인라인 ComboBox -->
                <DataGridTemplateColumn Header="상태" Width="110" SortMemberPath="Status">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{StaticResource StatusOptions}"
                                      SelectedItem="{Binding Status, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      SelectionChanged="StatusComboBox_SelectionChanged"
                                      Height="26" FontSize="11" FontWeight="SemiBold"
                                      VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                      Padding="6,0" Margin="6,0" BorderThickness="1">
                                <ComboBox.Style>
                                    <Style TargetType="ComboBox">
                                        <Setter Property="Background" Value="#FEF3C7"/>
                                        <Setter Property="Foreground" Value="#D97706"/>
                                        <Setter Property="BorderBrush" Value="#FDE68A"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="신청완료">
                                                <Setter Property="Background" Value="#CCFBF1"/>
                                                <Setter Property="Foreground" Value="#0F766E"/>
                                                <Setter Property="BorderBrush" Value="#99F6E4"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="진행">
                                                <Setter Property="Background" Value="#DBEAFE"/>
                                                <Setter Property="Foreground" Value="#2563EB"/>
                                                <Setter Property="BorderBrush" Value="#BFDBFE"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="완료">
                                                <Setter Property="Background" Value="#D1FAE5"/>
                                                <Setter Property="Foreground" Value="#065F46"/>
                                                <Setter Property="BorderBrush" Value="#A7F3D0"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="취소">
                                                <Setter Property="Background" Value="#FEE2E2"/>
                                                <Setter Property="Foreground" Value="#DC2626"/>
                                                <Setter Property="BorderBrush" Value="#FCA5A5"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ComboBox.Style>
                            </ComboBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- 진행률 컬럼: 텍스트 + ProgressBar -->
                <DataGridTemplateColumn Header="진행률" Width="110" SortMemberPath="Progress">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Margin="10,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding ProgressStr}" FontSize="11"
                                           Foreground="#475569" Margin="0,0,0,3"/>
                                <ProgressBar Value="{Binding Progress}" Maximum="100"
                                             Height="5" Background="#E2E8F0"
                                             Foreground="#2563EB" BorderThickness="0"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="방법" Binding="{Binding EduMethod}" Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding" Value="10,0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

    </Grid>
</UserControl>
