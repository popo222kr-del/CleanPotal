<Window x:Class="CleanPotal.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="세정팀 업무 통합 관리 시스템" Height="900" Width="1600"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        RenderOptions.BitmapScalingMode="HighQuality"
        UseLayoutRounding="True" SnapsToDevicePixels="True">

    <Window.Resources>
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Malgun Gothic"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="12,2"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F1F5F9"/>
                                <Setter Property="Foreground" Value="#0F172A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarButtonSelectedStyle" TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
            <Setter Property="Background" Value="#EFF6FF"/>
            <Setter Property="Foreground" Value="#2563EB"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="SidebarSubButtonStyle" TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
            <Setter Property="Height" Value="48"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Malgun Gothic"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Padding" Value="44,0,20,0"/>
        </Style>

        <Style x:Key="SidebarSubButtonSelectedStyle" TargetType="Button" BasedOn="{StaticResource SidebarSubButtonStyle}">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#2563EB"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="HeaderButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="21">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F8FAFC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="24,24,24,16" Orientation="Horizontal">
                    <Image x:Name="AppLogoImage" Source="/Images/bono.png" Width="42" Height="42" Margin="0,0,12,0" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="CleanPotal" FontSize="20" FontWeight="ExtraBold" Foreground="#0F172A"/>
                        <TextBlock Text="세정팀 통합 관리" FontSize="12" Foreground="#64748B"/>
                    </StackPanel>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,16,0,0">
                    <StackPanel>
                        <TextBlock Text="MAIN MENU" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="24,12,0,8" />
                        <Button x:Name="BtnNavPortal" Content="업무 파일 통합 관리" Style="{StaticResource SidebarButtonSelectedStyle}" Click="OpenPortal"/>
                        <Button x:Name="BtnNavHandover" Content="현장 인수인계" Style="{StaticResource SidebarButtonStyle}" Click="OpenHandover"/>

                        <Button x:Name="BtnNavVendor" Content="• 업체 정보 관리" Style="{StaticResource SidebarSubButtonStyle}" Click="OpenVendorManager_Click"/>

                        <Button x:Name="BtnNavSchedule" Content="스케줄 보드" Style="{StaticResource SidebarButtonStyle}" Click="OpenSchedule"/>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2" Margin="20,20,20,24" Padding="16" Background="#F8FAFC" CornerRadius="12">
                    <StackPanel>
                        <TextBlock Text="오늘 날짜" FontSize="12" Foreground="#64748B" Margin="0,0,0,4"/>
                        <TextBlock x:Name="TodayBadgeText" Text="2026-03-23 월요일" FontSize="14" FontWeight="Bold" Foreground="#0F172A"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="88"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                <Grid>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Left" Margin="40,0,0,0">
                        <TextBlock x:Name="CurrentSectionTitleText" Text="대시보드" FontSize="24" FontWeight="ExtraBold" Foreground="#0F172A"/>
                        <TextBlock x:Name="CurrentSectionDescriptionText" Text="설명" FontSize="14" Foreground="#64748B"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,40,0">
                        <Button x:Name="BtnCommandNotice" Content="공지 관리" Style="{StaticResource HeaderButtonStyle}" Visibility="Collapsed"/>
                        <Button x:Name="BtnCommandSecondary" Content="완료 목록" Style="{StaticResource HeaderButtonStyle}" Visibility="Collapsed"/>
                        <Button x:Name="BtnCommandProdReq" Content="생산팀 요청사항" Style="{StaticResource HeaderButtonStyle}" Visibility="Collapsed"/>

                        <Button x:Name="BtnCommandRecipeManage" Content="레시피 관리" Style="{StaticResource HeaderButtonStyle}" Visibility="Collapsed" Click="BtnCommandRecipeManage_Click"/>
                        <Button x:Name="BtnCommandCapture" Content="화면 캡처" Style="{StaticResource HeaderButtonStyle}" Visibility="Collapsed" Click="BtnCommandCapture_Click"/>
                        <Button x:Name="BtnCommandUndo" Content="되돌리기" Style="{StaticResource HeaderButtonStyle}" Visibility="Collapsed" Click="BtnCommandUndo_Click"/>
                        <Button x:Name="BtnCommandPartialReset" Content="부분 초기화" Style="{StaticResource HeaderButtonStyle}" Visibility="Collapsed" Click="BtnCommandPartialReset_Click"/>
                        <Button x:Name="BtnCommandReset" Content="전체 초기화" Style="{StaticResource HeaderButtonStyle}" Visibility="Collapsed" Foreground="#DC2626" Click="BtnCommandReset_Click"/>

                        <Button x:Name="BtnCommandPrimary" Content="파일 관리자" Style="{StaticResource HeaderButtonStyle}" Background="#111827" Foreground="White" BorderThickness="0" Visibility="Visible" Click="ManagePortalLinks_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <ContentControl x:Name="MainContent" Grid.Row="1" Margin="40,32,40,40"/>
        </Grid>
    </Grid>
</Window>