<Window x:Class="CleanPotal.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CleanPotal"
        Title="세정팀 업무 파일 통합 관리"
        Height="720" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="White"
        FontFamily="Malgun Gothic">

    <Window.Resources>

        <!-- 포털 버튼 스타일 -->
        <Style x:Key="PortalButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Background" Value="#FFD9D9D9"/>
            <Setter Property="BorderBrush" Value="#FF8A8A8A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- DataGrid 헤더 중앙 -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- DataGrid 셀 중앙(셀 컨테이너) -->
        <Style x:Key="CenterCellStyle" TargetType="DataGridCell">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="6,0"/>
        </Style>

        <!-- 공통 TextColumn(업체/입고일/출고일/상태)용: 글자 완전 중앙 -->
        <Style x:Key="CenterTextBlockStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- 컨버터 -->
        <local:PercentToBrushConverter x:Key="PercentToBrushConverter"/>
        <local:ProgressToWidthConverter x:Key="ProgressToWidthConverter"/>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- ProgressBar 색상이 Foreground대로 보이게 템플릿 -->
        <Style x:Key="ProgressBarColorStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="16"/>
            <Setter Property="Background" Value="#FFE5E5E5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="#FFB0B0B0"
                                    BorderThickness="1"/>
                            <Border Background="{TemplateBinding Foreground}"
                                    HorizontalAlignment="Left">
                                <Border.Width>
                                    <MultiBinding Converter="{StaticResource ProgressToWidthConverter}">
                                        <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="Value"/>
                                        <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="Maximum"/>
                                        <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="ActualWidth"/>
                                    </MultiBinding>
                                </Border.Width>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="10">
        <TabControl x:Name="MainTabs" Margin="0">

            <!-- ========================= -->
            <!-- 탭 1: 포털 -->
            <!-- ========================= -->
            <TabItem Header="업무 파일 통합 관리">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 탭1 헤더: 로고 + 큰제목 + 작은날짜 / 공지사항 없음 / 닫기 유지 -->
                    <Grid Grid.Row="0" Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Top"
                                    Margin="0,6,0,0">

                            <!-- 로고 -->
                            <Image Source="pack://application:,,,/Images/logo.png"
                                   Width="60" Height="60"
                                   Margin="0,0,15,0"
                                   Stretch="Uniform"/>

                            <StackPanel>
                                <TextBlock Text="세정팀 업무 파일 통합 관리"
                                           FontSize="28"
                                           FontWeight="Bold"
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="{Binding TodayText}"
                                           FontSize="14"/>
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="닫기"
                                Width="140" Height="44"
                                Margin="0,8,0,0"
                                Background="#FFD9D9D9"
                                BorderBrush="#FF8A8A8A"
                                BorderThickness="1"
                                Click="Close_Click"
                                VerticalAlignment="Top"/>
                    </Grid>

                    <!-- 포털 버튼 영역 -->
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <GroupBox Grid.Row="0" Grid.Column="0" Header="A급 QTZ" Margin="0,0,12,12">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button x:Name="Btn_A1" Grid.Row="0" Grid.Column="0" Style="{StaticResource PortalButtonStyle}"/>
                                <Button x:Name="Btn_A2" Grid.Row="0" Grid.Column="1" Style="{StaticResource PortalButtonStyle}"/>
                                <Button x:Name="Btn_A3" Grid.Row="1" Grid.Column="0" Style="{StaticResource PortalButtonStyle}"/>
                                <Button x:Name="Btn_A4" Grid.Row="1" Grid.Column="1" Style="{StaticResource PortalButtonStyle}"/>
                                <Button x:Name="Btn_A5" Grid.Row="2" Grid.Column="0" Style="{StaticResource PortalButtonStyle}"/>
                            </Grid>
                        </GroupBox>

                        <GroupBox Grid.Row="0" Grid.Column="1" Header="세메스" Margin="0,0,12,12">
                            <StackPanel Margin="10">
                                <Button x:Name="Btn_S1" Style="{StaticResource PortalButtonStyle}"/>
                                <Button x:Name="Btn_S2" Style="{StaticResource PortalButtonStyle}"/>
                                <Button x:Name="Btn_S3" Style="{StaticResource PortalButtonStyle}"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Grid.Row="0" Grid.Column="2" Header="기타" Margin="0,0,0,12">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button x:Name="Btn_E1" Grid.Row="0" Grid.Column="0" Style="{StaticResource PortalButtonStyle}"/>
                                <Button x:Name="Btn_E2" Grid.Row="0" Grid.Column="1" Style="{StaticResource PortalButtonStyle}"/>
                                <Button x:Name="Btn_E3" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource PortalButtonStyle}"/>
                            </Grid>
                        </GroupBox>

                        <GroupBox Grid.Row="1" Grid.Column="0" Header="폴더" Margin="0,0,12,0">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button x:Name="Btn_F1" Grid.Row="0" Grid.Column="0" Style="{StaticResource PortalButtonStyle}"/>
                                <Button x:Name="Btn_F2" Grid.Row="0" Grid.Column="1" Style="{StaticResource PortalButtonStyle}"/>
                                <Button x:Name="Btn_F3" Grid.Row="1" Grid.Column="0" Style="{StaticResource PortalButtonStyle}"/>
                                <Button x:Name="Btn_F4" Grid.Row="1" Grid.Column="1" Style="{StaticResource PortalButtonStyle}"/>
                            </Grid>
                        </GroupBox>

                        <GroupBox Grid.Row="1" Grid.Column="1" Header="DOME" Margin="0,0,12,0">
                            <StackPanel Margin="10">
                                <Button x:Name="Btn_D1" Style="{StaticResource PortalButtonStyle}"/>
                                <Button x:Name="Btn_D2" Style="{StaticResource PortalButtonStyle}"/>
                                <Button x:Name="Btn_D3" Style="{StaticResource PortalButtonStyle}"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Grid.Row="1" Grid.Column="2" Header="Daily" Margin="0">
                            <Grid Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button x:Name="Btn_Daily1" Grid.Column="0" Style="{StaticResource PortalButtonStyle}"/>
                                <Button x:Name="Btn_Daily2" Grid.Column="1" Style="{StaticResource PortalButtonStyle}"/>
                            </Grid>
                        </GroupBox>
                    </Grid>

                    <TextBlock Grid.Row="2"
                               Text="{Binding StatusText}"
                               Foreground="Gray"
                               Margin="0,12,0,0"/>
                </Grid>
            </TabItem>

            <!-- ========================= -->
            <!-- 탭 2: 인수인계 -->
            <!-- ========================= -->
            <TabItem Header="인수인계">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 탭2 헤더 -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="540"/>
                        </Grid.ColumnDefinitions>

                        <!-- 왼쪽: 로고 + 큰제목 + 작은날짜 -->
                        <StackPanel Grid.Column="0"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Top"
                                    Margin="0,6,0,0">
                            <Image Source="pack://application:,,,/Images/logo.png"
                                   Width="60" Height="60"
                                   Margin="0,0,15,0"
                                   Stretch="Uniform"/>

                            <StackPanel>
                                <TextBlock Text="세정 작업 인수인계서"
                                           FontSize="28"
                                           FontWeight="Bold"
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="{Binding TodayText}"
                                           FontSize="14"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- 오른쪽: 공지사항 -->
                        <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Top">
                            <TextBlock Text="공지사항"
                                       FontWeight="Bold"
                                       FontSize="15"
                                       Margin="6,0,0,6"/>

                            <Border BorderBrush="#BDBDBD"
                                    BorderThickness="1"
                                    Background="White"
                                    Padding="10"
                                    Width="520"
                                    Height="110">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <TextBlock Text="{Binding NoticeText}"
                                               TextWrapping="Wrap"
                                               FontSize="13"/>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- 등록/수정 (기본 접힘) -->
                    <Expander Grid.Row="1" Header="등록/수정" IsExpanded="False" Margin="0,0,0,12">
                        <Border BorderBrush="#FFD0D0D0" BorderThickness="1" Padding="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="320"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="300"/>
                                </Grid.ColumnDefinitions>

                                <!-- 1줄 -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="업체" VerticalAlignment="Center" TextAlignment="Right" Margin="0,0,8,0"/>
                                <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding EditVendor, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0"/>

                                <TextBlock Grid.Row="0" Grid.Column="2" Text="내용" VerticalAlignment="Center" TextAlignment="Right" Margin="0,0,8,0"/>
                                <TextBox   Grid.Row="0" Grid.Column="3"
                                           Text="{Binding EditContent, UpdateSourceTrigger=PropertyChanged}"
                                           Margin="0,0,12,0"
                                           AcceptsReturn="True"
                                           TextWrapping="Wrap"
                                           VerticalScrollBarVisibility="Auto"
                                           MinHeight="28"/>

                                <TextBlock Grid.Row="0" Grid.Column="4" Text="입고일" VerticalAlignment="Center" TextAlignment="Right" Margin="0,0,8,0"/>
                                <DatePicker Grid.Row="0" Grid.Column="5" SelectedDate="{Binding EditInDate}" Margin="0,0,12,0"/>

                                <TextBlock Grid.Row="0" Grid.Column="6" Text="출고일" VerticalAlignment="Center" TextAlignment="Right" Margin="0,0,8,0"/>
                                <DatePicker Grid.Row="0" Grid.Column="7" SelectedDate="{Binding EditOutDate}" Margin="0,0,12,0"/>

                                <!-- 2줄 -->
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="상태" VerticalAlignment="Center" TextAlignment="Right" Margin="0,8,8,0"/>
                                <ComboBox  Grid.Row="1" Grid.Column="1"
                                           ItemsSource="{Binding StatusOptions}"
                                           SelectedItem="{Binding EditStatus}"
                                           Margin="0,8,12,0"/>

                                <TextBlock Grid.Row="1" Grid.Column="2" Text="메모" VerticalAlignment="Center" TextAlignment="Right" Margin="0,8,8,0"/>
                                <TextBox   Grid.Row="1" Grid.Column="3"
                                           Text="{Binding EditMemo, UpdateSourceTrigger=PropertyChanged}"
                                           Margin="0,10,12,0"
                                           AcceptsReturn="True"
                                           TextWrapping="Wrap"
                                           VerticalScrollBarVisibility="Auto"
                                           MinHeight="28"/>

                                <!-- 진행률 미리보기 -->
                                <TextBlock Grid.Row="1" Grid.Column="4" Text="진행률" VerticalAlignment="Center" TextAlignment="Right" Margin="0,8,8,0"/>
                                <ProgressBar Grid.Row="1" Grid.Column="5"
                                             Minimum="0" Maximum="100"
                                             Value="{Binding EditProgressPercent, Mode=OneWay}"
                                             Style="{StaticResource ProgressBarColorStyle}"
                                             Foreground="{Binding EditProgressPercent, Mode=OneWay, Converter={StaticResource PercentToBrushConverter}}"
                                             Margin="0,15,11,4"/>
                                <TextBlock Grid.Row="1" Grid.Column="6" Grid.ColumnSpan="2"
                                           Text="{Binding EditProgressText, Mode=OneWay}"
                                           VerticalAlignment="Center"
                                           Margin="0,8,1,0"/>

                                <!-- 버튼 -->
                                <Button Grid.Row="0" Grid.Column="8" Grid.RowSpan="2"
                                        Content="추가/저장"
                                        Width="110" Height="34"
                                        HorizontalAlignment="Right"
                                        Margin="0,18,120,14"
                                        Click="HandoverSave_Click"/>

                                <Button Grid.Row="0" Grid.Column="8" Grid.RowSpan="2"
                                        Content="초기화"
                                        Width="90" Height="34"
                                        HorizontalAlignment="Right"
                                        Margin="0,18,20,14"
                                        Click="HandoverReset_Click"/>
                            </Grid>
                        </Border>
                    </Expander>

                    <!-- 진행/보류 목록 -->
                    <DataGrid x:Name="ActiveGrid"
                              Grid.Row="2"
                              ItemsSource="{Binding ActiveItems}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              FontSize="14"
                              RowHeight="56"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              BorderBrush="#FFD0D0D0"
                              BorderThickness="1"
                              CellStyle="{StaticResource CenterCellStyle}">

                        <!-- 행 컨텐츠를 위아래까지 완전 중앙으로 -->
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.Columns>
                            <!-- 선택 -->
                            <DataGridTemplateColumn Header="선택" Width="60">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  IsChecked="{Binding ManageChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="업체" Binding="{Binding Vendor}" Width="120"
                                                ElementStyle="{StaticResource CenterTextBlockStyle}"/>

                            <DataGridTemplateColumn Header="내용" Width="300">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Content}"
                                                   TextWrapping="Wrap"
                                                   TextAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="입고일" Binding="{Binding InDate, StringFormat=yyyy-MM-dd}" Width="110"
                                                ElementStyle="{StaticResource CenterTextBlockStyle}"/>
                            <DataGridTextColumn Header="출고일" Binding="{Binding OutDate, StringFormat=yyyy-MM-dd}" Width="110"
                                                ElementStyle="{StaticResource CenterTextBlockStyle}"/>
                            <DataGridTextColumn Header="상태" Binding="{Binding Status}" Width="90"
                                                ElementStyle="{StaticResource CenterTextBlockStyle}"/>

                            <DataGridTemplateColumn Header="메모" Width="200">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Memo}"
                                                   TextWrapping="Wrap"
                                                   TextAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- 진행률 -->
                            <DataGridTemplateColumn Header="진행률" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid Margin="6,0" VerticalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="50"/>
                                            </Grid.ColumnDefinitions>

                                            <ProgressBar Grid.Column="0"
                                                         Minimum="0" Maximum="100"
                                                         Height="18"
                                                         VerticalAlignment="Center"
                                                         Value="{Binding ProgressPercent, Mode=OneWay}"
                                                         Style="{StaticResource ProgressBarColorStyle}"
                                                         Foreground="{Binding ProgressPercent, Mode=OneWay, Converter={StaticResource PercentToBrushConverter}}"/>

                                            <TextBlock Grid.Column="1"
                                                       Margin="8,0,0,0"
                                                       VerticalAlignment="Center"
                                                       TextAlignment="Center"
                                                       Text="{Binding ProgressText, Mode=OneWay}"/>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- 관리 -->
                            <DataGridTemplateColumn x:Name="ManageColumn" Header="관리" Width="170" Visibility="Collapsed">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Button Content="수정"
                                                    Width="60" Height="30" Margin="4,0"
                                                    Click="HandoverEdit_Click"
                                                    Visibility="{Binding ManageChecked, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            <Button Content="삭제"
                                                    Width="60" Height="30" Margin="4,0"
                                                    Foreground="#FFB00000"
                                                    Click="HandoverDelete_Click"
                                                    Visibility="{Binding ManageChecked, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- 완료 목록: 기본 닫힘 / 진행률 표시 없음 -->
                    <Expander Grid.Row="3"
                              Header="완료 목록 (여기서 삭제하면 Excel에 자동 기록)"
                              IsExpanded="False"
                              Margin="0,12,0,0">
                        <Border BorderBrush="#FFD0D0D0" BorderThickness="1" Padding="8">
                            <DataGrid x:Name="DoneGrid"
                                      ItemsSource="{Binding DoneItems}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      FontSize="14"
                                      RowHeight="56"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      BorderBrush="#FFD0D0D0"
                                      BorderThickness="1"
                                      CellStyle="{StaticResource CenterCellStyle}">

                                <!-- 행 컨텐츠 위아래까지 완전 중앙 -->
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    </Style>
                                </DataGrid.RowStyle>

                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="업체" Binding="{Binding Vendor}" Width="120"
                                                        ElementStyle="{StaticResource CenterTextBlockStyle}"/>

                                    <DataGridTemplateColumn Header="내용" Width="260">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Content}"
                                                           TextWrapping="Wrap"
                                                           TextAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTextColumn Header="입고일" Binding="{Binding InDate, StringFormat=yyyy-MM-dd}" Width="110"
                                                        ElementStyle="{StaticResource CenterTextBlockStyle}"/>
                                    <DataGridTextColumn Header="출고일" Binding="{Binding OutDate, StringFormat=yyyy-MM-dd}" Width="110"
                                                        ElementStyle="{StaticResource CenterTextBlockStyle}"/>
                                    <DataGridTextColumn Header="상태" Binding="{Binding Status}" Width="90"
                                                        ElementStyle="{StaticResource CenterTextBlockStyle}"/>

                                    <DataGridTemplateColumn Header="메모" Width="220">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Memo}"
                                                           TextWrapping="Wrap"
                                                           TextAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <!-- 완료목록 삭제 -->
                                    <DataGridTemplateColumn Header="삭제" Width="90">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="삭제"
                                                        Width="60" Height="30"
                                                        Foreground="#FFB00000"
                                                        Click="DoneDelete_Click"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>

                            </DataGrid>
                        </Border>
                    </Expander>

                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>