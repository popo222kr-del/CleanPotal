<Window x:Class="CleanPortal.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="세정팀 업무 파일 통합 관리"
        Height="720" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="White"
        FontFamily="Malgun Gothic">

    <Grid Margin="20,20,0,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 헤더 -->
            <RowDefinition Height="*"/>
            <!-- 본문 -->
            <RowDefinition Height="Auto"/>
            <!-- 상태 -->
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="세정팀 업무 파일 통합 관리"
                           FontSize="26"
                           FontWeight="Bold"/>
                <TextBlock Text="{Binding TodayText}"
                           Margin="0,6,0,0"
                           FontSize="14"/>
            </StackPanel>

            <Button
                    Content="닫기"
                    Click="Close_Click" Margin="1082,10,18,10"/>
        </Grid>

        <!-- 본문: Access처럼 고정 배치 -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="386.667"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <!-- 1행 -->
            <GroupBox Grid.Row="0" Grid.Column="0" Margin="0,0,16,16" Padding="12"
                      Header="A급 QTZ">
                <ItemsControl ItemsSource="{Binding Path=Groups, Converter={StaticResource GroupItemsConverter}, ConverterParameter=A급 QTZ}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="2"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Title}"
                                    Height="38"
                                    Margin="0,0,10,10"
                                    Tag="{Binding}"
                                    Click="OpenItem_Click"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </GroupBox>

            <GroupBox Grid.Row="0" Grid.Column="1" Margin="0,0,16,16" Padding="12"
                      Header="세메스">
                <ItemsControl ItemsSource="{Binding Path=Groups, Converter={StaticResource GroupItemsConverter}, ConverterParameter=세메스}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="1"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Title}"
                                    Height="38"
                                    Margin="0,0,10,10"
                                    Tag="{Binding}"
                                    Click="OpenItem_Click"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </GroupBox>

            <GroupBox Grid.Row="0" Grid.Column="2" Margin="0,0,0,16" Padding="12"
                      Header="기타">
                <ItemsControl ItemsSource="{Binding Path=Groups, Converter={StaticResource GroupItemsConverter}, ConverterParameter=기타}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="2"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Title}"
                                    Height="38"
                                    Margin="0,0,10,10"
                                    Tag="{Binding}"
                                    Click="OpenItem_Click"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </GroupBox>

            <!-- 2행 -->
            <GroupBox Grid.Row="1" Grid.Column="0" Margin="0,0,16,16" Padding="12"
                      Header="폴더">
                <ItemsControl ItemsSource="{Binding Path=Groups, Converter={StaticResource GroupItemsConverter}, ConverterParameter=폴더}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="2"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Title}"
                                    Height="38"
                                    Margin="0,0,10,10"
                                    Tag="{Binding}"
                                    Click="OpenItem_Click"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </GroupBox>

            <GroupBox Grid.Row="1" Grid.Column="1" Margin="0,0,16,16" Padding="12"
                      Header="DOME">
                <ItemsControl ItemsSource="{Binding Path=Groups, Converter={StaticResource GroupItemsConverter}, ConverterParameter=DOME}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="1"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Title}"
                                    Height="38"
                                    Margin="0,0,10,10"
                                    Tag="{Binding}"
                                    Click="OpenItem_Click"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </GroupBox>

            <GroupBox Grid.Row="1" Grid.Column="2" Margin="0,0,0,16" Padding="12"
                      Header="Daily">
                <ItemsControl ItemsSource="{Binding Path=Groups, Converter={StaticResource GroupItemsConverter}, ConverterParameter=Daily}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="2"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Title}"
                                    Height="38"
                                    Margin="0,0,10,10"
                                    Tag="{Binding}"
                                    Click="OpenItem_Click"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </GroupBox>
        </Grid>

        <!-- 상태 -->
        <TextBlock Grid.Row="2"
                   Text="{Binding StatusText}"
                   Margin="0,10,0,0"
                   Foreground="Gray"/>
    </Grid>
</Window>
