<Window x:Class="CleanPotal.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="세정팀 업무 통합 관리 시스템" Height="900" Width="1600"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        RenderOptions.BitmapScalingMode="HighQuality"
        UseLayoutRounding="True" SnapsToDevicePixels="True">

    <Window.Resources>
        <!-- 🎨 모던 네비게이션 버튼 스타일 (최상위 단일 메뉴) -->
        <Style x:Key="ModernNavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Margin="10,2,10,2">
                            <!-- 왼쪽 세로 악센트 바 (선택 시에만 보임, 여기선 Collapsed) -->
                            <Border x:Name="Accent" Width="3" Height="22" CornerRadius="1.5" Background="#2563EB" HorizontalAlignment="Left" VerticalAlignment="Center" Visibility="Collapsed"/>
                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" HorizontalAlignment="Stretch">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="Icon" Grid.Column="0" Text="{TemplateBinding Tag}" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI Symbol" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}"/>
                                    <Grid Grid.Column="1" Width="176" HorizontalAlignment="Left" ClipToBounds="True">
                                        <TextBlock Text="{TemplateBinding Content}" FontSize="13.5" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}" Margin="2,0,0,0"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F1F5F9"/>
                                <Setter Property="Foreground" Value="#0F172A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 🎨 모던 네비게이션 버튼 - 선택 상태 -->
        <Style x:Key="ModernNavButtonSelectedStyle" TargetType="Button" BasedOn="{StaticResource ModernNavButtonStyle}">
            <Setter Property="Foreground" Value="#1D4ED8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Margin="10,2,10,2">
                            <Border x:Name="Accent" Width="3" Height="22" CornerRadius="1.5" Background="#2563EB" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                            <Border x:Name="border" Background="#DBEAFE" CornerRadius="8" HorizontalAlignment="Stretch">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{TemplateBinding Tag}" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI Symbol" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}"/>
                                    <Grid Grid.Column="1" Width="176" HorizontalAlignment="Left" ClipToBounds="True">
                                        <TextBlock Text="{TemplateBinding Content}" FontSize="13.5" FontWeight="Bold" VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}" Margin="2,0,0,0"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 🎨 모던 Expander 헤더 (Chevron 회전 애니메이션 포함) -->
        <Style x:Key="ModernExpanderHeaderStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" Margin="10,2,10,2" HorizontalAlignment="Stretch">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Tag, RelativeSource={RelativeSource AncestorType=Expander}}" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI Symbol" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}"/>
                                <Grid Grid.Column="1" Width="176" HorizontalAlignment="Left" ClipToBounds="True">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="28"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{TemplateBinding Content}" VerticalAlignment="Center" FontSize="13.5" FontWeight="SemiBold" Foreground="{TemplateBinding Foreground}" Margin="2,0,0,0"/>
                                    <!-- 회전하는 Chevron 아이콘 -->
                                    <TextBlock x:Name="Chevron" Grid.Column="1" Text="&#xE70D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI Symbol" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#94A3B8" RenderTransformOrigin="0.5,0.5">
                                        <TextBlock.RenderTransform>
                                            <RotateTransform x:Name="ChevronRotation" Angle="0"/>
                                        </TextBlock.RenderTransform>
                                    </TextBlock>
                                </Grid>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ChevronRotation" Storyboard.TargetProperty="Angle" To="180" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ChevronRotation" Storyboard.TargetProperty="Angle" To="0" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F1F5F9"/>
                                <Setter Property="Foreground" Value="#0F172A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 🎨 모던 Expander (슬라이드 다운 애니메이션) -->
        <Style x:Key="ModernExpanderStyle" TargetType="Expander">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <StackPanel>
                            <ToggleButton Content="{TemplateBinding Header}" IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}" Style="{StaticResource ModernExpanderHeaderStyle}"/>
                            <Border x:Name="ExpandSite" Background="Transparent" Margin="0,0,0,4" ClipToBounds="True">
                                <Border.LayoutTransform>
                                    <ScaleTransform x:Name="ExpandScale" ScaleY="0"/>
                                </Border.LayoutTransform>
                                <ContentPresenter/>
                            </Border>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ExpandScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.2" DecelerationRatio="0.6"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ExpandScale" Storyboard.TargetProperty="ScaleY" To="0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 🎨 모던 서브 메뉴 버튼 (불릿 제거 + 들여쓰기) -->
        <Style x:Key="ModernSubNavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Margin="10,1,10,1">
                            <Border x:Name="Accent" Width="3" Height="18" CornerRadius="1.5" Background="#2563EB" HorizontalAlignment="Left" VerticalAlignment="Center" Visibility="Collapsed"/>
                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" HorizontalAlignment="Stretch">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- 세로 얇은 연결선 (들여쓰기 시각화) -->
                                    <Border Grid.Column="0" Width="1" Background="#E2E8F0" HorizontalAlignment="Center" Margin="0,0,0,0"/>
                                    <Grid Grid.Column="1" Width="176" HorizontalAlignment="Left" ClipToBounds="True">
                                        <TextBlock Text="{TemplateBinding Content}" FontSize="13" FontWeight="Medium" VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}" Margin="2,0,0,0"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F1F5F9"/>
                                <Setter Property="Foreground" Value="#0F172A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 🎨 모던 서브 메뉴 버튼 - 선택 상태 -->
        <Style x:Key="ModernSubNavButtonSelectedStyle" TargetType="Button" BasedOn="{StaticResource ModernSubNavButtonStyle}">
            <Setter Property="Foreground" Value="#1D4ED8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Margin="10,1,10,1">
                            <Border x:Name="Accent" Width="3" Height="18" CornerRadius="1.5" Background="#2563EB" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                            <Border x:Name="border" Background="#DBEAFE" CornerRadius="6" HorizontalAlignment="Stretch">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="1" Background="#2563EB" HorizontalAlignment="Center" Opacity="0.3"/>
                                    <Grid Grid.Column="1" Width="176" HorizontalAlignment="Left" ClipToBounds="True">
                                        <TextBlock Text="{TemplateBinding Content}" FontSize="13" FontWeight="Bold" VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}" Margin="2,0,0,0"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 🎨 섹션 헤더 스타일 (MAIN / WORKSPACE / TOOLS) -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="Margin" Value="24,14,24,6"/>
        </Style>

        <!-- 기존 스타일 호환을 위한 별칭 (코드비하인드에서 사용 중) -->
        <Style x:Key="ErpMainButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernNavButtonStyle}"/>
        <Style x:Key="ErpMainButtonSelectedStyle" TargetType="Button" BasedOn="{StaticResource ModernNavButtonSelectedStyle}"/>
        <Style x:Key="ErpSubButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernSubNavButtonStyle}"/>
        <Style x:Key="ErpSubButtonSelectedStyle" TargetType="Button" BasedOn="{StaticResource ModernSubNavButtonSelectedStyle}"/>
        <Style x:Key="SidebarExpanderStyle" TargetType="Expander" BasedOn="{StaticResource ModernExpanderStyle}"/>
        <Style x:Key="SidebarExpanderActiveStyle" TargetType="Expander" BasedOn="{StaticResource ModernExpanderStyle}">
            <Setter Property="Foreground" Value="#2563EB"/>
        </Style>

        <Style x:Key="HeaderButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="21">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F8FAFC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" x:Name="SidebarBorder" Width="240" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="0,0,1,0" ClipToBounds="True">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.04" BlurRadius="12" ShadowDepth="0" Direction="0"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="72"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 🎨 로고 + 토글 영역 (현대화) -->
                <Grid Grid.Row="0" Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="64"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="BtnToggleSidebar" Grid.Column="0" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnToggleSidebar_Click" ToolTip="메뉴 접기/펼치기">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="togBd" Background="Transparent" CornerRadius="8" Width="36" Height="36" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE700;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI Symbol" FontSize="15" Foreground="#64748B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="togBd" Property="Background" Value="#F1F5F9"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Grid Grid.Column="1" Width="176" HorizontalAlignment="Left" ClipToBounds="True">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- 로고 이미지 with soft shadow -->
                            <Border Width="34" Height="34" Margin="0,0,10,0" CornerRadius="8">
                                <Border.Effect>
                                    <DropShadowEffect Color="#2563EB" Opacity="0.15" BlurRadius="10" ShadowDepth="2"/>
                                </Border.Effect>
                                <Image x:Name="AppLogoImage" Source="/Images/bono.png" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="CleanPotal" FontSize="17" FontWeight="ExtraBold" Foreground="#0F172A" LineHeight="18"/>
                                <TextBlock Text="세정팀 통합 관리" FontSize="10" Foreground="#94A3B8" FontWeight="Medium"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Grid>

                <!-- 🎨 메뉴 본문 (섹션 헤더 + 네비게이션) -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                    <StackPanel Margin="0,4,0,12">

                        <!-- 섹션: MAIN -->
                        <TextBlock x:Name="SectionHeaderMain" Text="MAIN" Style="{StaticResource SectionHeaderStyle}"/>
                        <Button x:Name="BtnNavPortal" Content="업무 파일 통합 관리" Tag="&#xE80F;" Style="{StaticResource ErpMainButtonSelectedStyle}" Click="OpenPortal"/>

                        <!-- 섹션: WORKSPACE (일정/인수인계/오피스 업무) -->
                        <TextBlock x:Name="SectionHeaderWorkspace" Text="WORKSPACE" Style="{StaticResource SectionHeaderStyle}"/>

                        <Expander x:Name="ExpanderAttendance" Header="일정관리" Tag="&#xE787;" Style="{StaticResource SidebarExpanderStyle}" Expanded="ExpanderAttendance_Expanded">
                            <StackPanel>
                                <Button x:Name="BtnNavTeamSchedule" Content="세정팀 일정 달력" Style="{StaticResource ErpSubButtonStyle}" Click="OpenTeamSchedule"/>
                                <Button x:Name="BtnNavPersonalMemo" Content="개인 메모장" Style="{StaticResource ErpSubButtonStyle}" Click="OpenPersonalMemo_Click"/>
                            </StackPanel>
                        </Expander>

                        <Grid>
                            <Expander x:Name="ExpanderProduction" Header="현장 인수인계" Tag="&#xE8D1;" Style="{StaticResource SidebarExpanderStyle}" Expanded="ExpanderProduction_Expanded">
                                <StackPanel>
                                    <Button x:Name="BtnNavHandover" Content="인수인계 현황" Style="{StaticResource ErpSubButtonStyle}" Click="OpenHandover"/>
                                    <Button x:Name="BtnNavWeeklyHandover" Content="주간세정 현황" Style="{StaticResource ErpSubButtonStyle}" Click="OpenWeeklyHandover_Click"/>
                                    <Button x:Name="BtnNavPersonalTask" Content="생산미팅" Style="{StaticResource ErpSubButtonStyle}" Click="OpenPersonalTask_Click" Cursor="Hand"/>
                                    <Grid>
                                        <Button x:Name="BtnNavProdReq" Content="생산팀 요청사항" Style="{StaticResource ErpSubButtonStyle}" Click="OpenProdReq_Click"/>
                                        <Border x:Name="BadgeProdReq" Background="#EF4444" CornerRadius="10" MinWidth="20" Height="20" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,18,0" Visibility="Collapsed" IsHitTestVisible="False">
                                            <TextBlock x:Name="BadgeProdReqText" Text="1" Foreground="White" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="6,0"/>
                                        </Border>
                                    </Grid>
                                    <Button x:Name="BtnNavSchedule" Content="스케줄 보드" Style="{StaticResource ErpSubButtonStyle}" Click="OpenSchedule"/>
                                </StackPanel>
                            </Expander>
                            <Border x:Name="BadgeExpanderProduction" Background="#EF4444" Width="8" Height="8" CornerRadius="4" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,18,18,0" Visibility="Collapsed" IsHitTestVisible="False"/>
                        </Grid>

                        <Expander x:Name="ExpanderFieldInspection" Header="현장 점검" Tag="&#xE8C8;" Style="{StaticResource SidebarExpanderStyle}" Expanded="ExpanderFieldInspection_Expanded">
                            <StackPanel>
                                <Button x:Name="BtnNavFieldChecklist" Content="체크시트" Style="{StaticResource ErpSubButtonStyle}" Click="OpenFieldChecklist_Click"/>
                            </StackPanel>
                        </Expander>

                        <Expander x:Name="ExpanderOffice" Header="OFFICE 업무" Tag="&#xE8F1;" Style="{StaticResource SidebarExpanderStyle}" Expanded="ExpanderOffice_Expanded">
                            <StackPanel>
                                <Button x:Name="BtnNavQuotation" Content="업체 견적서" Style="{StaticResource ErpSubButtonStyle}" Click="OpenQuotation_Click"/>
                                <Button x:Name="BtnNavWeeklyReport" Content="주간보고" Style="{StaticResource ErpSubButtonStyle}" Click="OpenWeeklyReport_Click"/>
                                <Button x:Name="BtnNavEduDashboard" Content="교육 현황 대시보드" Style="{StaticResource ErpSubButtonStyle}" Click="OpenEduDashboard_Click" Visibility="Collapsed"/>
                                <Button x:Name="BtnNavWorkAssignment" Content="개인별 업무 분장표" Style="{StaticResource ErpSubButtonStyle}" Click="OpenWorkAssignment_Click" Visibility="Collapsed"/>
                            </StackPanel>
                        </Expander>

                        <!-- 섹션: TOOLS (기타) -->
                        <TextBlock x:Name="SectionHeaderTools" Text="TOOLS" Style="{StaticResource SectionHeaderStyle}"/>

                        <Expander x:Name="ExpanderEtc" Header="기타" Tag="&#xE713;" Style="{StaticResource SidebarExpanderStyle}" Expanded="ExpanderEtc_Expanded">
                            <StackPanel>
                                <Button x:Name="BtnNavReport" Content="성적서 자동 변환" Style="{StaticResource ErpSubButtonStyle}" Click="OpenReport_Click"/>
                                <Button x:Name="BtnNavDispatchCert" Content="반출등록 성적서 생성" Style="{StaticResource ErpSubButtonStyle}" Click="OpenDispatchCert_Click"/>
                            </StackPanel>
                        </Expander>

                        <!-- 관리자 전용 섹션 -->
                        <TextBlock x:Name="SectionHeaderAdmin" Text="ADMIN" Style="{StaticResource SectionHeaderStyle}" Visibility="Collapsed"/>
                        <Expander x:Name="ExpanderAdmin" Header="관리자 영역" Tag="&#xE72E;" Style="{StaticResource SidebarExpanderStyle}" Expanded="ExpanderAdmin_Expanded" Visibility="Collapsed">
                            <StackPanel>
                                <Button x:Name="BtnNavUserManagement" Content="사용자 계정 관리" Style="{StaticResource ErpSubButtonStyle}" Click="OpenUserManagement_Click"/>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>

                <!-- 🎨 하단 프로필 카드 (그라데이션 아바타 + 링) -->
                <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="12,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="BtnProfileCard" Grid.Column="0" Cursor="Arrow" Background="Transparent" BorderThickness="0" HorizontalAlignment="Stretch" Padding="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- 🎨 그라데이션 아바타 + 외곽 링 -->
                                <Grid Grid.Column="0" Width="38" Height="38" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Ellipse x:Name="AvatarRing" Width="38" Height="38" StrokeThickness="2" Stroke="#DBEAFE"/>
                                    <Border x:Name="AvatarBg" Width="32" Height="32" CornerRadius="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#3B82F6" Offset="0"/>
                                                <GradientStop Color="#2563EB" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <TextBlock x:Name="AvatarText" Text="-" FontSize="13" FontWeight="ExtraBold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,1"/>
                                    </Border>
                                </Grid>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="2,0,0,0">
                                    <TextBlock x:Name="LoginUserNameText" Text="이름" FontSize="13" FontWeight="Bold" Foreground="#0F172A"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                        <Ellipse x:Name="StatusDot" Width="6" Height="6" Fill="#10B981" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="LoginUserRoleText" Text="소속 정보" FontSize="11" Foreground="#64748B" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Width="30" Height="30" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnOpenAccountEdit_Click" ToolTip="내 계정 정보 수정" Margin="0,0,2,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="gearBorder" Background="Transparent" CornerRadius="6">
                                            <TextBlock Text="&#xE713;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI Symbol" FontSize="14" Foreground="#94A3B8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="gearBorder" Property="Background" Value="#F1F5F9"/>
                                                <Setter Property="Foreground" Value="#0F172A"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Button Width="30" Height="30" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnLogout_Click" ToolTip="로그아웃 (다른 계정으로 로그인)">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="logoutBorder" Background="Transparent" CornerRadius="6">
                                            <TextBlock Text="&#xE7E8;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI Symbol" FontSize="14" Foreground="#EF4444" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-1,0,0"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="logoutBorder" Property="Background" Value="#FEF2F2"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="88"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="24,0,0,0">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="CurrentSectionTitleText" Text="대시보드" FontSize="24" FontWeight="ExtraBold" Foreground="#0F172A"/>
                            <TextBlock x:Name="CurrentSectionDescriptionText" Text="설명" FontSize="14" Foreground="#64748B"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,16,0">
                        <Border x:Name="HeaderSearchBoxArea" Background="#F1F5F9" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Height="40" Padding="12,0" Width="300" Margin="0,0,16,0" Visibility="Collapsed">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="&#xE721;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI Symbol" FontSize="15" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox x:Name="HeaderSearchBox" Grid.Column="1" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" FontSize="14" Foreground="#0F172A" TextChanged="HeaderSearchBox_TextChanged"/>
                                <TextBlock Grid.Column="1" Text="파일, 폴더, 웹 링크 검색..." Foreground="#94A3B8" FontSize="14" VerticalAlignment="Center" IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=HeaderSearchBox}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>

                        <StackPanel x:Name="HeaderCalendarControlArea" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0" Visibility="Collapsed">
                            <Button Width="36" Height="36" Style="{StaticResource HeaderButtonStyle}" Padding="0" Click="HeaderPrevMonth_Click">
                                <Path Data="M8,0 L0,6 L8,12 Z" Fill="#334155" Width="8" Height="12" Stretch="Fill" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Button>
                            <TextBlock x:Name="HeaderMonthYearText" Text="2026년 4월" FontSize="22" FontWeight="ExtraBold" Foreground="#0F172A" VerticalAlignment="Center" Margin="16,0"/>
                            <Button Width="36" Height="36" Style="{StaticResource HeaderButtonStyle}" Padding="0" Click="HeaderNextMonth_Click">
                                <Path Data="M0,0 L8,6 L0,12 Z" Fill="#334155" Width="8" Height="12" Stretch="Fill" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Button>
                            <Button Content="오늘" Style="{StaticResource HeaderButtonStyle}" Click="HeaderToday_Click"/>
                            <Button Content="⚙️ 패턴 생성" Style="{StaticResource HeaderButtonStyle}" Background="#10B981" Foreground="White" BorderThickness="0" Click="HeaderCreatePattern_Click"/>
                            <Button Content="+ 일정 등록" Style="{StaticResource HeaderButtonStyle}" Background="#2563EB" Foreground="White" BorderThickness="0" Click="HeaderRegisterSchedule_Click"/>
                        </StackPanel>

                        <Button x:Name="BtnCommandNotice" Content="공지 관리" Style="{StaticResource HeaderButtonStyle}" Visibility="Collapsed"/>
                        <Button x:Name="BtnCommandSecondary" Content="완료 목록" Style="{StaticResource HeaderButtonStyle}" Visibility="Collapsed"/>
                        <Button x:Name="BtnCommandVendor" Content="업체 관리" Style="{StaticResource HeaderButtonStyle}" Visibility="Collapsed"/>
                        <Button x:Name="BtnCommandRecipeManage" Content="레시피 관리" Style="{StaticResource HeaderButtonStyle}" Visibility="Collapsed" Click="BtnCommandRecipeManage_Click"/>
                        <Button x:Name="BtnCommandCapture" Content="화면 캡처" Style="{StaticResource HeaderButtonStyle}" Visibility="Collapsed" Click="BtnCommandCapture_Click"/>
                        <Button x:Name="BtnCommandUndo" Content="되돌리기" Style="{StaticResource HeaderButtonStyle}" Visibility="Collapsed" Click="BtnCommandUndo_Click"/>
                        <Button x:Name="BtnCommandPartialReset" Content="부분 초기화" Style="{StaticResource HeaderButtonStyle}" Visibility="Collapsed" Click="BtnCommandPartialReset_Click"/>
                        <Button x:Name="BtnCommandReset" Content="전체 초기화" Style="{StaticResource HeaderButtonStyle}" Visibility="Collapsed" Foreground="#DC2626" Click="BtnCommandReset_Click"/>
                        <Button x:Name="BtnCommandNewReq" Content="+ 새 요청 등록" Style="{StaticResource HeaderButtonStyle}" Background="#2563EB" Foreground="White" BorderThickness="0" Visibility="Collapsed" Click="BtnCommandNewReq_Click"/>
                        <Button x:Name="BtnCommandPrimary" Content="파일 관리자" Style="{StaticResource HeaderButtonStyle}" Background="#111827" Foreground="White" BorderThickness="0" Visibility="Visible" Click="ManagePortalLinks_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <ContentControl x:Name="MainContent" Grid.Row="1" Margin="12"/>

            <Border x:Name="ToastNotification" Grid.Row="1" Background="#1E293B" CornerRadius="12" Padding="20,16" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,24,24" Visibility="Collapsed" Panel.ZIndex="999">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.25" BlurRadius="15" ShadowDepth="5"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <Border Background="#2563EB" Width="40" Height="40" CornerRadius="20" Margin="0,0,16,0">
                        <TextBlock Text="🔔" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center" Margin="0,0,24,0">
                        <TextBlock Text="새로운 요청 등록 알림" FontWeight="ExtraBold" Foreground="White" FontSize="15" Margin="0,0,0,4"/>
                        <TextBlock x:Name="ToastMessage" Text="내용" Foreground="#94A3B8" FontSize="13"/>
                    </StackPanel>
                    <Button Content="✕" Background="Transparent" Foreground="#64748B" FontWeight="Bold" BorderThickness="0" FontSize="16" Cursor="Hand" Click="CloseToast_Click" VerticalAlignment="Top" Margin="0,-4,-8,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>