<Window x:Class="CleanPotal.FieldInspectionSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="현장 점검 - 서버 설정" Height="280" Width="460"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#F8FAFC">

    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="GhostButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="현장 점검 서버 설정" FontSize="18" FontWeight="Bold" Foreground="#1E293B"/>
            <TextBlock Text="NFC/QR 코드가 가리킬 사내 모바일 웹 서버의 주소를 입력합니다." FontSize="12" Foreground="#64748B" Margin="0,4,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <StackPanel Grid.Row="1">
            <TextBlock Text="서버 주소 (BaseUrl)" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6"/>
            <Border Background="White" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="6" Height="38" Margin="0,0,0,10">
                <TextBox x:Name="TxtBaseUrl" BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center" Padding="10,0"/>
            </Border>
            <TextBlock Text="예) http://10.10.40.98:5000  /  https://field.local" FontSize="11" Foreground="#94A3B8"/>
            <TextBlock x:Name="TokenInfoText" FontSize="11" Foreground="#94A3B8" Margin="0,12,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="취소" Style="{StaticResource GhostButton}" Width="90" Margin="0,0,8,0" Click="BtnCancel_Click"/>
            <Button Content="저장" Style="{StaticResource PrimaryButton}" Width="100" Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>
