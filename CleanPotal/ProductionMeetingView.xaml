<UserControl x:Class="CleanPotal.ProductionMeetingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FFFFFF" SnapsToDevicePixels="True" UseLayoutRounding="True">

    <UserControl.Resources>
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="10"/>
            <Setter Property="Margin" Value="2,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#CBD5E1" CornerRadius="4" Margin="2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MonthExpanderStyle" TargetType="Expander">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <StackPanel>
                            <ToggleButton x:Name="HeaderSite" IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}" Cursor="Hand" Padding="12,8">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="Arrow" Text="▶" FontSize="10" VerticalAlignment="Center" Foreground="#94A3B8" Margin="0,0,8,0"/>
                                                <ContentPresenter ContentSource="Content" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Arrow" Property="Text" Value="▼"/>
                                                <Setter TargetName="Arrow" Property="Foreground" Value="#475569"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <ContentPresenter Content="{TemplateBinding Header}"/>
                            </ToggleButton>
                            <Border x:Name="ExpandSite" Visibility="Collapsed" Margin="0,0,0,0">
                                <ContentPresenter />
                            </Border>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 🎨 카드(내용/팔로업)용 RichTextBox 공통 스타일 -->
        <Style x:Key="CardRichTextBoxStyle" TargetType="RichTextBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="AcceptsTab" Value="True"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="SpellCheck.IsEnabled" Value="False"/>
            <Setter Property="MinHeight" Value="38"/>
        </Style>

        <!-- 🎨 RichTextBox 단락 간격 (모든 RichTextBox에 적용 - 노션 느낌) -->
        <Style TargetType="Paragraph">
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>
    </UserControl.Resources>

    <!-- 외부 레이아웃: 스크롤 영역 + 줌 컨트롤 바 -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
        <Grid x:Name="ScalableGrid">
        <Grid.LayoutTransform>
            <ScaleTransform x:Name="MainScaleTransform" ScaleX="1" ScaleY="1"/>
        </Grid.LayoutTransform>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="340"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="0,0,1,0">
            <Grid Margin="0,20,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="14,8,14,8">
                    <Button x:Name="BtnCreateNewReport" Content="+ 새 보고서 생성" Margin="0,0,0,0" Height="36" Background="#2563EB" Foreground="White" FontWeight="SemiBold" FontSize="12" BorderThickness="0" Cursor="Hand" Click="BtnCreateNewReport_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>

                <!-- 검색 박스 -->
                <Border Grid.Row="1" Margin="14,0,14,8" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8">
                    <Grid>
                        <TextBlock Text="🔍" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="#94A3B8"/>
                        <TextBox x:Name="TxtSearch" Background="Transparent" BorderThickness="0" Padding="26,7,8,7"
                                 FontSize="12" Foreground="#334155"
                                 TextChanged="TxtSearch_TextChanged">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TextBox">
                                                <Grid>
                                                    <TextBlock x:Name="Placeholder" Text="보고서 검색..." FontSize="12" Foreground="#94A3B8" Margin="26,7,8,7" VerticalAlignment="Center" IsHitTestVisible="False">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                                                </Grid>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="GroupedHistoryControl" Margin="8,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Expander Header="{Binding MonthTitle}" IsExpanded="True" Style="{StaticResource MonthExpanderStyle}">
                                    <Expander.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" FontSize="13" FontWeight="Bold" Foreground="#475569"/>
                                        </DataTemplate>
                                    </Expander.HeaderTemplate>
                                    <ListBox ItemsSource="{Binding Reports}" Background="Transparent" BorderThickness="0" SelectionChanged="HistoryListBox_SelectionChanged" Margin="8,8,0,0">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Padding" Value="10,8"/>
                                                <Setter Property="Margin" Value="0,0,0,3"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Grid>
                                                                <Border x:Name="Bd" Background="Transparent" CornerRadius="8">
                                                                    <ContentPresenter Margin="4,0,0,0"/>
                                                                </Border>
                                                                <Border x:Name="Indicator" Width="3" Height="16" Background="#2563EB" CornerRadius="1.5" HorizontalAlignment="Left" Visibility="Collapsed"/>
                                                            </Grid>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="#E2E8F0"/>
                                                                </Trigger>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="#DBEAFE"/>
                                                                    <Setter Property="Foreground" Value="#1D4ED8"/>
                                                                    <Setter TargetName="Indicator" Property="Visibility" Value="Visible"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding ShortTitle}" FontWeight="Bold" FontSize="13"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Expander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="32,24,32,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="TxtCurrentReportTitle" Text="보고서를 선택하세요" FontSize="26" FontWeight="ExtraBold" Foreground="#0F172A"/>
                    <TextBlock x:Name="TxtCurrentReportDate" Text="작성 기간이 표시됩니다." FontSize="13" Foreground="#64748B" Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                    <Button x:Name="BtnDeleteReport" Content="보고서 삭제" Height="32" Padding="12,0" Margin="0,0,10,0" Background="#FEE2E2" Foreground="#B91C1C" BorderBrush="#FCA5A5" BorderThickness="1" FontWeight="Bold" Cursor="Hand" Click="BtnDeleteReport_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button x:Name="BtnClearSelection" Content="초기화" Height="32" Padding="10,0" Background="#F1F5F9" Foreground="#475569" BorderBrush="#CBD5E1" BorderThickness="1" FontWeight="Bold" Cursor="Hand" Click="BtnClearSelection_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>

            <Border Grid.Row="1" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10">
                <RichTextBox x:Name="MainContentRichEditor" Tag="Main"
                             BorderThickness="0" Background="Transparent"
                             Padding="20,16" FontSize="14" Foreground="#1E293B"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                             AcceptsTab="True" AllowDrop="True"
                             GotKeyboardFocus="AnyRichTextBox_GotFocus"
                             LostKeyboardFocus="AnyRichTextBox_LostFocus"
                             PreviewKeyDown="CardRichTextBox_PreviewKeyDown"
                             PreviewDragOver="AnyRichTextBox_PreviewDragOver"
                             Drop="AnyRichTextBox_Drop"
                             TextChanged="MainContentRichEditor_TextChanged"
                             SpellCheck.IsEnabled="False">
                    <RichTextBox.Resources>
                        <Style TargetType="Paragraph">
                            <Setter Property="Margin" Value="0,0,0,4"/>
                        </Style>
                    </RichTextBox.Resources>
                </RichTextBox>
            </Border>

            <!-- 🔥 중앙 본문 별도 첨부 영역 (Main RichTextBox 아래) -->
            <Border Grid.Row="2" Height="100" Margin="0,12,0,0" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10" Padding="10" AllowDrop="True" PreviewDragOver="MainAttachmentPanel_PreviewDragOver" Drop="MainAttachmentPanel_Drop" PreviewKeyDown="MainAttachmentPanel_PreviewKeyDown" Focusable="True">
                <StackPanel>
                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="별도 첨부 (이미지/파일)" FontSize="11" FontWeight="Bold" Foreground="#64748B" VerticalAlignment="Center"/>
                        <Button Content="+" Height="20" Width="20" HorizontalAlignment="Right" Background="#E2E8F0" Foreground="#334155" BorderThickness="0" Cursor="Hand" FontWeight="Bold" Click="BtnAddMainAttachment_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="10"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </Grid>
                    <ScrollViewer VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Auto" Height="52">
                        <ItemsControl x:Name="MainAttachmentsControl" ItemsSource="{Binding MainAttachments}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Width="48" Height="48" Margin="0,0,8,0"
                                          AllowDrop="True"
                                          MouseLeftButtonDown="MainAttachmentItem_MouseDown"
                                          MouseMove="MainAttachmentItem_MouseMove"
                                          DragOver="MainAttachmentItem_DragOver"
                                          Drop="MainAttachmentItem_Drop">
                                        <Border Cursor="Hand" CornerRadius="8" BorderBrush="#CBD5E1" BorderThickness="1" MouseLeftButtonUp="AttachmentPreview_Click" Background="#E2E8F0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#E2E8F0"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsImage}" Value="True">
                                                            <Setter Property="Background">
                                                                <Setter.Value>
                                                                    <ImageBrush ImageSource="{Binding FilePath}" Stretch="UniformToFill"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding FileName}" Foreground="#334155" FontSize="8" TextWrapping="Wrap" TextAlignment="Center" VerticalAlignment="Center" Margin="3">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsImage}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                        <Button Content="✕" Width="14" Height="14" Background="#EF4444" Foreground="White" BorderThickness="0" FontSize="9" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-4,-4,0" Cursor="Hand" Tag="{Binding}" Click="BtnRemoveMainAttachment_Click">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="7"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Column="2" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1,0,0,0">
            <Grid x:Name="MemoArea" Margin="20,28,20,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 제목 -->
                <TextBlock Grid.Row="0" Text="추가 메모" FontSize="18" FontWeight="ExtraBold" Foreground="#0F172A" Margin="0,0,0,12" HorizontalAlignment="Center"/>

                <!-- 🎨 RichTextBox 본문 -->
                <Border Grid.Row="1" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10">
                    <RichTextBox x:Name="MemoRichEditor" Tag="Memo"
                                 BorderThickness="0" Background="Transparent"
                                 Padding="16,12" FontSize="14" Foreground="#1E293B"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                 AcceptsTab="True" AllowDrop="True"
                                 GotKeyboardFocus="AnyRichTextBox_GotFocus"
                                 LostKeyboardFocus="AnyRichTextBox_LostFocus"
                                 PreviewKeyDown="CardRichTextBox_PreviewKeyDown"
                                 PreviewDragOver="AnyRichTextBox_PreviewDragOver"
                                 Drop="AnyRichTextBox_Drop"
                                 TextChanged="MemoRichEditor_TextChanged"
                                 SpellCheck.IsEnabled="False">
                        <RichTextBox.Resources>
                            <Style TargetType="Paragraph">
                                <Setter Property="Margin" Value="0,0,0,4"/>
                            </Style>
                        </RichTextBox.Resources>
                    </RichTextBox>
                </Border>

                <!-- 첨부 영역 -->
                <Border Grid.Row="2" Height="100" Margin="0,10,0,0" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10" Padding="10" AllowDrop="True" PreviewDragOver="MemoAttachmentPanel_PreviewDragOver" Drop="MemoAttachmentPanel_Drop" PreviewKeyDown="MemoAttachmentPanel_PreviewKeyDown" Focusable="True">
                    <StackPanel>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="별도 첨부 (이미지/파일)" FontSize="11" FontWeight="Bold" Foreground="#64748B" VerticalAlignment="Center"/>
                            <Button Content="+" Height="20" Width="20" HorizontalAlignment="Right" Background="#E2E8F0" Foreground="#334155" BorderThickness="0" Cursor="Hand" FontWeight="Bold" Click="BtnAddMemoAttachment_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="10"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </Grid>
                        <ScrollViewer VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Auto" Height="52">
                            <ItemsControl x:Name="MemoAttachmentsControl" ItemsSource="{Binding MemoAttachments}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Width="48" Height="48" Margin="0,0,8,0"
                                              AllowDrop="True"
                                              MouseLeftButtonDown="MemoAttachmentItem_MouseDown"
                                              MouseMove="MemoAttachmentItem_MouseMove"
                                              DragOver="MemoAttachmentItem_DragOver"
                                              Drop="MemoAttachmentItem_Drop">
                                            <Border Cursor="Hand" CornerRadius="8" BorderBrush="#CBD5E1" BorderThickness="1" MouseLeftButtonUp="AttachmentPreview_Click" Background="#E2E8F0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#E2E8F0"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsImage}" Value="True">
                                                                <Setter Property="Background">
                                                                    <Setter.Value>
                                                                        <ImageBrush ImageSource="{Binding FilePath}" Stretch="UniformToFill"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding FileName}" Foreground="#334155" FontSize="8" TextWrapping="Wrap" TextAlignment="Center" VerticalAlignment="Center" Margin="3">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsImage}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                            <Button Content="✕" Width="14" Height="14" Background="#EF4444" Foreground="White" BorderThickness="0" FontSize="9" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-4,-4,0" Cursor="Hand" Tag="{Binding}" Click="BtnRemoveMemoAttachment_Click">
                                                <Button.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="7"/>
                                                    </Style>
                                                </Button.Resources>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border x:Name="CreateReportModal" Grid.ColumnSpan="3" Background="#80000000" Visibility="Collapsed" Panel.ZIndex="200">
            <Border Background="White" Width="350" VerticalAlignment="Center" HorizontalAlignment="Center" CornerRadius="16" Padding="30">
                <StackPanel>
                    <TextBlock Text="새 보고서 생성" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,25"/>

                    <TextBlock Text="작성 날짜 선택" FontSize="13" Foreground="#64748B" Margin="0,0,0,10"/>
                    <DatePicker x:Name="DpMeetingDate" Height="40" SelectedDateFormat="Long" HorizontalContentAlignment="Center"/>

                    <TextBlock x:Name="TxtAutoDatePreview" Text="선택 날짜: -" FontSize="12" Foreground="#2563EB" HorizontalAlignment="Center" Margin="0,12,0,30"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Content="취소" Grid.Column="0" Height="45" Margin="0,0,5,0" Background="#F1F5F9" Foreground="#475569" BorderThickness="0" FontWeight="Bold" Click="BtnCancelCreate_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="10"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <Button Content="생성하기" Grid.Column="1" Height="45" Margin="5,0,0,0" Background="#2563EB" Foreground="White" BorderThickness="0" FontWeight="Bold" Click="BtnConfirmCreate_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="10"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
        </Border>

        <!-- 🎨 공유 플로팅 툴바 - 어떤 RichTextBox든 포커스 받으면 자동 표시 -->
        <Border x:Name="SharedToolbar" 
                Grid.ColumnSpan="3"
                HorizontalAlignment="Center" VerticalAlignment="Top" 
                Margin="0,8,0,0"
                Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" 
                CornerRadius="10" Padding="8,5"
                Visibility="Collapsed"
                Panel.ZIndex="999">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.12" BlurRadius="14" ShadowDepth="2"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <StackPanel.Resources>
                    <Style x:Key="ToolBtn" TargetType="Button">
                        <Setter Property="Width" Value="30"/>
                        <Setter Property="Height" Value="28"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Margin" Value="1,0"/>
                        <Setter Property="Foreground" Value="#475569"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="5">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#F1F5F9"/>
                                            <Setter Property="Foreground" Value="#0F172A"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                    <Style x:Key="ToolSep" TargetType="Border">
                        <Setter Property="Width" Value="1"/>
                        <Setter Property="Background" Value="#E2E8F0"/>
                        <Setter Property="Margin" Value="4,5"/>
                    </Style>
                </StackPanel.Resources>

                <ComboBox x:Name="ToolbarFontSize" Width="56" Height="26" VerticalContentAlignment="Center" FontSize="12" SelectionChanged="ToolbarFontSize_SelectionChanged" ToolTip="글자 크기">
                    <ComboBoxItem Content="11"/>
                    <ComboBoxItem Content="13"/>
                    <ComboBoxItem Content="14" IsSelected="True"/>
                    <ComboBoxItem Content="16"/>
                    <ComboBoxItem Content="18"/>
                    <ComboBoxItem Content="22"/>
                    <ComboBoxItem Content="28"/>
                </ComboBox>

                <Border Style="{StaticResource ToolSep}"/>

                <Button Style="{StaticResource ToolBtn}" Click="ToolbarBold_Click" ToolTip="굵게 (Ctrl+B)">
                    <TextBlock Text="B" FontWeight="Bold" FontSize="14"/>
                </Button>
                <Button Style="{StaticResource ToolBtn}" Click="ToolbarItalic_Click" ToolTip="기울임 (Ctrl+I)">
                    <TextBlock Text="I" FontStyle="Italic" FontSize="14" FontWeight="SemiBold"/>
                </Button>
                <Button Style="{StaticResource ToolBtn}" Click="ToolbarUnderline_Click" ToolTip="밑줄 (Ctrl+U)">
                    <TextBlock Text="U" FontWeight="SemiBold" FontSize="14" TextDecorations="Underline"/>
                </Button>

                <Border Style="{StaticResource ToolSep}"/>

                <Button Style="{StaticResource ToolBtn}" Click="ToolbarColor_Click" Tag="#0F172A" ToolTip="검정">
                    <Ellipse Width="14" Height="14" Fill="#0F172A"/>
                </Button>
                <Button Style="{StaticResource ToolBtn}" Click="ToolbarColor_Click" Tag="#DC2626" ToolTip="빨강">
                    <Ellipse Width="14" Height="14" Fill="#DC2626"/>
                </Button>
                <Button Style="{StaticResource ToolBtn}" Click="ToolbarColor_Click" Tag="#2563EB" ToolTip="파랑">
                    <Ellipse Width="14" Height="14" Fill="#2563EB"/>
                </Button>
                <Button Style="{StaticResource ToolBtn}" Click="ToolbarColor_Click" Tag="#16A34A" ToolTip="초록">
                    <Ellipse Width="14" Height="14" Fill="#16A34A"/>
                </Button>
                <Button Style="{StaticResource ToolBtn}" Click="ToolbarHighlight_Click" Tag="#FEF3C7" ToolTip="노란 형광펜">
                    <Border Width="14" Height="14" Background="#FEF3C7" BorderBrush="#D97706" BorderThickness="1" CornerRadius="2"/>
                </Button>

                <Border Style="{StaticResource ToolSep}"/>

                <Button Style="{StaticResource ToolBtn}" Click="ToolbarBullet_Click" ToolTip="글머리표">
                    <TextBlock Text="•—" FontSize="13" FontWeight="Bold"/>
                </Button>
                <Button Style="{StaticResource ToolBtn}" Click="ToolbarNumbering_Click" ToolTip="번호 매기기">
                    <TextBlock Text="1." FontSize="12" FontWeight="Bold"/>
                </Button>
                <Button Style="{StaticResource ToolBtn}" Click="ToolbarCheckbox_Click" ToolTip="체크박스 (Ctrl+Shift+L)">
                    <TextBlock Text="☐" FontSize="14"/>
                </Button>

                <Border Style="{StaticResource ToolSep}"/>

                <Button Style="{StaticResource ToolBtn}" Click="ToolbarInsertImage_Click" ToolTip="이미지 삽입">
                    <TextBlock Text="🖼" FontSize="13"/>
                </Button>
                <Button Style="{StaticResource ToolBtn}" Click="ToolbarInsertFile_Click" ToolTip="파일 첨부 (본문 인라인)">
                    <TextBlock Text="📎" FontSize="13"/>
                </Button>
            </StackPanel>
        </Border>
        </Grid>
        </ScrollViewer>

        <!-- 줌 컨트롤 바 -->
        <Border Grid.Row="1" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Height="36">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="16,0">
                <Button Content="−" Width="26" Height="26" Click="ZoomOut_Click" FontSize="14" FontWeight="Bold"
                        Background="#E2E8F0" Foreground="#334155" BorderThickness="0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <TextBlock x:Name="TxtZoomLevel" Text="100%" FontSize="12" FontWeight="SemiBold" Foreground="#475569"
                           VerticalAlignment="Center" Margin="10,0" MinWidth="36" TextAlignment="Center"/>
                <Button Content="+" Width="26" Height="26" Click="ZoomIn_Click" FontSize="14" FontWeight="Bold"
                        Background="#E2E8F0" Foreground="#334155" BorderThickness="0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>