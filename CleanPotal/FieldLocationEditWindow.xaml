<Window x:Class="CleanPotal.FieldLocationEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="위치 등록 / 수정" Height="540" Width="440"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#F8FAFC">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="FieldBox" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="GhostButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock x:Name="HeaderText" Text="새 위치 등록" FontSize="20" FontWeight="Bold" Foreground="#1E293B"/>
            <TextBlock Text="현장 점검 대상 위치/구역/설비를 등록합니다." FontSize="12" Foreground="#64748B" Margin="0,4,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1">
            <TextBlock Text="위치 코드 (필수, 고유)" Style="{StaticResource FieldLabel}"/>
            <Border Style="{StaticResource FieldBox}">
                <TextBox x:Name="TxtCode" BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center" Padding="10,0"/>
            </Border>

            <TextBlock Text="위치명 (필수)" Style="{StaticResource FieldLabel}"/>
            <Border Style="{StaticResource FieldBox}">
                <TextBox x:Name="TxtName" BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center" Padding="10,0"/>
            </Border>

            <TextBlock Text="구역명" Style="{StaticResource FieldLabel}"/>
            <Border Style="{StaticResource FieldBox}">
                <TextBox x:Name="TxtZone" BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center" Padding="10,0"/>
            </Border>

            <TextBlock Text="설비명" Style="{StaticResource FieldLabel}"/>
            <Border Style="{StaticResource FieldBox}">
                <TextBox x:Name="TxtEquipment" BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center" Padding="10,0"/>
            </Border>

            <TextBlock Text="비고" Style="{StaticResource FieldLabel}"/>
            <Border Style="{StaticResource FieldBox}" Height="60">
                <TextBox x:Name="TxtMemo" BorderThickness="0" Background="Transparent" VerticalContentAlignment="Top" Padding="10,8" TextWrapping="Wrap" AcceptsReturn="True"/>
            </Border>

            <CheckBox x:Name="ChkActive" Content="활성 (현장에서 사용)" IsChecked="True" Margin="0,4,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="취소" Style="{StaticResource GhostButton}" Width="90" Margin="0,0,8,0" Click="BtnCancel_Click"/>
            <Button Content="저장" Style="{StaticResource PrimaryButton}" Width="100" Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>
