<UserControl x:Class="CleanPotal.WorkAssignmentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F8FAFC">

    <UserControl.Resources>
        <!-- 카드 섹션 헤더 텍스트 -->
        <Style x:Key="CardHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#0F172A"/>
        </Style>

        <!-- 라벨 텍스트 -->
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- 읽기전용 값 텍스트 -->
        <Style x:Key="FieldValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <!-- 소형 버튼 (그리드 행 추가/삭제) -->
        <Style x:Key="SmallBtnStyle" TargetType="Button">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 멤버 리스트 아이템 -->
        <Style x:Key="MemberItemStyle" TargetType="ListBoxItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="8" Padding="12,8" Margin="0,1,0,1" Cursor="Hand">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- 아바타 -->
                                <Border Grid.Column="0" Width="28" Height="28" CornerRadius="14">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#3B82F6" Offset="0"/>
                                            <GradientStop Color="#2563EB" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock x:Name="AvatarChar" Text="{Binding InitialChar}"
                                               FontSize="11" FontWeight="Bold" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="6,0,0,0">
                                    <TextBlock x:Name="NameText" Text="{Binding RealName}" FontSize="13" FontWeight="SemiBold" Foreground="#0F172A"/>
                                    <TextBlock Text="{Binding TeamName}" FontSize="11" Foreground="#94A3B8"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#DBEAFE"/>
                                <Setter TargetName="NameText" Property="Foreground" Value="#1D4ED8"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="bd" Property="Background" Value="#F1F5F9"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid 공통 -->
        <Style x:Key="AssignGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ─── 왼쪽: 멤버 목록 패널 ─── -->
        <Border Grid.Column="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 헤더 -->
                <Border Grid.Row="0" Padding="16,14,16,10" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="인원 목록" FontSize="13" FontWeight="Bold" Foreground="#0F172A"/>
                        <TextBlock x:Name="TxtMemberCount" Text="0명" FontSize="11" Foreground="#94A3B8" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 멤버 리스트 -->
                <ListBox x:Name="MemberList" Grid.Row="1"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         SelectionMode="Multiple"
                         SelectionChanged="MemberList_SelectionChanged"
                         ItemContainerStyle="{StaticResource MemberItemStyle}"
                         Padding="8,6">
                </ListBox>

                <!-- 추가/삭제 버튼 -->
                <Border Grid.Row="2" Padding="10,8" BorderBrush="#F1F5F9" BorderThickness="0,1,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="+ 인원 추가" Click="BtnAddMember_Click"
                                Style="{StaticResource SmallBtnStyle}"
                                Background="#2563EB" Foreground="White" Margin="0,0,6,0"/>
                        <Button Content="삭제" Click="BtnRemoveMember_Click"
                                Style="{StaticResource SmallBtnStyle}"
                                Background="#FEE2E2" Foreground="#DC2626"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ─── 오른쪽: 상세 패널 ─── -->
        <Grid Grid.Column="1">
            <!-- 선택 안 된 상태 / 다중 선택 안내 -->
            <StackPanel x:Name="PanelEmpty" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="👤" FontSize="40" HorizontalAlignment="Center"/>
                <TextBlock x:Name="SingleSelectHint" Text="인원을 선택하면 업무 분장표가 표시됩니다."
                           FontSize="14" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                <Border x:Name="MultiSelectHint" Background="#FEF3C7" CornerRadius="8" Padding="16,10"
                        Margin="0,12,0,0" Visibility="Collapsed">
                    <TextBlock x:Name="MultiSelectCountText" FontSize="13" Foreground="#92400E"
                               HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="300"/>
                </Border>
            </StackPanel>

            <!-- 상세 내용 -->
            <ScrollViewer x:Name="PanelDetail" Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                          Padding="28,20,28,28">
                <StackPanel>

                    <!-- ── 기본 정보 카드 ── -->
                    <Border Background="White" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1" Padding="20,16" Margin="0,0,0,16">
                        <Border.Effect>
                            <DropShadowEffect Color="#000" Opacity="0.04" BlurRadius="10" ShadowDepth="0"/>
                        </Border.Effect>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Border Width="4" Height="16" CornerRadius="2" Background="#2563EB" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="기본 정보" Style="{StaticResource CardHeaderStyle}"/>
                            </StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Row 0 -->
                                <StackPanel Grid.Column="0" Margin="0,0,16,12">
                                    <TextBlock Text="이름" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBlock x:Name="InfoRealName" Style="{StaticResource FieldValueStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="0,0,16,12">
                                    <TextBlock Text="아이디" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBlock x:Name="InfoUsername" Style="{StaticResource FieldValueStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="0,0,16,12">
                                    <TextBlock Text="사번" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBlock x:Name="InfoEmployeeNumber" Style="{StaticResource FieldValueStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="3" Margin="0,0,16,12">
                                    <TextBlock Text="소속팀" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBlock x:Name="InfoTeam" Style="{StaticResource FieldValueStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="4" Margin="0,0,0,12">
                                    <TextBlock Text="직위" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBlock x:Name="InfoJobTitle" Style="{StaticResource FieldValueStyle}"/>
                                </StackPanel>

                                <!-- Row 1 -->
                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,16,0">
                                    <TextBlock Text="입사일" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBlock x:Name="InfoHireDate" Style="{StaticResource FieldValueStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,16,0">
                                    <TextBlock Text="경력" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBlock x:Name="InfoCareer" Style="{StaticResource FieldValueStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,16,0">
                                    <TextBlock Text="이메일" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBlock x:Name="InfoEmail" Style="{StaticResource FieldValueStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="3" Margin="0,0,16,0">
                                    <TextBlock Text="전화번호" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBlock x:Name="InfoPhone" Style="{StaticResource FieldValueStyle}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ── 기본 교육 기록 카드 ── -->
                    <Border Background="White" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1" Padding="20,16" Margin="0,0,0,16">
                        <Border.Effect>
                            <DropShadowEffect Color="#000" Opacity="0.04" BlurRadius="10" ShadowDepth="0"/>
                        </Border.Effect>
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="4" Height="16" CornerRadius="2" Background="#10B981" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="기본 교육 기록" Style="{StaticResource CardHeaderStyle}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="+ 행 추가" Click="BtnAddEduRow_Click"
                                            Style="{StaticResource SmallBtnStyle}"
                                            Background="#F0FDF4" Foreground="#059669" Margin="0,0,6,0"/>
                                    <Button Content="저장" Click="BtnSaveEdu_Click"
                                            Style="{StaticResource SmallBtnStyle}"
                                            Background="#2563EB" Foreground="White"/>
                                </StackPanel>
                            </Grid>

                            <DataGrid x:Name="EduBasicGrid"
                                      AutoGenerateColumns="False" CanUserSortColumns="False"
                                      CanUserAddRows="False" CanUserDeleteRows="False"
                                      BorderBrush="#E2E8F0" BorderThickness="1"
                                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9"
                                      RowHeight="34" HeadersVisibility="Column"
                                      Background="White" AlternatingRowBackground="#FAFAFA"
                                      ColumnHeaderStyle="{StaticResource AssignGridHeaderStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="교육명" Binding="{Binding EduName, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                    <DataGridTextColumn Header="교육일" Binding="{Binding EduDate, UpdateSourceTrigger=PropertyChanged}" Width="110"/>
                                    <DataGridTextColumn Header="강사/기관" Binding="{Binding Instructor, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                                    <DataGridTextColumn Header="비고" Binding="{Binding Note, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                    <DataGridTemplateColumn Header="" Width="36">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="✕" FontSize="11" Background="Transparent" BorderThickness="0"
                                                        Foreground="#94A3B8" Cursor="Hand" VerticalAlignment="Center" HorizontalAlignment="Center"
                                                        Click="BtnDeleteEduRow_Click" Tag="{Binding}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                    <!-- ── 기관 계정 카드 ── -->
                    <Border Background="White" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1" Padding="20,16" Margin="0,0,0,16">
                        <Border.Effect>
                            <DropShadowEffect Color="#000" Opacity="0.04" BlurRadius="10" ShadowDepth="0"/>
                        </Border.Effect>
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="4" Height="16" CornerRadius="2" Background="#8B5CF6" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="기관 계정" Style="{StaticResource CardHeaderStyle}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="+ 행 추가" Click="BtnAddAccountRow_Click"
                                            Style="{StaticResource SmallBtnStyle}"
                                            Background="#F5F3FF" Foreground="#7C3AED" Margin="0,0,6,0"/>
                                    <Button Content="저장" Click="BtnSaveAccounts_Click"
                                            Style="{StaticResource SmallBtnStyle}"
                                            Background="#2563EB" Foreground="White"/>
                                </StackPanel>
                            </Grid>

                            <DataGrid x:Name="AccountGrid"
                                      AutoGenerateColumns="False" CanUserSortColumns="False"
                                      CanUserAddRows="False" CanUserDeleteRows="False"
                                      BorderBrush="#E2E8F0" BorderThickness="1"
                                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9"
                                      RowHeight="34" HeadersVisibility="Column"
                                      Background="White" AlternatingRowBackground="#FAFAFA"
                                      ColumnHeaderStyle="{StaticResource AssignGridHeaderStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="서비스명" Binding="{Binding ServiceName, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                    <DataGridTextColumn Header="계정 ID" Binding="{Binding AccountId, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                    <DataGridTextColumn Header="비밀번호" Binding="{Binding AccountPassword, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                    <DataGridTextColumn Header="비고" Binding="{Binding Note, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                    <DataGridTemplateColumn Header="" Width="36">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="✕" FontSize="11" Background="Transparent" BorderThickness="0"
                                                        Foreground="#94A3B8" Cursor="Hand" VerticalAlignment="Center" HorizontalAlignment="Center"
                                                        Click="BtnDeleteAccountRow_Click" Tag="{Binding}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                    <!-- ── 외부 교육 이력 카드 ── -->
                    <Border Background="White" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1" Padding="20,16" Margin="0,0,0,0">
                        <Border.Effect>
                            <DropShadowEffect Color="#000" Opacity="0.04" BlurRadius="10" ShadowDepth="0"/>
                        </Border.Effect>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="4" Height="16" CornerRadius="2" Background="#F59E0B" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="외부 교육 이력" Style="{StaticResource CardHeaderStyle}"/>
                                <TextBlock Text="(자동 연동 - 교육 현황 대시보드 기준)" FontSize="11" Foreground="#94A3B8" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>

                            <DataGrid x:Name="ExtEduGrid"
                                      AutoGenerateColumns="False" IsReadOnly="True" CanUserSortColumns="False"
                                      BorderBrush="#E2E8F0" BorderThickness="1"
                                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9"
                                      RowHeight="34" HeadersVisibility="Column"
                                      Background="White" AlternatingRowBackground="#FAFAFA"
                                      ColumnHeaderStyle="{StaticResource AssignGridHeaderStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="교육명" Binding="{Binding CourseName}" Width="*"/>
                                    <DataGridTextColumn Header="시작일" Binding="{Binding StartDate, StringFormat=yyyy-MM-dd}" Width="110"/>
                                    <DataGridTextColumn Header="종료일" Binding="{Binding EndDate, StringFormat=yyyy-MM-dd}" Width="110"/>
                                    <DataGridTextColumn Header="방법" Binding="{Binding EduMethod}" Width="100"/>
                                    <DataGridTextColumn Header="상태" Binding="{Binding Status}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
