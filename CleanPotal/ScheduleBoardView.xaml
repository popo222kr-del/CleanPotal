<UserControl x:Class="CleanPotal.ScheduleBoardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="True"
             Loaded="ScheduleBoardView_Loaded"
             IsVisibleChanged="ScheduleBoardView_IsVisibleChanged"
             PreviewKeyDown="ScheduleBoardView_PreviewKeyDown"
             PreviewKeyUp="ScheduleBoardView_PreviewKeyUp"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             Background="#F5F7FB">

    <UserControl.Resources>
        <Style x:Key="StarCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent">
                            <TextBlock x:Name="StarText" Text="☆" FontSize="20" Foreground="#CBD5E1" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,-2,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="StarText" Property="Text" Value="★"/>
                                <Setter TargetName="StarText" Property="Foreground" Value="#F59E0B"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="StarText" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RecipeItemButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="8,10"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20,0,20,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="16" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="레시피 선택" FontWeight="ExtraBold" FontSize="16" Foreground="#111827" Margin="0,0,0,16"/>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="RecipeListPanel"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <GridSplitter Grid.Column="1" Width="16" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent" ResizeDirection="Columns"/>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="16" Padding="20,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <WrapPanel Grid.Column="0" VerticalAlignment="Center">
                        <CheckBox x:Name="DayCheckBox" Content="주간 (07:00~19:00)" VerticalAlignment="Center" Margin="0,0,16,0" Checked="DayCheckBox_Checked" Unchecked="DayCheckBox_Unchecked" Foreground="#111827" FontWeight="SemiBold"/>
                        <CheckBox x:Name="NightCheckBox" Content="야간 (19:00~06:00)" VerticalAlignment="Center" Margin="0,0,16,0" Checked="NightCheckBox_Checked" Unchecked="NightCheckBox_Unchecked" Foreground="#111827" FontWeight="SemiBold"/>
                        <TextBlock x:Name="StatusTextBlock" VerticalAlignment="Center" Foreground="#4B5563" FontSize="13" MaxWidth="400" TextTrimming="CharacterEllipsis"/>
                    </WrapPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Zoom" Foreground="#4B5563" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <Slider x:Name="ZoomSlider" Width="120" Minimum="0.5" Maximum="2.0" SmallChange="0.05" LargeChange="0.1" Value="1.0" VerticalAlignment="Center" ValueChanged="ZoomSlider_ValueChanged"/>
                        <TextBlock x:Name="ZoomPercentText" Width="44" TextAlignment="Right" Foreground="#111827" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="2" x:Name="RootCaptureTarget" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="16">
                <Grid>
                    <Grid.OpacityMask>
                        <VisualBrush>
                            <VisualBrush.Visual>
                                <Border Background="Black" CornerRadius="16" Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Grid}}" Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Grid}}"/>
                            </VisualBrush.Visual>
                        </VisualBrush>
                    </Grid.OpacityMask>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Canvas x:Name="EquipmentHeaderCanvas" Grid.Row="0" Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Top" SnapsToDevicePixels="True" UseLayoutRounding="True" Background="#F8FAFC"/>

                    <ScrollViewer x:Name="EquipmentScrollViewer" Grid.Row="1" Grid.Column="0" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Hidden" ScrollChanged="EquipmentScrollViewer_ScrollChanged" PreviewMouseWheel="AnyScroll_PreviewMouseWheel" CanContentScroll="False">
                        <Canvas x:Name="EquipmentCanvas" HorizontalAlignment="Left" VerticalAlignment="Top" SnapsToDevicePixels="True" UseLayoutRounding="True"/>
                    </ScrollViewer>

                    <ScrollViewer x:Name="HeaderScrollViewer" Grid.Row="0" Grid.Column="1" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Hidden" ScrollChanged="HeaderScrollViewer_ScrollChanged" PreviewMouseWheel="AnyScroll_PreviewMouseWheel" CanContentScroll="False" Background="#F8FAFC">
                        <Canvas x:Name="TimelineHeaderCanvas" HorizontalAlignment="Left" VerticalAlignment="Top" SnapsToDevicePixels="True" UseLayoutRounding="True"/>
                    </ScrollViewer>

                    <ScrollViewer x:Name="BoardScrollViewer" Grid.Row="1" Grid.Column="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" ScrollChanged="BoardScrollViewer_ScrollChanged" PreviewMouseWheel="AnyScroll_PreviewMouseWheel" CanContentScroll="False" Focusable="True">
                        <Canvas x:Name="BoardContentCanvas" ClipToBounds="True" HorizontalAlignment="Left" VerticalAlignment="Top" SnapsToDevicePixels="True" UseLayoutRounding="True">
                            <Canvas x:Name="BoardGridCanvas" Background="#FFFFFF" HorizontalAlignment="Left" VerticalAlignment="Top" SnapsToDevicePixels="True" UseLayoutRounding="True"/>
                            <Canvas x:Name="BoardBlocksCanvas" Background="Transparent" IsHitTestVisible="False" HorizontalAlignment="Left" VerticalAlignment="Top" SnapsToDevicePixels="True" UseLayoutRounding="True"/>
                            <Canvas x:Name="BoardInputLayer" Background="Transparent" HorizontalAlignment="Left" VerticalAlignment="Top" MouseMove="BoardInputLayer_MouseMove" MouseLeave="BoardInputLayer_MouseLeave" MouseLeftButtonDown="BoardInputLayer_MouseLeftButtonDown" MouseRightButtonDown="BoardInputLayer_MouseRightButtonDown"/>
                        </Canvas>
                    </ScrollViewer>

                    <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" IsHitTestVisible="False"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>