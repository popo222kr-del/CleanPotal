<Window x:Class="CleanPotal.ScheduleProgramWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="세정팀 통합 근무 스케줄러" Width="1400" Height="850" 
        WindowStartupLocation="CenterOwner" Background="#F8FAFC" SnapsToDevicePixels="True" UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType" RenderOptions.BitmapScalingMode="HighQuality"
        WindowState="Maximized">

    <Window.Resources>
        <Style TargetType="ScrollBar">
            <Setter Property="Margin" Value="2,0,2,0"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <Style x:Key="TeamFilterTabStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#0F172A"/>
                                <Setter TargetName="bg" Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#2563EB"/>
                                <Setter TargetName="bg" Property="BorderThickness" Value="0"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernPillButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="19">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F1F5F9"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#CBD5E1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernToggleDarkStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="19">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1E293B"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#1E293B"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,0,30,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8"/>
                            <ToggleButton Name="ToggleButton" Focusable="false" IsChecked="{Binding Path=IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}" ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent">
                                            <Path x:Name="Arrow" Fill="#64748B" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0" Data="M0,0 L4,4 L8,0 Z"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" Margin="{TemplateBinding Padding}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" HorizontalAlignment="Left"/>
                            <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Border Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Margin="0,4,0,0" MinWidth="{TemplateBinding ActualWidth}">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#64748B" Opacity="0.1" BlurRadius="8" ShadowDepth="2"/>
                                    </Border.Effect>
                                    <ScrollViewer Margin="0,4" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#2563EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F8FAFC"/>
                                <Setter Property="Foreground" Value="#0F172A"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EFF6FF"/>
                                <Setter Property="Foreground" Value="#2563EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24,20,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="16" Padding="20,14" Margin="0,0,0,16">
            <Border.Effect>
                <DropShadowEffect Color="#64748B" Opacity="0.05" BlurRadius="12" ShadowDepth="4"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="◀" FontSize="14" Width="36" Height="36" Style="{StaticResource ModernPillButtonStyle}" Click="PrevMonth_Click" Padding="0"/>
                    <TextBlock x:Name="TxtMonthYear" Text="2026년 4월" FontSize="22" FontWeight="ExtraBold" Margin="16,0" VerticalAlignment="Center" Foreground="#0F172A"/>
                    <Button Content="▶" FontSize="14" Width="36" Height="36" Style="{StaticResource ModernPillButtonStyle}" Click="NextMonth_Click" Padding="0" Margin="0,0,24,0"/>

                    <Border Background="#F1F5F9" CornerRadius="10" Padding="4">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton Content="전체" IsChecked="True" Style="{StaticResource TeamFilterTabStyle}" Checked="TeamFilter_Changed"/>
                            <RadioButton Content="김팀" Style="{StaticResource TeamFilterTabStyle}" Checked="TeamFilter_Changed"/>
                            <RadioButton Content="장팀" Style="{StaticResource TeamFilterTabStyle}" Checked="TeamFilter_Changed"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <ToggleButton x:Name="TglPredictPattern" Content="근무 미리보기" Style="{StaticResource ModernToggleDarkStyle}" Click="TglPredictPattern_Click" Margin="0,0,12,0"/>
                    <Button x:Name="BtnOpenNewWindow" Content="이전 근무표" Style="{StaticResource ModernPillButtonStyle}" Background="#1E293B" Foreground="White" BorderThickness="0" Margin="0,0,24,0" Click="BtnOpenNewWindow_Click"/>

                    <TextBlock Text="도장 :" FontSize="14" FontWeight="Bold" Foreground="#64748B" VerticalAlignment="Center" Margin="0,0,10,0"/>

                    <Border Background="#F1F5F9" CornerRadius="8" Padding="4" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="TxtPaintDays" Text="1" Width="34" Height="30" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="15" FontWeight="Bold" Foreground="#2563EB"/>
                            <TextBlock Text="일" FontSize="13" FontWeight="Bold" Foreground="#64748B" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        </StackPanel>
                    </Border>

                    <ComboBox x:Name="CmbPaintType" Width="90" Height="38" Style="{StaticResource ModernComboBoxStyle}">
                        <ComboBoxItem Content="주간"/>
                        <ComboBoxItem Content="야간"/>
                        <ComboBoxItem Content="반차"/>
                        <ComboBoxItem Content="휴무" IsSelected="True"/>
                        <ComboBoxItem Content="연차"/>
                        <ComboBoxItem Content="특근"/>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" VerticalAlignment="Top" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="16" ClipToBounds="True">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="0,0,1,0">
                    <ScrollViewer x:Name="LeftScroll" VerticalScrollBarVisibility="Hidden">
                        <ItemsControl x:Name="LeftTeamsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <Border Height="42" Background="#F1F5F9" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                                            <StackPanel Orientation="Horizontal" Width="260">
                                                <TextBlock Text="구분" Width="60" TextAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="#94A3B8"/>
                                                <TextBlock Text="담당 업무" Width="90" TextAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="#94A3B8"/>
                                                <TextBlock Text="성명" Width="110" TextAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="#94A3B8"/>
                                            </StackPanel>
                                        </Border>
                                        <Grid Width="260">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" BorderBrush="#E2E8F0" BorderThickness="0,0,1,1">
                                                <StackPanel VerticalAlignment="Center" Margin="0,10">
                                                    <CheckBox IsChecked="{Binding IsTeamChecked}" Click="ChkTeam_Click" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                                    <TextBlock Text="{Binding TeamName}" FontSize="13" FontWeight="ExtraBold" Foreground="#1E293B" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <ItemsControl Grid.Column="1" ItemsSource="{Binding JobTitles}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="90"/>
                                                                <ColumnDefinition Width="110"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Border Grid.Column="0" BorderBrush="#E2E8F0" BorderThickness="0,0,1,1">
                                                                <TextBlock Text="{Binding JobTitle}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" FontWeight="Bold" Foreground="#64748B"/>
                                                            </Border>
                                                            <ItemsControl Grid.Column="1" ItemsSource="{Binding Rows}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border Height="40" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1">
                                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                                                <CheckBox IsChecked="{Binding IsChecked}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                                                <TextBlock Text="{Binding MemberName}" VerticalAlignment="Center" Foreground="#334155" FontWeight="Bold" FontSize="14"/>
                                                                            </StackPanel>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                        <Border Height="40" Background="#F8FAFC">
                                            <TextBlock Text="근무 인원" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" FontWeight="Bold" Foreground="#64748B"/>
                                        </Border>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <ScrollViewer x:Name="RightScroll" Grid.Column="1" HorizontalScrollBarVisibility="Auto" ScrollChanged="RightScroll_ScrollChanged">
                    <ItemsControl x:Name="RightTeamsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <Border Height="42" Background="#F1F5F9" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="65"/>
                                            </Grid.ColumnDefinitions>
                                            <ItemsControl Grid.Column="0" ItemsSource="{Binding DataContext.HeaderDays, RelativeSource={RelativeSource AncestorType=Window}}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <UniformGrid Rows="1"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border BorderBrush="#E2E8F0" BorderThickness="0,0,1,0" Background="{Binding BgBrush}">
                                                            <TextBlock Text="{Binding Text}" TextAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="{Binding FgBrush}"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <TextBlock Grid.Column="1" Text="실 근무" TextAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="#94A3B8"/>
                                        </Grid>
                                    </Border>

                                    <ItemsControl ItemsSource="{Binding JobTitles}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <ItemsControl ItemsSource="{Binding Rows}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Height="40" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="65"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <ItemsControl Grid.Column="0" ItemsSource="{Binding Cells}">
                                                                        <ItemsControl.ItemsPanel>
                                                                            <ItemsPanelTemplate>
                                                                                <UniformGrid Rows="1"/>
                                                                            </ItemsPanelTemplate>
                                                                        </ItemsControl.ItemsPanel>
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <Border BorderBrush="#F1F5F9" BorderThickness="0,0,1,0" Background="{Binding ColumnBgBrush}"
                                                                                        MouseLeftButtonDown="Cell_MouseLeftButtonDown" MouseRightButtonDown="Cell_MouseRightButtonDown" Cursor="Hand">
                                                                                    <Border Background="{Binding BgBrush}" CornerRadius="6" Margin="3,4">
                                                                                        <TextBlock Text="{Binding DisplayText}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{Binding FgBrush}" FontSize="13" FontWeight="ExtraBold"/>
                                                                                    </Border>
                                                                                </Border>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                    <TextBlock Grid.Column="1" Text="{Binding TotalWorkDays}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#2563EB" FontSize="14" FontWeight="ExtraBold"/>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Border Height="40" Background="#F8FAFC">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="65"/>
                                            </Grid.ColumnDefinitions>
                                            <ItemsControl Grid.Column="0" ItemsSource="{Binding DailyCounts}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <UniformGrid Rows="1"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Count}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="ExtraBold" Foreground="#475569" FontSize="13"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <Border Grid.Column="1" Background="#EFF6FF">
                                                <TextBlock Text="{Binding GrandTotal}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="ExtraBold" Foreground="#2563EB" FontSize="14"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>