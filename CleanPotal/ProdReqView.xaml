<UserControl x:Class="CleanPotal.ProdReqView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             RenderOptions.BitmapScalingMode="HighQuality"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <SolidColorBrush x:Key="TextPrimary" Color="#111827"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#4B5563"/>
        <SolidColorBrush x:Key="BorderLight" Color="#E5E7EB"/>
        <SolidColorBrush x:Key="BorderDark" Color="#D1D5DB"/>

        <Style x:Key="FormLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="2,0,0,6"/>
        </Style>

        <Style x:Key="InputWrapperStyle" TargetType="Border">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>

        <Style x:Key="MultiLineInputWrapperStyle" TargetType="Border" BasedOn="{StaticResource InputWrapperStyle}">
            <Setter Property="Height" Value="120"/>
        </Style>

        <Style x:Key="CleanTextBoxStyle" TargetType="TextBox">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="MultiLineTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource CleanTextBoxStyle}">
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Padding" Value="12,12"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
        </Style>

        <Style x:Key="ModalPrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#F3F4F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModalDangerButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#DC2626"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="#FECACA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FEF2F2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="12,12"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <Style x:Key="CenterCellStyle" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EFF6FF"/>
                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBlock" x:Key="GridTextStyle">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#1E293B"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="12,0,12,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="생산팀 요청 리스트" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,0,16,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="+ 새 요청 등록" Background="#2563EB" Foreground="White" FontWeight="Bold" FontSize="14" BorderThickness="0" Padding="20,10" Cursor="Hand" Click="BtnOpenRegister_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" VerticalAlignment="Top" Background="White" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" Padding="2" ClipToBounds="True">
            <DataGrid x:Name="ReqGrid" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="None"
                      Background="White" BorderThickness="0" MinRowHeight="60" CellStyle="{StaticResource CenterCellStyle}"
                      MouseDoubleClick="ReqGrid_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="선택" Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <CheckBox IsChecked="{Binding ManageChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <CheckBox.LayoutTransform>
                                            <ScaleTransform ScaleX="1.2" ScaleY="1.2"/>
                                        </CheckBox.LayoutTransform>
                                    </CheckBox>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="요청일" Binding="{Binding RequestDate, StringFormat=yyyy-MM-dd}" Width="100" ElementStyle="{StaticResource GridTextStyle}"/>
                    <DataGridTextColumn Header="예정일" Binding="{Binding DueDate, StringFormat=yyyy-MM-dd}" Width="100" ElementStyle="{StaticResource GridTextStyle}"/>

                    <DataGridTemplateColumn Header="상태" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DurationText}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="ExtraBold" FontSize="14">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#10B981"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDelayed}" Value="True">
                                                    <Setter Property="Foreground" Value="#EF4444"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding DurationText}" Value="D-Day">
                                                    <Setter Property="Foreground" Value="#F59E0B"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding DurationText}" Value="완료">
                                                    <Setter Property="Foreground" Value="#3B82F6"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding DurationText}" Value="-">
                                                    <Setter Property="Foreground" Value="#9CA3AF"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="구분" Binding="{Binding Category}" Width="100" ElementStyle="{StaticResource GridTextStyle}"/>
                    <DataGridTextColumn Header="세부위치" Binding="{Binding Location}" Width="100" ElementStyle="{StaticResource GridTextStyle}"/>
                    <DataGridTextColumn Header="요청사항" Binding="{Binding RequestDetail}" Width="2*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource GridTextStyle}">
                                <Setter Property="HorizontalAlignment" Value="Left"/>
                                <Setter Property="Margin" Value="16,0,0,0"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="TextWrapping" Value="Wrap"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Header="첨부" Width="85">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Width="38" Height="38" CornerRadius="6" BorderBrush="{StaticResource BorderDark}" BorderThickness="1"
                                        Cursor="Hand" MouseLeftButtonDown="GridThumbnail_Click"
                                        Visibility="{Binding HasRequestImage, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Border.Background>
                                        <ImageBrush ImageSource="{Binding RequestFirstImagePath}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                                    </Border.Background>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="요청자" Binding="{Binding Requester}" Width="90" ElementStyle="{StaticResource GridTextStyle}"/>

                    <DataGridTextColumn Header="조치내용" Binding="{Binding ActionDetail}" Width="1.5*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource GridTextStyle}">
                                <Setter Property="HorizontalAlignment" Value="Left"/>
                                <Setter Property="Margin" Value="16,0,0,0"/>
                                <Setter Property="Foreground" Value="#475569"/>
                                <Setter Property="TextWrapping" Value="Wrap"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Header="조치결과" Width="85">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Width="38" Height="38" CornerRadius="6" BorderBrush="{StaticResource BorderDark}" BorderThickness="1"
                                        Cursor="Hand" MouseLeftButtonDown="GridActionThumbnail_Click"
                                        Visibility="{Binding HasActionImage, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Border.Background>
                                        <ImageBrush ImageSource="{Binding ActionFirstImagePath}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                                    </Border.Background>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="담당자" Binding="{Binding Assignee}" Width="90" ElementStyle="{StaticResource GridTextStyle}"/>

                    <DataGridTemplateColumn x:Name="ManageColumn" Header="관리" Width="90" Visibility="Collapsed">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="삭제" Width="60" Height="32" Style="{StaticResource ModalDangerButtonStyle}" Click="ArchiveDelete_Click" Visibility="{Binding ManageChecked, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Background="#80111827" Visibility="{Binding IsRegisterModalOpen, Converter={StaticResource BoolToVisibilityConverter}}" Panel.ZIndex="20">
            <Border Background="#FFFFFF" BorderThickness="0" CornerRadius="16" MaxWidth="900" MaxHeight="800" Margin="40" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="30,24,30,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="새 요청 등록" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="요청일과 요청자는 시스템에서 자동 입력됩니다." Margin="0,4,0,0" FontSize="14" Foreground="{StaticResource TextSecondary}"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="✕" Width="36" Height="36" FontSize="16" Foreground="{StaticResource TextSecondary}" Background="Transparent" BorderThickness="0" Click="CloseRegisterModal_Click" VerticalAlignment="Top"/>
                    </Grid>
                    <Rectangle Grid.Row="1" Height="1" Fill="{StaticResource BorderLight}"/>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="30,24,30,24">
                        <StackPanel>
                            <Grid Margin="0,0,0,24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="구분 (위치)" Style="{StaticResource FormLabelStyle}"/>
                                    <Border Style="{StaticResource InputWrapperStyle}">
                                        <ComboBox Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="8,0" 
                                                  ItemsSource="{Binding ReqLocations}" SelectedItem="{Binding EditLocation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="세부 위치" Style="{StaticResource FormLabelStyle}"/>
                                    <Border Style="{StaticResource InputWrapperStyle}">
                                        <ComboBox Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="8,0" 
                                                  ItemsSource="{Binding ReqSubLocations}" SelectedItem="{Binding EditSubLocation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="요청 분류 (내용)" Style="{StaticResource FormLabelStyle}"/>
                                    <Border Style="{StaticResource InputWrapperStyle}">
                                        <ComboBox Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="8,0" 
                                                  ItemsSource="{Binding ReqContentTypes}" SelectedItem="{Binding EditContentType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="요청일" Style="{StaticResource FormLabelStyle}"/>
                                    <Border Height="42" Background="#F3F4F6" BorderBrush="{StaticResource BorderDark}" BorderThickness="1" CornerRadius="6" Padding="12,0">
                                        <TextBlock Text="{Binding EditRequestDate, StringFormat=yyyy-MM-dd}" VerticalAlignment="Center" Foreground="#4B5563" FontSize="14" FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="요청자" Style="{StaticResource FormLabelStyle}"/>
                                    <Border Height="42" Background="#F3F4F6" BorderBrush="{StaticResource BorderDark}" BorderThickness="1" CornerRadius="6" Padding="12,0">
                                        <TextBlock Text="{Binding EditRequester}" VerticalAlignment="Center" Foreground="#4B5563" FontSize="14" FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="1.5*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="상세 요청사항" Style="{StaticResource FormLabelStyle}"/>
                                    <Border Style="{StaticResource MultiLineInputWrapperStyle}">
                                        <TextBox Style="{StaticResource MultiLineTextBoxStyle}" Text="{Binding EditRequestDetail, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="이미지 첨부" Style="{StaticResource FormLabelStyle}"/>
                                    <Border Style="{StaticResource MultiLineInputWrapperStyle}" BorderBrush="#9CA3AF" BorderThickness="1" Height="50">
                                        <TextBox Style="{StaticResource MultiLineTextBoxStyle}" Padding="12,12" TextWrapping="NoWrap" AcceptsReturn="False" VerticalScrollBarVisibility="Hidden"
                                                 PreviewDragOver="RegisterModalMemo_PreviewDragOver" Drop="RegisterModalMemo_Drop" PreviewKeyDown="RegisterModalMemo_PreviewKeyDown" AllowDrop="True"
                                                 ToolTip="여기를 클릭하고 이미지를 Ctrl+V 하거나 드래그하여 놓으세요." Text="여기에 이미지를 붙여넣으세요"/>
                                    </Border>
                                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="0,12,0,0" Height="58">
                                        <ItemsControl ItemsSource="{Binding RegisterModalAttachmentPaths}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,8,0" Width="52" Height="52">
                                                        <Border CornerRadius="4" BorderBrush="{StaticResource BorderDark}" BorderThickness="1" Cursor="Hand" MouseLeftButtonDown="ModalThumbnail_Click" ClipToBounds="True">
                                                            <Border.Background>
                                                                <ImageBrush ImageSource="{Binding}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                            </Border.Background>
                                                        </Border>
                                                        <Button Content="✕" Width="20" Height="20" Background="#EF4444" Foreground="White" FontWeight="Bold" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-6,-6,0" BorderThickness="0" Cursor="Hand" Click="RegisterDeleteAttachment_Click">
                                                            <Button.Resources>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="CornerRadius" Value="10"/>
                                                                </Style>
                                                            </Button.Resources>
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-1,0,0"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>

                    <Rectangle Grid.Row="3" Height="1" Fill="{StaticResource BorderLight}"/>
                    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="30,20,30,24">
                        <Button Content="초기화" Style="{StaticResource ModalPrimaryButtonStyle}" Width="100" Margin="0,0,12,0" Click="BtnResetRegister_Click"/>
                        <Button Content="요청 등록하기" Style="{StaticResource ModalPrimaryButtonStyle}" Background="#2563EB" Foreground="White" BorderThickness="0" Width="180" Click="BtnSaveRegister_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>

        <Border Background="#80111827" Visibility="{Binding IsActionModalOpen, Converter={StaticResource BoolToVisibilityConverter}}" Panel.ZIndex="21">
            <Border Background="#FFFFFF" BorderThickness="0" CornerRadius="16" MaxWidth="900" MaxHeight="800" Margin="40" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="30,24,30,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="요청 사항 조치 (수정)" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="상태를 완료로 변경하면 조치일이 오늘로 자동 고정됩니다." Margin="0,4,0,0" FontSize="14" Foreground="{StaticResource TextSecondary}"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="✕" Width="36" Height="36" FontSize="16" Foreground="{StaticResource TextSecondary}" Background="Transparent" BorderThickness="0" Click="CloseActionModal_Click" VerticalAlignment="Top"/>
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="30,0,30,24">
                        <StackPanel>
                            <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,24">
                                <StackPanel>
                                    <TextBlock Text="요청 원본 정보" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,12"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="{Binding ReadCategoryLoc}" FontWeight="Bold" Foreground="#0F172A" FontSize="15" Margin="0,0,20,0"/>
                                        <TextBlock Text="{Binding ReadDates}" Foreground="#475569" FontSize="14" Margin="0,0,20,0"/>
                                        <TextBlock Text="{Binding ReadRequester}" Foreground="#475569" FontSize="14"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding ReadRequestDetail}" TextWrapping="Wrap" Foreground="#334155" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>

                                    <ItemsControl ItemsSource="{Binding ReadRequestImages}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,8,0" Width="60" Height="60" CornerRadius="6" BorderBrush="{StaticResource BorderDark}" BorderThickness="1" Cursor="Hand" MouseLeftButtonDown="ModalThumbnail_Click" ClipToBounds="True">
                                                    <Border.Background>
                                                        <ImageBrush ImageSource="{Binding}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                    </Border.Background>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="진행 상태" Style="{StaticResource FormLabelStyle}" Foreground="#2563EB"/>
                                    <Border Style="{StaticResource InputWrapperStyle}" BorderBrush="#2563EB" BorderThickness="2">
                                        <ComboBox Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="8,0" FontWeight="Bold" Foreground="#1E40AF"
                                                  ItemsSource="{Binding ActionStatusOptions}"
                                                  SelectedItem="{Binding ActionStatus, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                        </ComboBox>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="조치 예정일" Style="{StaticResource FormLabelStyle}"/>
                                    <Border Style="{StaticResource InputWrapperStyle}">
                                        <DatePicker Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" SelectedDate="{Binding ActionDueDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="조치일 (고정)" Style="{StaticResource FormLabelStyle}"/>
                                    <Border Height="42" Background="#F3F4F6" BorderBrush="{StaticResource BorderDark}" BorderThickness="1" CornerRadius="6" Padding="12,0">
                                        <TextBlock Text="{Binding ActionDateDisplay}" VerticalAlignment="Center" Foreground="#4B5563" FontSize="14" FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Column="6">
                                    <TextBlock Text="담당자" Style="{StaticResource FormLabelStyle}"/>
                                    <Border Style="{StaticResource InputWrapperStyle}">
                                        <TextBox Style="{StaticResource CleanTextBoxStyle}" Text="{Binding ActionAssignee, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="1.5*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="조치 세부 내용" Style="{StaticResource FormLabelStyle}"/>
                                    <Border Style="{StaticResource MultiLineInputWrapperStyle}">
                                        <TextBox Style="{StaticResource MultiLineTextBoxStyle}" Text="{Binding ActionDetail, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="조치 결과 사진 첨부" Style="{StaticResource FormLabelStyle}"/>
                                    <Border Style="{StaticResource MultiLineInputWrapperStyle}" BorderBrush="#9CA3AF" BorderThickness="1" Height="50">
                                        <TextBox Style="{StaticResource MultiLineTextBoxStyle}" Padding="12,12" TextWrapping="NoWrap" AcceptsReturn="False" VerticalScrollBarVisibility="Hidden"
                                                 PreviewDragOver="ActionModalMemo_PreviewDragOver" Drop="ActionModalMemo_Drop" PreviewKeyDown="ActionModalMemo_PreviewKeyDown" AllowDrop="True"
                                                 ToolTip="결과 사진을 Ctrl+V 하거나 드래그하여 놓으세요." Text="여기에 이미지를 붙여넣으세요..."/>
                                    </Border>
                                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="0,12,0,0" Height="58">
                                        <ItemsControl ItemsSource="{Binding ActionModalAttachmentPaths}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,8,0" Width="52" Height="52">
                                                        <Border CornerRadius="4" BorderBrush="{StaticResource BorderDark}" BorderThickness="1" Cursor="Hand" MouseLeftButtonDown="ModalThumbnail_Click" ClipToBounds="True">
                                                            <Border.Background>
                                                                <ImageBrush ImageSource="{Binding}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                            </Border.Background>
                                                        </Border>
                                                        <Button Content="✕" Width="20" Height="20" Background="#EF4444" Foreground="White" FontWeight="Bold" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-6,-6,0" BorderThickness="0" Cursor="Hand" Click="ActionDeleteAttachment_Click">
                                                            <Button.Resources>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="CornerRadius" Value="10"/>
                                                                </Style>
                                                            </Button.Resources>
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-1,0,0"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>

                    <Rectangle Grid.Row="2" Height="1" Fill="{StaticResource BorderLight}" VerticalAlignment="Bottom"/>
                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="30,20,30,24">
                        <Button Content="취소" Style="{StaticResource ModalPrimaryButtonStyle}" Width="100" Margin="0,0,12,0" Click="CloseActionModal_Click"/>
                        <Button Content="수정/조치 완료" Style="{StaticResource ModalPrimaryButtonStyle}" Background="#2563EB" Foreground="White" BorderThickness="0" Width="180" Click="BtnSaveAction_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>