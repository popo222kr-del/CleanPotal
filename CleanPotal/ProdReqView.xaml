<UserControl x:Class="CleanPotal.ProdReqView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent" SnapsToDevicePixels="True" UseLayoutRounding="True"
             TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType" RenderOptions.BitmapScalingMode="HighQuality">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <SolidColorBrush x:Key="TextPrimary" Color="#111827"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#4B5563"/>
        <SolidColorBrush x:Key="BorderLight" Color="#E5E7EB"/>
        <SolidColorBrush x:Key="BorderDark" Color="#D1D5DB"/>

        <Style x:Key="SegmentedTabStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,4"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#0F172A"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="#E2E8F0"/>
                                <Setter Property="Foreground" Value="#0F172A"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 🎨 알약 모양 토글 (대시보드 접기/펴기 스타일) -->
        <Style x:Key="PillToggleStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="14" BorderBrush="#CBD5E1" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect Color="#94A3B8" Opacity="0.18" BlurRadius="6" ShadowDepth="1"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#DBEAFE"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3B82F6"/>
                                <Setter Property="Foreground" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3B82F6"/>
                                <Setter Property="Foreground" Value="#1D4ED8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FormLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="2,0,0,6"/>
        </Style>
        <Style x:Key="InputWrapperStyle" TargetType="Border">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style x:Key="MultiLineTextBoxStyle" TargetType="TextBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="ModalPrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#F3F4F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModalDangerButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="#FEE2E2"/>
            <Setter Property="Foreground" Value="#DC2626"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="12,12"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <Style x:Key="CenterCellStyle" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EFF6FF"/>
                    <Setter Property="Foreground" Value="#111827"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBlock" x:Key="GridTextStyle">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#1E293B"/>
        </Style>

        <!-- 🎨 노션/맥 스타일 컬럼 헤더: 작고 옅은 회색 글씨 -->
        <Style x:Key="ProdReqColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#F1F5F9"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="6,0"/>
        </Style>

        <!-- 🎨 행 호버: 옅은 회색 (파란 배경 → 미니멀 회색) -->
        <Style x:Key="ProdReqRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8FAFC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#CBD5E1" CornerRadius="4"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition x:Name="TopRow" Height="6*" MinHeight="120"/>
            <RowDefinition x:Name="SplitterRow" Height="36"/>
            <RowDefinition x:Name="BottomRow" Height="4*" MinHeight="120"/>
        </Grid.RowDefinitions>

        <!-- 🎨 상단 카드: 노션/맥 스타일 미니멀 컨테이너 -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="10" ClipToBounds="True">
            <Border.Effect>
                <DropShadowEffect Color="#94A3B8" Opacity="0.06" BlurRadius="12" ShadowDepth="1"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <!-- 헤더: 흰색 + 하단 구분선 한 줄 -->
                <Border Background="White" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="진행 및 보류 중인 요청" FontWeight="Bold" Foreground="#0F172A" FontSize="14" VerticalAlignment="Center" Margin="0,0,20,0"/>
                            <RadioButton x:Name="TabAll" Style="{StaticResource SegmentedTabStyle}" IsChecked="True" Checked="FilterTab_Checked">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="전체" VerticalAlignment="Center"/>
                                    <Border Background="#F1F5F9" CornerRadius="9" MinWidth="22" Height="18" Margin="6,0,0,0" Padding="6,0">
                                        <TextBlock x:Name="CountAll" Text="0" FontSize="11" FontWeight="Bold" Foreground="#475569" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="TabInProgress" Style="{StaticResource SegmentedTabStyle}" Checked="FilterTab_Checked">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="진행" VerticalAlignment="Center"/>
                                    <Border Background="#DCFCE7" CornerRadius="9" MinWidth="22" Height="18" Margin="6,0,0,0" Padding="6,0">
                                        <TextBlock x:Name="CountInProgress" Text="0" FontSize="11" FontWeight="Bold" Foreground="#15803D" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="TabPending" Style="{StaticResource SegmentedTabStyle}" Checked="FilterTab_Checked">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="보류" VerticalAlignment="Center"/>
                                    <Border Background="#FEF3C7" CornerRadius="9" MinWidth="22" Height="18" Margin="6,0,0,0" Padding="6,0">
                                        <TextBlock x:Name="CountPending" Text="0" FontSize="11" FontWeight="Bold" Foreground="#B45309" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                            </RadioButton>
                        </StackPanel>
                    </Grid>
                </Border>
                <DataGrid x:Name="ReqGrid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9" Background="White" BorderThickness="0" MinRowHeight="56" AlternationCount="2" CellStyle="{StaticResource CenterCellStyle}" RowStyle="{StaticResource ProdReqRowStyle}" ColumnHeaderStyle="{StaticResource ProdReqColumnHeaderStyle}" MouseDoubleClick="ReqGrid_MouseDoubleClick" VirtualizingPanel.ScrollUnit="Pixel">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="선택" Width="50">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding ManageChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="요청일" Binding="{Binding RequestDate, StringFormat=yyyy-MM-dd}" Width="90" ElementStyle="{StaticResource GridTextStyle}"/>
                        <DataGridTemplateColumn Header="상태" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <!-- 🎨 미니멀 칩: 점 + 텍스트, 모델의 색상 속성 사용 -->
                                    <Border CornerRadius="10" Padding="8,3" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding StatusBackground}"/>
                                        </Border.Background>
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="6" Height="6" VerticalAlignment="Center" Margin="0,0,6,0">
                                                <Ellipse.Fill>
                                                    <SolidColorBrush Color="{Binding StatusForeground}"/>
                                                </Ellipse.Fill>
                                            </Ellipse>
                                            <TextBlock Text="{Binding DurationText}" FontWeight="Bold" FontSize="12" VerticalAlignment="Center">
                                                <TextBlock.Foreground>
                                                    <SolidColorBrush Color="{Binding StatusForeground}"/>
                                                </TextBlock.Foreground>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="구분" Binding="{Binding Category}" Width="80" ElementStyle="{StaticResource GridTextStyle}"/>

                        <DataGridTemplateColumn Header="요청사항" Width="1.5*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="5,0,5,0" VerticalAlignment="Center" HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding RequestContentTypeTag}" Foreground="#2563EB" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding RequestDetailText}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="첨부(요청)" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ItemsControl ItemsSource="{Binding RequestImagePaths}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="32" Height="32" Margin="2" CornerRadius="6" BorderBrush="#BFDBFE" BorderThickness="1" Cursor="Hand" MouseLeftButtonDown="GridThumbnail_Click" ToolTip="요청 첨부">
                                                    <Border.Background>
                                                        <ImageBrush ImageSource="{Binding}" Stretch="UniformToFill"/>
                                                    </Border.Background>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="요청자 / 담당자" Width="140">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <!-- 🎨 미니멀: 컬러 점 + 라벨 + 이름 (테두리/배경 박스 제거) -->
                                    <StackPanel VerticalAlignment="Center" Margin="10,6">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                            <Ellipse Width="6" Height="6" Fill="#3B82F6" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="요청" FontSize="11" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding Requester}" FontSize="13" FontWeight="SemiBold" Foreground="#0F172A" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="6" Height="6" Fill="#10B981" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="담당" FontSize="11" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding Assignee}" FontSize="13" FontWeight="SemiBold" Foreground="#0F172A" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="조치내용" Width="1.5*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding ActionDetail}" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5,0,5,0" Foreground="#475569"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="첨부(조치)" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ItemsControl ItemsSource="{Binding ActionImagePaths}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="32" Height="32" Margin="2" CornerRadius="6" BorderBrush="#A7F3D0" BorderThickness="1" Cursor="Hand" MouseLeftButtonDown="GridActionThumbnail_Click" ToolTip="조치 첨부">
                                                    <Border.Background>
                                                        <ImageBrush ImageSource="{Binding}" Stretch="UniformToFill"/>
                                                    </Border.Background>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn x:Name="ReqGrid_ManageColumn" Header="삭제" Width="70" Visibility="Collapsed">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="삭제" Style="{StaticResource ModalDangerButtonStyle}" Click="ArchiveDelete_Click"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- 🎨 분할 영역: 가운데 알약 모양 "접기/펴기" 토글 + 드래그 가능 GridSplitter -->
        <Grid Grid.Row="1">
            <GridSplitter Height="12" HorizontalAlignment="Stretch" VerticalAlignment="Center" Background="Transparent" Cursor="SizeNS" ShowsPreview="True" ResizeBehavior="PreviousAndNext" ResizeDirection="Rows">
                <GridSplitter.Template>
                    <ControlTemplate TargetType="GridSplitter">
                        <Grid Background="Transparent">
                            <Border x:Name="Handle" Width="48" Height="4" CornerRadius="2" Background="#CBD5E1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Handle" Property="Background" Value="#3B82F6"/>
                                <Setter TargetName="Handle" Property="Width" Value="64"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="Handle" Property="Background" Value="#2563EB"/>
                                <Setter TargetName="Handle" Property="Height" Value="6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </GridSplitter.Template>
            </GridSplitter>

            <!-- 알약 모양 토글: 위로 누르면 상단 접힘, 아래로 누르면 하단 접힘 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <ToggleButton x:Name="BtnToggleTop" Style="{StaticResource PillToggleStyle}" Click="BtnToggleTop_Click" ToolTip="진행 목록 접기/펴기">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="ToggleTopIcon" Text="▲" FontSize="9" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="ToggleTopText" Text="진행 목록 접기" VerticalAlignment="Center"/>
                    </StackPanel>
                </ToggleButton>
                <ToggleButton x:Name="BtnToggleBottom" Style="{StaticResource PillToggleStyle}" Click="BtnToggleBottom_Click" ToolTip="조치 완료 접기/펴기" Margin="6,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="ToggleBottomText" Text="조치 완료 접기" VerticalAlignment="Center"/>
                        <TextBlock x:Name="ToggleBottomIcon" Text="▼" FontSize="9" Margin="5,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </ToggleButton>
            </StackPanel>
        </Grid>

        <!-- 🎨 하단 카드: 동일한 미니멀 컨테이너 -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="10" ClipToBounds="True">
            <Border.Effect>
                <DropShadowEffect Color="#94A3B8" Opacity="0.06" BlurRadius="12" ShadowDepth="1"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Background="White" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Padding="16,12">
                    <Grid>
                        <TextBlock Text="조치 완료 내역 (최근)" FontWeight="Bold" Foreground="#0F172A" FontSize="14" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
                <DataGrid x:Name="HistoryGrid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9" Background="White" BorderThickness="0" MinRowHeight="56" AlternationCount="2" CellStyle="{StaticResource CenterCellStyle}" RowStyle="{StaticResource ProdReqRowStyle}" ColumnHeaderStyle="{StaticResource ProdReqColumnHeaderStyle}" MouseDoubleClick="ReqGrid_MouseDoubleClick" VirtualizingPanel.ScrollUnit="Pixel">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="선택" Width="50">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding ManageChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="완료일" Binding="{Binding ActionDate, StringFormat=yyyy-MM-dd}" Width="100" ElementStyle="{StaticResource GridTextStyle}"/>
                        <DataGridTextColumn Header="구분" Binding="{Binding Category}" Width="90" ElementStyle="{StaticResource GridTextStyle}"/>

                        <DataGridTemplateColumn Header="요청내용" Width="1.5*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding RequestDetailText}" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5,0,5,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="첨부(요청)" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ItemsControl ItemsSource="{Binding RequestImagePaths}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="32" Height="32" Margin="2" CornerRadius="6" BorderBrush="#BFDBFE" BorderThickness="1" Cursor="Hand" MouseLeftButtonDown="GridThumbnail_Click" ToolTip="요청 첨부">
                                                    <Border.Background>
                                                        <ImageBrush ImageSource="{Binding}" Stretch="UniformToFill"/>
                                                    </Border.Background>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="요청자 / 담당자" Width="140">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <!-- 🎨 미니멀: 컬러 점 + 라벨 + 이름 (테두리/배경 박스 제거) -->
                                    <StackPanel VerticalAlignment="Center" Margin="10,6">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                            <Ellipse Width="6" Height="6" Fill="#3B82F6" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="요청" FontSize="11" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding Requester}" FontSize="13" FontWeight="SemiBold" Foreground="#0F172A" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="6" Height="6" Fill="#10B981" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="담당" FontSize="11" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding Assignee}" FontSize="13" FontWeight="SemiBold" Foreground="#0F172A" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="조치내용" Width="1.5*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding ActionDetail}" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5,0,5,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="조치결과" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ItemsControl ItemsSource="{Binding ActionImagePaths}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="32" Height="32" Margin="2" CornerRadius="6" BorderBrush="#A7F3D0" BorderThickness="1" Cursor="Hand" MouseLeftButtonDown="GridActionThumbnail_Click" ToolTip="조치 첨부">
                                                    <Border.Background>
                                                        <ImageBrush ImageSource="{Binding}" Stretch="UniformToFill"/>
                                                    </Border.Background>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn x:Name="HistoryGrid_ManageColumn" Header="삭제" Width="70" Visibility="Collapsed">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="삭제" Style="{StaticResource ModalDangerButtonStyle}" Click="ArchiveDelete_Click"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Background="#80111827" Visibility="{Binding IsRegisterModalOpen, Converter={StaticResource BoolToVisibilityConverter}}" Panel.ZIndex="50" Grid.RowSpan="3">
            <Border Background="White" CornerRadius="12" MaxWidth="650" Padding="30" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="새 요청 등록" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="구분" Style="{StaticResource FormLabelStyle}"/>
                            <Border Style="{StaticResource InputWrapperStyle}" Margin="0,0,0,0">
                                <ComboBox ItemsSource="{Binding ReqLocations}" SelectedItem="{Binding EditLocation, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" BorderThickness="0" FontSize="14" Padding="6,0" VerticalContentAlignment="Center"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="세부 위치" Style="{StaticResource FormLabelStyle}"/>
                            <Border Style="{StaticResource InputWrapperStyle}" Margin="0,0,0,0">
                                <ComboBox ItemsSource="{Binding ReqSubLocations}" SelectedItem="{Binding EditSubLocation, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" BorderThickness="0" FontSize="14" Padding="6,0" VerticalContentAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="요청 분류" Style="{StaticResource FormLabelStyle}"/>
                    <Border Style="{StaticResource InputWrapperStyle}" Margin="0,0,0,20">
                        <ComboBox ItemsSource="{Binding ReqContentTypes}" SelectedItem="{Binding EditContentType, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" BorderThickness="0" FontSize="14" Padding="6,0" VerticalContentAlignment="Center"/>
                    </Border>
                    <TextBlock Text="상세 요청사항" Style="{StaticResource FormLabelStyle}"/>
                    <Border Style="{StaticResource InputWrapperStyle}" Height="120" Margin="0,0,0,20">
                        <TextBox Style="{StaticResource MultiLineTextBoxStyle}" Text="{Binding EditRequestDetail, UpdateSourceTrigger=PropertyChanged}"/>
                    </Border>
                    <TextBlock Text="이미지 첨부 (Ctrl+V 또는 드래그)" Style="{StaticResource FormLabelStyle}"/>
                    <Border Height="100" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6" Padding="10" AllowDrop="True" PreviewDragOver="RegisterModalMemo_PreviewDragOver" Drop="RegisterModalMemo_Drop" PreviewKeyDown="RegisterModalMemo_PreviewKeyDown">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding RegisterModalAttachmentPaths}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,10,0">
                                            <Border Width="70" Height="70" CornerRadius="6" BorderBrush="#CBD5E1" BorderThickness="1" ClipToBounds="True">
                                                <Image Source="{Binding}" Stretch="UniformToFill"/>
                                            </Border>
                                            <Button Content="✕" Width="20" Height="20" Background="#EF4444" Foreground="White" FontWeight="Bold" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,-5,-5,0" Click="RegisterDeleteAttachment_Click">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,25,0,0">
                        <Button Content="취소" Width="100" Height="40" Click="CloseRegisterModal_Click" Margin="0,0,10,0" Style="{StaticResource ModalPrimaryButtonStyle}"/>
                        <Button Content="요청 등록" Width="150" Height="40" Background="#2563EB" Foreground="White" Click="BtnSaveRegister_Click" Style="{StaticResource ModalPrimaryButtonStyle}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <Border Background="#80111827" Visibility="{Binding IsActionModalOpen, Converter={StaticResource BoolToVisibilityConverter}}" Panel.ZIndex="51" Grid.RowSpan="3">
            <Border Background="White" CornerRadius="12" MaxWidth="750" Padding="30" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="요청 사항 조치 및 수정" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
                    <Border Background="#F8FAFC" CornerRadius="8" Padding="15" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="[원본 요청사항]" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding EditableRequestDetail, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="{Binding IsRequestInfoReadOnly}" TextWrapping="Wrap" AcceptsReturn="True" Background="Transparent" BorderThickness="0" FontSize="14"/>
                            <ItemsControl ItemsSource="{Binding RequestEditAttachmentPaths}" Margin="0,10,0,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,10,5">
                                            <Border Width="50" Height="50" CornerRadius="4" BorderBrush="#D1D5DB" BorderThickness="1" ClipToBounds="True" MouseLeftButtonDown="ModalThumbnail_Click">
                                                <Image Source="{Binding}" Stretch="UniformToFill"/>
                                            </Border>
                                            <Button Content="✕" Width="16" Height="16" Background="#EF4444" Foreground="White" Click="RequestEditDeleteAttachment_Click" Visibility="{Binding DataContext.CanEditRequestInfo, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- 🔥 누락 복원: 상태 / 담당자 / 조치 예정일 -->
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="상태" Style="{StaticResource FormLabelStyle}"/>
                            <Border Style="{StaticResource InputWrapperStyle}">
                                <ComboBox ItemsSource="{Binding ActionStatusOptions}" SelectedItem="{Binding ActionStatus, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" BorderThickness="0" FontSize="14" Padding="6,0" VerticalContentAlignment="Center"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="담당자 (자동 기록)" Style="{StaticResource FormLabelStyle}"/>
                            <Border Background="#F1F5F9" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="6" Height="40" ToolTip="저장 시 현재 로그인 사용자가 자동으로 기록됩니다">
                                <Grid Margin="10,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="🔒" FontSize="12" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Grid.Column="1" Text="{Binding ActionAssignee}" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="자동" FontSize="10" FontWeight="Bold" Foreground="#64748B" VerticalAlignment="Center" Background="#E2E8F0" Padding="6,2"/>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <TextBlock Text="조치 예정일" Style="{StaticResource FormLabelStyle}"/>
                            <Border Style="{StaticResource InputWrapperStyle}">
                                <DatePicker SelectedDate="{Binding ActionDueDate, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" BorderThickness="0" FontSize="14" Padding="4,0" VerticalContentAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="조치 내용" Style="{StaticResource FormLabelStyle}"/>
                    <Border Style="{StaticResource InputWrapperStyle}" Height="100" Margin="0,0,0,15">
                        <TextBox Style="{StaticResource MultiLineTextBoxStyle}" Text="{Binding ActionDetail, UpdateSourceTrigger=PropertyChanged}"/>
                    </Border>

                    <TextBlock Text="조치 결과 사진 (Ctrl+V 또는 드래그)" Style="{StaticResource FormLabelStyle}"/>
                    <Border Height="90" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6" Padding="8" AllowDrop="True" PreviewDragOver="ActionModalMemo_PreviewDragOver" Drop="ActionModalMemo_Drop" PreviewKeyDown="ActionModalMemo_PreviewKeyDown">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding ActionModalAttachmentPaths}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,10,0">
                                            <Border Width="65" Height="65" CornerRadius="5" BorderBrush="#CBD5E1" BorderThickness="1" ClipToBounds="True">
                                                <Image Source="{Binding}" Stretch="UniformToFill"/>
                                            </Border>
                                            <Button Content="✕" Width="18" Height="18" Background="#EF4444" Foreground="White" Click="ActionDeleteAttachment_Click" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-4,-4,0">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,25,0,0">
                        <Button Content="닫기" Width="100" Height="40" Click="CloseActionModal_Click" Margin="0,0,10,0" Style="{StaticResource ModalPrimaryButtonStyle}"/>
                        <Button Content="조치/수정 완료" Width="180" Height="40" Background="#2563EB" Foreground="White" BorderThickness="0" Click="BtnSaveAction_Click" Style="{StaticResource ModalPrimaryButtonStyle}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>