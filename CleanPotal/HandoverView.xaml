                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="내용" Width="1.5*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,6">
                                            <TextBlock Text="{Binding Content}" FontSize="15" Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap" HorizontalAlignment="Left"/>
                                            <TextBlock Text="{Binding CreatorText}" FontSize="11" Foreground="#9CA3AF" Margin="0,4,0,0" HorizontalAlignment="Left"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="입고일" Binding="{Binding InDate, StringFormat=yyyy-MM-dd}" Width="110" ElementStyle="{StaticResource CenterTextBlockStyle}"/>
                            <DataGridTextColumn Header="출고일" Binding="{Binding OutDate, StringFormat=yyyy-MM-dd}" Width="110" ElementStyle="{StaticResource CenterTextBlockStyle}"/>
                            <DataGridTextColumn Header="상태" Binding="{Binding Status}" Width="90" ElementStyle="{StaticResource StatusTextBlockStyle}"/>

                            <DataGridTemplateColumn Header="메모" Width="1.8*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Left" Margin="12,6">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="38" Height="38" Margin="0,0,12,0" CornerRadius="8" BorderBrush="{StaticResource BorderDark}" BorderThickness="1"
                                                        Cursor="Hand" MouseLeftButtonDown="GridThumbnail_Click"
                                                        Visibility="{Binding HasImage, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <Border.Background>
                                                        <ImageBrush ImageSource="{Binding FirstImagePath}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                    </Border.Background>
                                                </Border>
                                                <TextBlock Text="{Binding DisplayMemoText}" VerticalAlignment="Center" TextWrapping="Wrap" Foreground="{StaticResource TextSecondary}" MaxWidth="280" FontSize="15"
                                                           Visibility="{Binding HasText, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding ModifierText}" FontSize="11" Foreground="#9CA3AF" Margin="0,4,0,0" Visibility="{Binding HasModifier, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="담당자" Binding="{Binding Owner}" Width="0.9*" ElementStyle="{StaticResource CenterTextBlockStyle}"/>

                            <DataGridTemplateColumn Header="납품" Width="60">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DeliveryIcon}" FontFamily="Segoe UI Emoji" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="{Binding DeliveryMethod}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="관리" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="삭제" Width="60" Height="32" Style="{StaticResource ModalDangerButtonStyle}" Click="DoneDelete_Click"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Border>

        <Border Background="#80111827" Visibility="{Binding IsNoticeModalOpen, Converter={StaticResource BoolToVisibilityConverter}}" Panel.ZIndex="23">
            <Border Background="#FFFFFF" BorderThickness="0" CornerRadius="20" MaxWidth="800" MaxHeight="700" Margin="40" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.15" BlurRadius="20" Direction="270" ShadowDepth="10"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="30,24,30,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="공지사항 관리" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="✕" Width="36" Height="36" FontSize="16" Foreground="{StaticResource TextSecondary}" Background="Transparent" BorderThickness="0" Click="CloseNoticeModal_Click" VerticalAlignment="Top"/>
                    </Grid>
                    <Rectangle Grid.Row="1" Height="1" Fill="{StaticResource BorderLight}"/>
                    <Grid Grid.Row="2" Margin="30,24,30,24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource InputWrapperStyle}" Height="Auto" MinHeight="42">
                                <TextBox x:Name="NoticeInputBox" Style="{StaticResource CleanTextBoxStyle}" AcceptsReturn="True" TextWrapping="Wrap" MaxHeight="120" Padding="12,10" KeyDown="NoticeInputBox_KeyDown" ToolTip="공지사항을 입력하세요..."/>
                            </Border>
                            <Button Grid.Column="2" Content="공지 추가" Style="{StaticResource ModalPrimaryButtonStyle}" Background="#111827" Foreground="White" Width="100" Click="AddNotice_Click" VerticalAlignment="Bottom"/>
                        </Grid>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding NoticeItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#F9FAFB" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" CornerRadius="8" Padding="16,12" Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="•" Foreground="#6B7280" FontSize="18" Margin="0,-2,12,0" VerticalAlignment="Top"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Text}" TextWrapping="Wrap" Foreground="{StaticResource TextPrimary}" FontSize="14" LineHeight="22" VerticalAlignment="Center"/>
                                                <Button Grid.Column="2" Content="✕" Width="28" Height="28" Background="Transparent" Foreground="{StaticResource TextSecondary}" BorderThickness="0" FontSize="14" FontWeight="Bold" Cursor="Hand" Click="DeleteNotice_Click" Margin="12,0,0,0" VerticalAlignment="Top"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>